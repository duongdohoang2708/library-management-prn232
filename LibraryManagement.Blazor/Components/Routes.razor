<CascadingAuthenticationState>
    <Router AppAssembly="typeof(Program).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)">
                <NotAuthorized>
                    <AuthRedirect />
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </Found>
        <NotFound>
            <LayoutView Layout="typeof(Layout.MainLayout)">
                <div class="flex flex-1 items-center justify-center px-8 py-16">
                    <div class="w-full max-w-xl rounded-[2rem] border border-white/10 bg-black/20 p-10 text-center backdrop-blur">
                        <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-white/5 text-primary">
                            <span class="material-symbols-outlined text-4xl">search_off</span>
                        </div>
                        <h1 class="mt-6 text-4xl font-black text-white">Route not found</h1>
                        <p class="mt-4 text-sm leading-7 text-white/60">
                            The page you requested does not exist or is no longer available.
                        </p>
                        <div class="mt-8 flex justify-center gap-3">
                            <a href="/" class="rounded-full border border-white/10 bg-white/5 px-5 py-2.5 text-sm text-white/70 transition hover:border-primary/30 hover:text-white">Back to home</a>
                            <a href="/Books/ViewBooks" class="rounded-full bg-primary px-5 py-2.5 text-sm font-semibold text-background-dark transition hover:brightness-105">Browse books</a>
                        </div>
                    </div>
                </div>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
