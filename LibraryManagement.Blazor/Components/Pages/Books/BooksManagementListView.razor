@namespace LibraryManagement.Blazor.Components.Pages
@using LibraryManagementDAL.DTO.Book

<div class="flex flex-1 overflow-hidden">
    <div class="custom-scrollbar flex-1 overflow-y-auto px-8 py-12">
        @if (NewBookId.HasValue)
        {
            <div class="mb-8 flex flex-col items-start justify-between gap-4 rounded-xl border border-green-500/20 bg-green-500/10 p-4 sm:flex-row sm:items-center">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-green-400">check_circle</span>
                    <div>
                        <strong class="block text-green-400">Book created successfully!</strong>
                        <span class="text-sm text-green-400/80">Would you like to manage physical copies for this new book?</span>
                    </div>
                </div>
                <a href="/Inventory/ManageCopies?bookId=@NewBookId" class="flex w-max items-center gap-2 whitespace-nowrap rounded-lg border border-green-500/30 bg-green-500/20 px-5 py-2.5 font-bold text-green-300 transition-colors hover:bg-green-500/30">
                    <span class="material-symbols-outlined text-[18px]">inventory_2</span>
                    Manage Copies
                </a>
            </div>
        }

        <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div>
                <h2 class="mb-1 text-3xl font-bold text-white">Book Catalog Management</h2>
                <p class="text-sm text-white/40">View and manage all books in the system</p>
            </div>
            <a href="/Books/AddBook" class="flex items-center gap-2 rounded-xl bg-primary px-6 py-3 font-black text-background-dark transition-all hover:shadow-xl hover:shadow-primary/30">
                <span class="material-symbols-outlined">add_box</span>
                Add New Book
            </a>
        </div>

        <div class="mb-8 rounded-2xl border border-white/10 bg-black/20 p-6 backdrop-blur-md">
            <form method="get" action="/Books/AllBooks" class="flex flex-col gap-4 md:flex-row">
                <input type="hidden" name="page" value="@Page" />
                <div class="relative flex-1">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-white/40">search</span>
                    <input type="text" name="keyword" value="@Keyword"
                           oninput="clearTimeout(this.delay); this.delay = setTimeout(() => { this.form.querySelector('input[name=\'page\']').value = 1; this.form.requestSubmit(); }, 500);"
                           placeholder="Search by book title, author, or ISBN..."
                           class="w-full rounded-xl border border-white/10 bg-black/40 py-3 pl-12 pr-4 text-white transition-colors focus:border-primary focus:outline-none" />
                </div>

                <div class="flex flex-wrap gap-4">
                    <select name="category"
                            onchange="this.form.querySelector('input[name=\'page\']').value = 1; this.form.requestSubmit()"
                            class="min-w-[150px] cursor-pointer rounded-xl border border-white/10 bg-black/40 px-4 py-3 text-white transition-colors focus:border-primary focus:outline-none">
                        <option value="">All Categories</option>
                        @foreach (var category in Options.Categories)
                        {
                            <option value="@category.CategoryName" selected="@(Category == category.CategoryName)">@category.CategoryName</option>
                        }
                    </select>

                    <select name="publisherId"
                            onchange="this.form.querySelector('input[name=\'page\']').value = 1; this.form.requestSubmit()"
                            class="min-w-[160px] cursor-pointer rounded-xl border border-white/10 bg-black/40 px-4 py-3 text-white transition-colors focus:border-primary focus:outline-none">
                        <option value="">All Publishers</option>
                        @foreach (var publisher in Options.Publishers)
                        {
                            <option value="@publisher.PublisherId" selected="@(PublisherId == publisher.PublisherId)">@publisher.PublisherName</option>
                        }
                    </select>

                    <select name="publishYear"
                            onchange="this.form.querySelector('input[name=\'page\']').value = 1; this.form.requestSubmit()"
                            class="min-w-[130px] cursor-pointer rounded-xl border border-white/10 bg-black/40 px-4 py-3 text-white transition-colors focus:border-primary focus:outline-none">
                        <option value="">All Years</option>
                        @foreach (var publishYear in ListResult.PublishYears)
                        {
                            <option value="@publishYear" selected="@(PublishYear == publishYear)">@publishYear</option>
                        }
                    </select>

                    <select name="isActive"
                            onchange="this.form.querySelector('input[name=\'page\']').value = 1; this.form.requestSubmit()"
                            class="min-w-[130px] cursor-pointer rounded-xl border border-white/10 bg-black/40 px-4 py-3 text-white transition-colors focus:border-primary focus:outline-none">
                        <option value="">All Status</option>
                        <option value="true" selected="@(IsActive == true)">Active</option>
                        <option value="false" selected="@(IsActive == false)">Inactive</option>
                    </select>

                    <select name="availability"
                            onchange="this.form.querySelector('input[name=\'page\']').value = 1; this.form.requestSubmit()"
                            class="min-w-[150px] cursor-pointer rounded-xl border border-white/10 bg-black/40 px-4 py-3 text-white transition-colors focus:border-primary focus:outline-none">
                        <option value="">Any Availability</option>
                        <option value="available" selected="@(Availability == "available")">Available</option>
                        <option value="unavailable" selected="@(Availability == "unavailable")">Unavailable</option>
                        <option value="borrowed" selected="@(Availability == "borrowed")">Borrowed</option>
                        <option value="reserved" selected="@(Availability == "reserved")">Reserved</option>
                        <option value="lost" selected="@(Availability == "lost")">Lost</option>
                        <option value="damaged" selected="@(Availability == "damaged")">Damaged</option>
                    </select>

                    <select name="minRating"
                            onchange="this.form.querySelector('input[name=\'page\']').value = 1; this.form.requestSubmit()"
                            class="min-w-[130px] cursor-pointer rounded-xl border border-white/10 bg-black/40 px-4 py-3 text-white transition-colors focus:border-primary focus:outline-none">
                        <option value="">Any Rating</option>
                        <option value="5" selected="@(MinRating == 5)">5 stars</option>
                        <option value="4" selected="@(MinRating == 4)">4+ stars</option>
                        <option value="3" selected="@(MinRating == 3)">3+ stars</option>
                    </select>

                    <select name="sort"
                            onchange="this.form.requestSubmit()"
                            class="min-w-[150px] cursor-pointer rounded-xl border border-white/10 bg-black/40 px-4 py-3 text-white transition-colors focus:border-primary focus:outline-none">
                        <option value="">Sort By</option>
                        <option value="newest" selected="@(Sort == "newest")">Newest arrivals</option>
                        <option value="year" selected="@(Sort == "year")">Publish Year</option>
                        <option value="az" selected="@(Sort == "az")">Title: A-Z</option>
                    </select>

                    @if (HasFilters)
                    {
                        <a href="/Books/AllBooks" class="flex items-center rounded-xl bg-white/5 px-4 py-3 text-white/60 transition-colors hover:bg-white/10" title="Clear Filters">
                            <span class="material-symbols-outlined">close</span>
                        </a>
                    }
                </div>
            </form>
        </div>

        <div id="staffContainer" class="mb-12 overflow-hidden rounded-2xl border border-white/10 bg-black/20 shadow-2xl">
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="border-b border-white/5 bg-white/5 text-[10px] font-bold uppercase tracking-widest text-white/40">
                        <tr>
                            <th class="px-6 py-4">Book</th>
                            <th class="px-6 py-4">Category</th>
                            <th class="px-6 py-4">Publisher</th>
                            <th class="px-6 py-4">Year</th>
                            <th class="px-6 py-4">Edition</th>
                            <th class="px-6 py-4">Status</th>
                            <th class="px-6 py-4 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5 text-sm">
                        @foreach (var item in ListResult.Items)
                        {
                            <tr class="group transition-colors hover:bg-white/[0.02]">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-4">
                                        <div class="flex h-14 w-10 flex-shrink-0 items-center justify-center overflow-hidden rounded border border-primary/20 bg-black/40 p-0.5 shadow-lg transition-all group-hover:border-primary/50">
                                            <img alt="@item.Title"
                                                 src="@BookImageHelper.Resolve(item.ImageUrl, item.Title)"
                                                 onerror="this.onerror=null;this.src='/images/book-placeholder.svg';"
                                                 class="h-full w-full rounded-sm object-contain">
                                        </div>
                                        <div>
                                            <p class="font-bold text-white transition-colors group-hover:text-primary">@item.Title</p>
                                            <p class="text-[11px] italic text-white/40">@item.Author?.Name</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-white/60">@item.Category?.CategoryName</td>
                                <td class="px-6 py-4 text-white/60">@item.Publisher?.PublisherName</td>
                                <td class="px-6 py-4 text-white/60">@item.PublishYear</td>
                                <td class="px-6 py-4">
                                    <span class="rounded bg-primary/10 px-2 py-0.5 text-[10px] font-bold text-primary">ED @item.EditionNumber</span>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="rounded border px-2 py-0.5 text-[10px] font-bold @(item.IsActive ? "border-emerald-500/20 bg-emerald-500/10 text-emerald-400" : "border-red-500/20 bg-red-500/10 text-red-500")">
                                        @(item.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex justify-end gap-2">
                                        <a href="/Books/Details/@item.BookId" class="rounded-lg border border-white/10 bg-white/5 p-2 text-white/60 transition-all hover:border-primary/50 hover:text-primary" title="View Details">
                                            <span class="material-symbols-outlined text-sm">visibility</span>
                                        </a>
                                        <a href="/Books/Update/@item.BookId" class="rounded-lg border border-white/10 bg-white/5 p-2 text-white/60 transition-all hover:border-primary/50 hover:text-primary" title="Edit Book">
                                            <span class="material-symbols-outlined text-sm">edit</span>
                                        </a>
                                        <a href="/Inventory/ManageCopies?bookId=@item.BookId" class="rounded-lg border border-white/10 bg-white/5 p-2 text-white/60 transition-all hover:border-yellow-400/50 hover:text-yellow-400" title="Manage Copies">
                                            <span class="material-symbols-outlined text-sm">inventory_2</span>
                                        </a>
                                        <button type="button"
                                                @onclick="() => ToggleStatusAsync.InvokeAsync(item.BookId)"
                                                class="rounded-lg border border-white/10 bg-white/5 p-2 text-white/60 transition-all hover:@(item.IsActive ? "text-red-400 hover:border-red-400/50" : "text-emerald-400 hover:border-emerald-400/50")"
                                                title="@(item.IsActive ? "Deactivate Book" : "Activate Book")">
                                            <span class="material-symbols-outlined text-sm">@(item.IsActive ? "delete" : "restore")</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <PagedFooter CurrentPage="@Page" TotalPages="@ListResult.TotalPages" BuildHref="@GetAllBooksUrl" />
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public BookListApiResult ListResult { get; set; } = new();
    [Parameter, EditorRequired] public BookOptionsApiResult Options { get; set; } = new();
    [Parameter] public string? Keyword { get; set; }
    [Parameter] public string? Category { get; set; }
    [Parameter] public int? PublisherId { get; set; }
    [Parameter] public int? PublishYear { get; set; }
    [Parameter] public bool? IsActive { get; set; }
    [Parameter] public string? Availability { get; set; }
    [Parameter] public int? MinRating { get; set; }
    [Parameter] public string? Sort { get; set; }
    [Parameter] public int Page { get; set; }
    [Parameter] public int? NewBookId { get; set; }
    [Parameter] public bool HasFilters { get; set; }
    [Parameter, EditorRequired] public Func<int, string> GetAllBooksUrl { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback<int> ToggleStatusAsync { get; set; }
}
