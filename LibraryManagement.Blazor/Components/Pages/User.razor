@page "/User/Profile"
@page "/User/AllUsers"
@page "/User/MemberDashboard"
@page "/User/BorrowHistory"
@attribute [Authorize]
@using System.Security.Claims
@using LibraryManagement.Blazor.DTO.User
@using LibraryManagementDAL.DTO.Circulation
@using LibraryManagementDAL.DTO.Pagination
@using LibraryManagementDAL.DTO.User
@using LibraryManagementDAL.Models
@inject UserClientService UserService
@inject NavigationManager Navigation
@inject ToastService Toasts

<PageTitle>@GetPageTitle()</PageTitle>

@if (requiresAdminOrManager && !isAdminOrManager)
{
    <AuthRedirect />
}
else if (requiresMember && !isMember)
{
    <AuthRedirect />
}
else if (isLoading)
{
    <div class="custom-scrollbar flex-1 overflow-y-auto p-8">
        <SurfacePanel ContainerClass="rounded-2xl border border-white/10 bg-black/20 p-10 text-center text-white/60"
                     Title="Loading..."
                     TitleClass="text-base font-medium text-white/60" />
    </div>
}
else if (view == "allusers")
{
    <div class="custom-scrollbar flex-1 min-w-0 overflow-y-auto p-8">
        <div class="mb-8 flex items-center justify-between">
            <div>
                <h1 class="mb-2 font-display text-4xl font-bold text-white">User Management</h1>
                <p class="text-white/60">Manage readers, librarians, managers, and administrators</p>
            </div>
            <div class="flex items-center gap-3">
                <a href="/User/Create" class="flex items-center gap-2 rounded-xl bg-primary px-5 py-2.5 font-bold text-background-dark transition-all hover:shadow-lg hover:shadow-primary/20">
                    <span class="material-symbols-outlined text-xl">person_add</span>
                    Add User
                </a>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="mb-6 rounded-xl border border-red-500/20 bg-red-500/10 px-4 py-3 text-sm font-medium text-red-400">@errorMessage</div>
        }

        <div class="mb-8 rounded-2xl border border-white/10 bg-black/20 p-6 backdrop-blur-md">
            <form method="get" action="/User/AllUsers" class="flex flex-col gap-4 lg:flex-row">
                <div class="relative flex-1">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-white/40">search</span>
                    <input type="text"
                           name="search"
                           value="@Search"
                           oninput="clearTimeout(this.delay); this.delay = setTimeout(() => { this.form.requestSubmit(); }, 500);"
                           placeholder="Search by username or user id..."
                           class="w-full rounded-xl border border-white/10 bg-black/40 py-3 pl-12 pr-4 text-white focus:border-primary focus:outline-none transition-colors" />
                </div>

                <div class="flex gap-4">
                    <select name="roleName"
                            onchange="this.form.requestSubmit()"
                            class="min-w-[180px] cursor-pointer rounded-xl border border-white/10 bg-black/40 px-4 py-3 text-white focus:border-primary focus:outline-none transition-colors">
                        <option value="">All Role</option>
                        @foreach (var role in roles)
                        {
                            <option value="@role" selected="@(RoleName == role)">@role</option>
                        }
                    </select>

                    @if (!string.IsNullOrWhiteSpace(Search) || !string.IsNullOrWhiteSpace(RoleName))
                    {
                        <a href="/User/AllUsers" class="flex items-center rounded-xl bg-white/5 px-4 py-3 font-medium text-white/60 transition-colors hover:bg-white/10">
                            <span class="material-symbols-outlined">close</span>
                        </a>
                    }
                </div>
            </form>
        </div>

        <div class="overflow-hidden rounded-2xl border border-white/10 bg-white/5 shadow-2xl">
            <div class="flex items-center justify-between border-b border-white/5 bg-black/20 p-6 text-white">
                <h3 class="flex items-center gap-2 text-lg font-bold">
                    <span class="material-symbols-outlined text-primary">group</span>
                    All Users
                </h3>
                <div class="text-xs text-white/40">
                    Page @users.CurrentPage / @users.TotalPages
                </div>
            </div>

            <div class="custom-scrollbar overflow-x-auto">
                <table class="w-full border-collapse text-left">
                    <thead>
                        <tr class="bg-black/20 text-[11px] font-bold uppercase tracking-wider text-white/40">
                            <th class="border-b border-white/5 p-4">User ID</th>
                            <th class="border-b border-white/5 p-4">Full Name</th>
                            <th class="border-b border-white/5 p-4">Email</th>
                            <th class="border-b border-white/5 p-4">Phone</th>
                            <th class="border-b border-white/5 p-4">Roles</th>
                            <th class="border-b border-white/5 p-4">Status</th>
                            <th class="border-b border-white/5 p-4">Created At</th>
                            <th class="border-b border-white/5 p-4 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm">
                        @if (users.Items.Any())
                        {
                            @foreach (var user in users.Items)
                            {
                                <tr class="group border-b border-white/5 text-white/80 transition-colors hover:bg-white/5">
                                    <td class="p-4 font-medium text-white">#@user.UserId</td>
                                    <td class="p-4">
                                        <div class="font-semibold text-white transition-colors group-hover:text-primary">
                                            @(string.IsNullOrWhiteSpace(user.FullName) ? "N/A" : user.FullName)
                                        </div>
                                        <div class="text-[11px] text-white/40">User account</div>
                                    </td>
                                    <td class="p-4 text-white/60">@(string.IsNullOrWhiteSpace(user.Email) ? "N/A" : user.Email)</td>
                                    <td class="p-4 text-white/60">@(string.IsNullOrWhiteSpace(user.Phone) ? "N/A" : user.Phone)</td>
                                    <td class="p-4">
                                        <span class="inline-flex items-center gap-1.5 rounded-full border px-2.5 py-1 text-[11px] font-bold uppercase tracking-wider @GetRoleClass(user)">
                                            <span class="h-1.5 w-1.5 rounded-full bg-current"></span>
                                            @GetRoleName(user)
                                        </span>
                                    </td>
                                    <td class="p-4">
                                        <span class="inline-flex items-center gap-1.5 rounded-full border px-2.5 py-1 text-[11px] font-bold uppercase tracking-wider @(user.IsActive ? "border-emerald-500/20 bg-emerald-500/10 text-emerald-400" : "border-red-500/20 bg-red-500/10 text-red-400")">
                                            <span class="h-1.5 w-1.5 rounded-full bg-current"></span>
                                            @(user.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td class="p-4 text-white/60">@user.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="p-4">
                                        <div class="flex items-center justify-end gap-2">
                                            <a href="/User/Profile?id=@user.UserId" class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-white/10 bg-white/5 text-primary transition-all hover:border-primary hover:bg-primary hover:text-background-dark" title="View Details">
                                                <span class="material-symbols-outlined text-lg">visibility</span>
                                            </a>
                                            <button type="button" @onclick="() => ToggleStatusAsync(user.UserId)" disabled="@isBusy" class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-white/10 bg-white/5 transition-all disabled:cursor-not-allowed disabled:opacity-60 @(user.IsActive ? "text-red-400 hover:border-red-500 hover:bg-red-500 hover:text-white" : "text-emerald-400 hover:border-emerald-500 hover:bg-emerald-500 hover:text-white")" title="@(user.IsActive ? "Deactivate User" : "Activate User")">
                                                <span class="material-symbols-outlined text-lg">@(user.IsActive ? "person_off" : "check_circle")</span>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="p-12 text-center text-white/40">
                                    <span class="material-symbols-outlined mb-4 block text-6xl text-white/10">group_off</span>
                                    <p class="text-sm">No users found.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <PagedFooter CurrentPage="@users.CurrentPage" TotalPages="@users.TotalPages" BuildHref="@BuildAllUsersHref" />
        </div>
    </div>
}
else if (view == "profile")
{
    <div class="mx-auto max-w-5xl p-6 lg:p-10">
        <div class="mb-10 flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
            <div>
                <h1 class="mb-2 tracking-tight text-4xl font-black text-white">Account Settings</h1>
                <p class="font-medium text-white/50">
                    Manage your profile information and account security.
                </p>
            </div>

            <div class="flex gap-3">
                <a href="/User/ChangePassword" class="flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-5 py-2.5 font-bold text-white/80 shadow-sm transition hover:border-white/20 hover:bg-white/10 hover:text-white">
                    <span class="material-symbols-outlined text-lg">lock</span>
                    Change Password
                </a>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="mb-8 flex items-center gap-3 rounded-2xl border border-rose-500/20 bg-rose-500/10 p-4 text-rose-400">
                <span class="material-symbols-outlined">error</span>
                <span class="font-bold">@errorMessage</span>
            </div>
        }

        @if (profile is not null)
        {
            <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
                <div class="lg:col-span-1">
                    <div class="sticky top-10 rounded-3xl border border-white/10 bg-white/5 p-8 shadow-xl shadow-black/20 backdrop-blur-md">
                        <div class="flex flex-col items-center">
                            <div class="h-32 w-32 rounded-full bg-gradient-to-br from-primary to-yellow-400 p-1 shadow-2xl shadow-primary/20">
                                <div class="flex h-full w-full items-center justify-center overflow-hidden rounded-full bg-background-dark/80">
                                    <span class="material-symbols-outlined text-6xl text-white/30">person</span>
                                </div>
                            </div>

                            <h2 class="mt-6 text-2xl font-black text-white">@profile.FullName</h2>
                            <p class="font-bold text-primary">@(isAdmin ? "Administrator" : "Member")</p>

                            <div class="mt-8 w-full space-y-4 border-t border-white/10 pt-8">
                                <div class="flex items-center gap-3 text-white/50">
                                    <span class="material-symbols-outlined text-lg">mail</span>
                                    <span class="text-sm font-medium">@profile.Email</span>
                                </div>
                                <div class="flex items-center gap-3 text-white/50">
                                    <span class="material-symbols-outlined text-lg">phone</span>
                                    <span class="text-sm font-medium">@(string.IsNullOrWhiteSpace(profile.Phone) ? "Not updated" : profile.Phone)</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="lg:col-span-2">
                    <div class="rounded-3xl border border-white/10 bg-white/5 p-8 shadow-xl shadow-black/20 backdrop-blur-md lg:p-10">
                        @if (isAdmin)
                        {
                            <h3 class="mb-8 flex items-center gap-2 text-xl font-black text-white">
                                <span class="material-symbols-outlined text-primary">visibility</span>
                                Profile Information
                            </h3>

                            <div class="mb-6 flex items-center gap-3 rounded-2xl border border-primary/20 bg-primary/10 p-4 text-primary/80">
                                <span class="material-symbols-outlined">info</span>
                                <span class="font-semibold">Administrators can only view profile information.</span>
                            </div>

                            <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                                @FieldDisplay("Full Name", profile.FullName)
                                @FieldDisplay("Phone Number", string.IsNullOrWhiteSpace(profile.Phone) ? "Not updated" : profile.Phone)
                                @FieldDisplay("Address", string.IsNullOrWhiteSpace(profile.Address) ? "Not updated" : profile.Address)
                                @FieldDisplay("Date of Birth", profile.DateOfBirth?.ToString("dd/MM/yyyy") ?? "Not updated")
                            </div>
                        }
                        else
                        {
                            <h3 class="mb-8 flex items-center gap-2 text-xl font-black text-white">
                                <span class="material-symbols-outlined text-primary">edit_note</span>
                                Personal Information
                            </h3>

                            <EditForm Model="@profile" OnValidSubmit="UpdateProfileAsync" class="space-y-6">
                                <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                                    <div class="space-y-2">
                                        <label class="ml-1 block text-sm font-bold text-white/70">Full Name</label>
                                        <input @bind="profile.FullName" type="text" class="w-full rounded-2xl border border-white/10 bg-black/20 px-5 py-4 font-medium text-white transition-all focus:border-primary focus:ring-2 focus:ring-primary/20" required />
                                    </div>
                                    <div class="space-y-2">
                                        <label class="ml-1 block text-sm font-bold text-white/70">Phone Number</label>
                                        <input @bind="profile.Phone" type="tel" class="w-full rounded-2xl border border-white/10 bg-black/20 px-5 py-4 font-medium text-white transition-all focus:border-primary focus:ring-2 focus:ring-primary/20" />
                                    </div>
                                    <div class="space-y-2">
                                        <label class="ml-1 block text-sm font-bold text-white/70">Address</label>
                                        <input @bind="profile.Address" type="text" class="w-full rounded-2xl border border-white/10 bg-black/20 px-5 py-4 font-medium text-white transition-all focus:border-primary focus:ring-2 focus:ring-primary/20" />
                                    </div>
                                    <div class="space-y-2">
                                        <label class="ml-1 block text-sm font-bold text-white/70">Date of Birth</label>
                                        <input @bind="profile.DateOfBirth" type="date" class="w-full rounded-2xl border border-white/10 bg-black/20 px-5 py-4 font-medium text-white transition-all focus:border-primary focus:ring-2 focus:ring-primary/20" />
                                    </div>
                                </div>

                                <div class="pt-6">
                                    <button disabled="@isBusy" class="flex w-full items-center justify-center gap-2 rounded-2xl bg-primary px-10 py-4 font-black text-background-dark transition-all active:scale-[0.98] hover:bg-primary-hover md:w-auto disabled:cursor-not-allowed disabled:opacity-60">
                                        <span class="material-symbols-outlined">save</span>
                                        Save Changes
                                    </button>
                                </div>
                            </EditForm>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else if (view == "memberdashboard")
{
    <div class="mx-auto max-w-7xl px-8 py-12">
        <div class="mb-10">
            <h1 class="text-4xl font-black text-white">My Library Dashboard</h1>
            <p class="mt-2 text-white/50">Your current loans, reservations, fines, and latest notifications.</p>
        </div>

        <div class="mb-8 grid grid-cols-1 gap-4 md:grid-cols-4">
            <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-5">
                <p class="text-xs font-black uppercase tracking-widest text-white/40">Borrowed</p>
                <p class="mt-2 text-3xl font-black text-white">@memberDashboard.CurrentlyBorrowedCount</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-5">
                <p class="text-xs font-black uppercase tracking-widest text-white/40">Overdue</p>
                <p class="mt-2 text-3xl font-black text-red-300">@memberDashboard.OverdueCount</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-5">
                <p class="text-xs font-black uppercase tracking-widest text-white/40">Fines</p>
                <p class="mt-2 text-3xl font-black text-yellow-300">@memberDashboard.UnpaidFineAmount.ToString("N0")</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-5">
                <p class="text-xs font-black uppercase tracking-widest text-white/40">Reservations</p>
                <p class="mt-2 text-3xl font-black text-primary">@memberDashboard.ActiveReservationCount</p>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-6 xl:grid-cols-3">
            <section class="rounded-2xl border border-white/10 bg-white/[0.04] p-6">
                <div class="mb-4 flex items-center justify-between">
                    <h2 class="text-xl font-black text-white">Recent Borrowing</h2>
                    <a href="/User/BorrowHistory" class="text-sm font-bold text-primary">View all</a>
                </div>
                <div class="space-y-3">
                    @foreach (var transaction in memberDashboard.BorrowTransactions)
                    {
                        <div class="rounded-xl border border-white/10 bg-background-dark/70 p-4">
                            <div class="flex justify-between gap-3">
                                <p class="font-bold text-white">#@transaction.BorrowTransactionId</p>
                                <span class="text-xs font-black text-primary">@transaction.Status</span>
                            </div>
                            <p class="mt-1 text-sm text-white/50">Due @transaction.DueDate.ToString("dd/MM/yyyy")</p>
                            <p class="mt-2 text-sm text-white/60">@transaction.BorrowDetails.Count book(s)</p>
                        </div>
                    }
                    @if (!memberDashboard.BorrowTransactions.Any())
                    {
                        <p class="text-white/50">No borrow history yet.</p>
                    }
                </div>
            </section>

            <section class="rounded-2xl border border-white/10 bg-white/[0.04] p-6">
                <div class="mb-4 flex items-center justify-between">
                    <h2 class="text-xl font-black text-white">Reservations</h2>
                    <a href="/Reservation/MyReservations" class="text-sm font-bold text-primary">View all</a>
                </div>
                <div class="space-y-3">
                    @foreach (var reservation in memberDashboard.Reservations)
                    {
                        <div class="rounded-xl border border-white/10 bg-background-dark/70 p-4">
                            <p class="font-bold text-white">@reservation.BookTitle</p>
                            <div class="mt-2 flex justify-between gap-3">
                                <span class="text-sm text-white/50">@reservation.ReservedAt.ToString("dd/MM/yyyy")</span>
                                <span class="text-xs font-black text-primary">@reservation.Status</span>
                            </div>
                        </div>
                    }
                    @if (!memberDashboard.Reservations.Any())
                    {
                        <p class="text-white/50">No reservations yet.</p>
                    }
                </div>
            </section>

            <section class="rounded-2xl border border-white/10 bg-white/[0.04] p-6">
                <div class="mb-4 flex items-center justify-between">
                    <h2 class="text-xl font-black text-white">Notifications</h2>
                    <a href="/Notification/Index" class="text-sm font-bold text-primary">View all</a>
                </div>
                <div class="space-y-3">
                    @foreach (var notification in memberDashboard.Notifications)
                    {
                        <div class="rounded-xl border border-white/10 bg-background-dark/70 p-4">
                            <p class="font-bold text-white">@notification.Title</p>
                            <p class="mt-1 text-sm text-white/50">@notification.Message</p>
                        </div>
                    }
                    @if (!memberDashboard.Notifications.Any())
                    {
                        <p class="text-white/50">No notifications yet.</p>
                    }
                </div>
            </section>
        </div>
    </div>
}
else if (view == "borrowhistory")
{
    <div class="p-8">
        <div class="mx-auto max-w-6xl">
            <div class="mb-10 flex flex-col justify-between gap-6 md:flex-row md:items-center">
                <div>
                    <h2 class="mb-2 tracking-tight text-4xl font-black text-white">Borrow History</h2>
                    <p class="font-medium text-white/40">Track the books you have borrowed and their return status.</p>
                </div>

                <div class="flex items-center gap-4 rounded-2xl border border-white/10 bg-white/5 p-2 backdrop-blur-md">
                    <div class="flex flex-col border-r border-white/10 px-4">
                        <span class="text-[10px] font-black uppercase tracking-widest text-white/30">Transactions</span>
                        <span class="text-xl font-black text-primary">@borrowHistory.Count</span>
                    </div>
                    <div class="flex flex-col px-4">
                        <span class="text-[10px] font-black uppercase tracking-widest text-white/30">Currently Borrowing</span>
                        <span class="text-xl font-black text-emerald-400">@borrowHistory.Count(t => t.Status == "Borrowing" || t.Status == "Overdue")</span>
                    </div>
                </div>
            </div>

            <div class="space-y-6">
                @if (!borrowHistory.Any())
                {
                    <div class="rounded-3xl border border-white/10 bg-white/5 p-20 text-center">
                        <div class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-white/5">
                            <span class="material-symbols-outlined text-4xl text-white/20">history_edu</span>
                        </div>
                        <h3 class="mb-2 text-xl font-bold text-white">No Borrow History</h3>
                        <p class="mx-auto mb-8 max-w-sm text-white/40">You have not made any borrowing transactions in our system.</p>
                        <a href="/Books/ViewBooks" class="inline-flex items-center gap-2 rounded-xl bg-primary px-8 py-3 font-black text-background-dark transition-all hover:bg-primary-hover">
                            <span class="material-symbols-outlined">explore</span>
                            Explore Library
                        </a>
                    </div>
                }
                else
                {
                    @foreach (var transaction in borrowHistory)
                    {
                        <div class="group overflow-hidden rounded-3xl border border-white/10 bg-white/5 transition-all hover:border-white/20">
                            <div class="flex flex-wrap items-center justify-between gap-4 border-b border-white/5 bg-gradient-to-r from-white/5 to-transparent p-6">
                                <div class="flex items-center gap-4">
                                    <div class="flex h-12 w-12 items-center justify-center rounded-2xl border border-primary/20 bg-primary/10 text-primary">
                                        <span class="material-symbols-outlined">receipt_long</span>
                                    </div>
                                    <div>
                                        <div class="mb-0.5 text-[10px] font-black uppercase tracking-widest text-white/30">Transaction ID</div>
                                        <div class="font-bold text-white">#@transaction.BorrowTransactionId.ToString().PadLeft(5, '0')</div>
                                    </div>
                                </div>

                                <div class="flex items-center gap-8">
                                    <div>
                                        <div class="mb-0.5 text-right text-[10px] font-black uppercase tracking-widest text-white/30">Borrow Date</div>
                                        <div class="font-bold text-white/80">@transaction.BorrowDate.ToString("dd/MM/yyyy")</div>
                                    </div>
                                    <div>
                                        <div class="mb-0.5 text-right text-[10px] font-black uppercase tracking-widest text-white/30">Due Date</div>
                                        <div class="font-bold @(transaction.Status == "Overdue" ? "text-rose-400" : "text-white/80")">@transaction.DueDate.ToString("dd/MM/yyyy")</div>
                                    </div>
                                    <div>
                                        <span class="rounded-lg border px-3 py-1.5 text-[10px] font-black uppercase tracking-wider @GetBorrowStatusClass(transaction.Status)">
                                            @transaction.Status
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <div class="p-6">
                                <div class="space-y-4">
                                    @foreach (var detail in transaction.BorrowDetails)
                                    {
                                        <div class="group/book flex items-center gap-4 rounded-2xl border border-white/5 bg-black/20 p-4">
                                            <div class="h-16 w-12 flex-shrink-0 overflow-hidden rounded-lg border border-white/10 bg-white/5">
                                                <img src="@BookImageHelper.Resolve(detail.ImageUrl, detail.BookTitle)" alt="@detail.BookTitle" onerror="this.onerror=null;this.src='@BookImageHelper.Placeholder';" class="h-full w-full object-cover" />
                                            </div>
                                            <div class="min-w-0 flex-1">
                                                <h4 class="truncate font-bold text-white transition-colors group-hover/book:text-primary">@detail.BookTitle</h4>
                                                <p class="text-xs text-white/40">Book Code: @detail.Barcode</p>
                                            </div>
                                            <div class="text-right">
                                                @if (detail.ActualReturnDate.HasValue)
                                                {
                                                    <div class="mb-0.5 text-[10px] font-black uppercase tracking-widest text-emerald-400/60">Returned At</div>
                                                    <div class="text-sm font-bold text-emerald-400/80">@detail.ActualReturnDate.Value.ToString("dd/MM/yyyy HH:mm")</div>
                                                }
                                                else
                                                {
                                                    <div class="mb-0.5 text-[10px] font-black uppercase tracking-widest text-white/20">Due Date</div>
                                                    <div class="text-sm font-bold @(detail.DueDate.Date < DateTime.UtcNow.Date ? "text-rose-400" : "text-white/50")">@detail.DueDate.ToString("dd/MM/yyyy")</div>
                                                }
                                            </div>
                                            @if (detail.FineAmount.HasValue && detail.FineAmount.Value > 0)
                                            {
                                                <div class="ml-4 border-l border-white/10 pl-4 text-right">
                                                    <div class="mb-0.5 text-[10px] font-black uppercase tracking-widest text-rose-400/60">Fine</div>
                                                    <div class="text-sm font-black text-rose-400">@detail.FineAmount.Value.ToString("N0") VND</div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter]
    public Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    [SupplyParameterFromQuery(Name = "search")]
    public string? Search { get; set; }

    [SupplyParameterFromQuery(Name = "roleName")]
    public string? RoleName { get; set; }

    [SupplyParameterFromQuery(Name = "page")]
    public int Page { get; set; } = 1;

    [SupplyParameterFromQuery(Name = "id")]
    public int? Id { get; set; }

    private string view = "profile";
    private bool isLoading = true;
    private bool isBusy;
    private string? errorMessage;
    private bool isAdmin;
    private bool isAdminOrManager;
    private bool isMember;
    private bool requiresAdminOrManager;
    private bool requiresMember;
    private PaginationResponseModel<Account> users = new();
    private List<string> roles = new();
    private UserProfileDto? profile;
    private MemberDashboardViewModel memberDashboard = new();
    private List<CirculationTransactionItem> borrowHistory = new();

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;
        view = GetView();
        requiresAdminOrManager = view == "allusers";
        requiresMember = view == "memberdashboard";

        var authState = await AuthenticationStateTask;
        var principal = authState.User;
        isAdmin = principal.IsInRole("Admin");
        isAdminOrManager = principal.IsInRole("Admin") || principal.IsInRole("Manager");
        isMember = principal.IsInRole("Member");

        if ((requiresAdminOrManager && !isAdminOrManager) || (requiresMember && !isMember))
        {
            isLoading = false;
            return;
        }

        try
        {
            switch (view)
            {
                case "allusers":
                    users = await UserService.GetUsersAsync(Search, RoleName, Page);
                    roles = await UserService.GetRoleNamesAsync();
                    break;
                case "memberdashboard":
                    if (!UserService.TryGetCurrentUserId(out var memberUserId))
                    {
                        errorMessage = "Please log in to continue.";
                        break;
                    }

                    memberDashboard = await UserService.GetMemberDashboardAsync(memberUserId);
                    break;
                case "borrowhistory":
                    if (!UserService.TryGetCurrentUserId(out var historyUserId))
                    {
                        errorMessage = "Please log in to continue.";
                        break;
                    }

                    borrowHistory = await UserService.GetBorrowHistoryAsync(historyUserId);
                    break;
                default:
                    var targetUserId = Id;
                    var currentUserId = 0;
                    if (!targetUserId.HasValue && !UserService.TryGetCurrentUserId(out currentUserId))
                    {
                        errorMessage = "Please log in to continue.";
                        break;
                    }

                    profile = await UserService.GetProfileAsync(targetUserId ?? currentUserId);
                    if (profile is null)
                    {
                        errorMessage = "Profile not found.";
                    }
                    break;
            }
        }
        catch
        {
            errorMessage = "Could not load this page right now.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetView()
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
        var path = relative.Split('?', '#')[0].Trim('/').ToLowerInvariant();

        return path switch
        {
            "user/allusers" => "allusers",
            "user/memberdashboard" => "memberdashboard",
            "user/borrowhistory" => "borrowhistory",
            _ => "profile"
        };
    }

    private async Task ToggleStatusAsync(int userId)
    {
        isBusy = true;
        try
        {
            var result = await UserService.ToggleStatusAsync(userId);
            if (result.IsSuccess)
            {
                Toasts.Success(result.Message);
                users = await UserService.GetUsersAsync(Search, RoleName, Page);
            }
            else
            {
                Toasts.Error(result.Message);
            }
        }
        catch
        {
            Toasts.Error("Update user status failed.");
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task UpdateProfileAsync()
    {
        if (profile is null || !UserService.TryGetCurrentUserId(out var userId))
        {
            Toasts.Error("Please log in to continue.");
            return;
        }

        isBusy = true;
        try
        {
            var result = await UserService.UpdateProfileAsync(userId, profile);
            if (result.IsSuccess)
            {
                Toasts.Success(result.Message);
            }
            else
            {
                Toasts.Error(result.Message);
            }
        }
        catch
        {
            Toasts.Error("Profile update failed.");
        }
        finally
        {
            isBusy = false;
        }
    }

    private string BuildAllUsersHref(int page)
    {
        var query = new List<string> { $"page={page}" };
        if (!string.IsNullOrWhiteSpace(Search))
        {
            query.Add($"search={Uri.EscapeDataString(Search)}");
        }

        if (!string.IsNullOrWhiteSpace(RoleName))
        {
            query.Add($"roleName={Uri.EscapeDataString(RoleName)}");
        }

        return "/User/AllUsers?" + string.Join("&", query);
    }

    private static string GetRoleName(Account user) => user.Staff?.Role?.RoleName ?? (user.Member != null ? "Member" : "No Role");

    private static string GetRoleClass(Account user) => GetRoleName(user) switch
    {
        "Admin" => "border-red-500/20 bg-red-500/10 text-red-400",
        "Manager" => "border-purple-500/20 bg-purple-500/10 text-purple-400",
        "Librarian" => "border-primary/20 bg-primary/10 text-primary",
        "Member" => "border-emerald-500/20 bg-emerald-500/10 text-emerald-400",
        _ => "border-white/10 bg-white/10 text-white/60"
    };

    private static string GetBorrowStatusClass(string status) => status switch
    {
        "Borrowing" => "border-emerald-500/20 bg-emerald-500/10 text-emerald-400",
        "Returned" => "border-primary/20 bg-primary/10 text-primary",
        "Overdue" => "border-rose-500/20 bg-rose-500/10 text-rose-400",
        _ => "border-white/10 bg-white/10 text-white/40"
    };

    private RenderFragment FieldDisplay(string label, string value) => builder =>
    {
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "space-y-2");
        builder.OpenElement(2, "label");
        builder.AddAttribute(3, "class", "ml-1 block text-sm font-bold text-white/70");
        builder.AddContent(4, label);
        builder.CloseElement();
        builder.OpenElement(5, "div");
        builder.AddAttribute(6, "class", "w-full rounded-2xl border border-white/10 bg-black/20 px-5 py-4 font-medium text-white");
        builder.AddContent(7, value);
        builder.CloseElement();
        builder.CloseElement();
    };

    private string GetPageTitle() => GetView() switch
    {
        "allusers" => "User Management - Standard Library",
        "memberdashboard" => "My Library Dashboard - Standard Library",
        "borrowhistory" => "Borrow History - Standard Library",
        _ => "Profile - Standard Library"
    };
}
