@namespace LibraryManagement.Blazor.Components.Pages
<div class="custom-scrollbar flex-1 min-w-0 overflow-y-auto p-8">
    <div class="group mb-8 flex w-fit cursor-pointer items-center gap-3">
        <a href="/Payment/Index" class="flex items-center gap-3">
            <span class="material-symbols-outlined text-white/40 transition-colors group-hover:text-primary">arrow_back</span>
            <span class="text-sm font-medium tracking-wide text-white/40 transition-colors group-hover:text-primary">Back</span>
        </a>
    </div>

    <div class="mx-auto max-w-2xl">
        <div class="relative overflow-hidden rounded-2xl border border-white/5 bg-white/5 shadow-2xl">
            <div class="pointer-events-none absolute -right-20 -top-20 h-64 w-64 rounded-full bg-primary/10 blur-3xl"></div>

            <div class="relative z-10 border-b border-white/5 p-8">
                <h2 class="mb-2 flex items-center gap-3 text-2xl font-bold tracking-tight text-white">
                    <span class="material-symbols-outlined text-3xl text-primary">add_card</span>
                    Create Manual Fine
                </h2>
                <p class="text-sm text-white/40">Applies to cases such as lost card, damaged property, or other compensations.</p>
            </div>

            <div class="relative z-10 bg-black/10 p-8">
                @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                {
                    <div class="mb-6 rounded-xl border border-red-500/20 bg-red-500/10 p-4 text-sm font-medium text-red-400">@ErrorMessage</div>
                }

                <div class="flex flex-col gap-6">
                    <div class="relative flex flex-col gap-2">
                        <label class="flex items-center gap-2 text-sm font-semibold text-white/80">
                            <span class="material-symbols-outlined text-[18px] text-white/40">person_search</span>
                            Select Member (ID or Name)
                        </label>

                        <div class="group relative">
                            <input value="@UserSearchQuery"
                                   @oninput="HandleUserSearchInput"
                                   class="w-full rounded-xl border border-white/10 bg-white/5 py-3.5 pl-4 pr-10 text-sm text-white placeholder:text-white/20 shadow-inner shadow-black/20 transition-all focus:border-primary/40 focus:outline-none focus:ring-2 focus:ring-primary/40"
                                   placeholder="Type ID, name or email to search..."
                                   autocomplete="off" />
                            <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-2xl text-white/20 transition-colors group-focus-within:text-primary">person_search</span>
                        </div>

                        @if (UserSearchResultsVisible)
                        {
                            <div class="absolute left-0 right-0 top-full z-[100] mt-2 overflow-hidden rounded-xl border border-white/5 bg-background-dark shadow-2xl backdrop-blur-xl">
                                <div class="custom-scrollbar max-h-[300px] overflow-y-auto">
                                    @if (SearchingUsers)
                                    {
                                        <div class="p-4 text-center text-sm text-white/40">Searching...</div>
                                    }
                                    else if (UserSearchResults.Any())
                                    {
                                        @foreach (var userResult in UserSearchResults)
                                        {
                                            <button type="button"
                                                    @onclick="async () => await SelectUser.InvokeAsync(userResult)"
                                                    class="group flex w-full cursor-pointer items-center justify-between gap-3 border-b border-white/5 px-4 py-3 text-left transition-colors hover:bg-white/[0.03] last:border-0">
                                                <div class="min-w-0">
                                                    <div class="truncate text-sm font-bold text-white transition-colors group-hover:text-primary">@userResult.FullName</div>
                                                    <div class="truncate font-mono text-[10px] text-white/40">@userResult.Email</div>
                                                </div>
                                                <div class="rounded bg-white/5 px-2 py-0.5 text-[10px] font-bold text-primary">ID: @userResult.UserId</div>
                                            </button>
                                        }
                                    }
                                    else
                                    {
                                        <div class="p-4 text-center text-sm text-white/40">No matching users found.</div>
                                    }
                                </div>
                            </div>
                        }

                        @if (SelectedUserId > 0)
                        {
                            <div class="mt-2 flex items-center justify-between rounded-xl border border-primary/30 bg-primary/10 p-3">
                                <div class="flex items-center gap-3">
                                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary/20 text-primary">
                                        <span class="material-symbols-outlined">person</span>
                                    </div>
                                    <div>
                                        <h4 class="text-sm font-bold text-white">@SelectedUserName</h4>
                                        <p class="font-mono text-[11px] text-primary/70">ID: @SelectedUserId | @SelectedUserEmail</p>
                                    </div>
                                </div>
                                <button type="button"
                                        @onclick="async () => await ClearSelectedUser.InvokeAsync()"
                                        class="rounded-lg p-1.5 text-white/40 transition-colors hover:bg-white/5 hover:text-red-400">
                                    <span class="material-symbols-outlined text-sm">close</span>
                                </button>
                            </div>
                        }
                    </div>

                    <div class="flex flex-col gap-2">
                        <label class="flex items-center gap-2 text-sm font-semibold text-white/80">
                            <span class="material-symbols-outlined text-[18px] text-white/40">payments</span>
                            Fine Amount (VND)
                        </label>
                        <input type="number"
                               min="1000"
                               step="1000"
                               value="@ManualFineAmount"
                               @oninput="HandleAmountInput"
                               class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder:text-white/20 shadow-inner shadow-black/20 transition-all focus:border-primary/40 focus:outline-none focus:ring-2 focus:ring-primary/40"
                               placeholder="Example: 50000" />
                    </div>

                    <div class="flex flex-col gap-2">
                        <label class="flex items-center gap-2 text-sm font-semibold text-white/80">
                            <span class="material-symbols-outlined text-[18px] text-white/40">description</span>
                            Reason for Fine
                        </label>
                        <textarea value="@ManualFineReason"
                                  @oninput="HandleReasonInput"
                                  rows="3"
                                  class="custom-scrollbar w-full rounded-xl border border-white/10 bg-white/5 p-4 text-sm text-white placeholder:text-white/20 shadow-inner shadow-black/20 transition-all focus:border-primary/40 focus:outline-none focus:ring-2 focus:ring-primary/40"
                                  placeholder="Clearly state the reason for the charge."></textarea>
                    </div>

                    <div class="flex items-center gap-4 border-t border-white/5 pt-6">
                        <a href="/Payment/Index" class="flex-1 rounded-xl border border-white/5 bg-white/5 py-3 text-center font-bold text-white/80 transition-all hover:border-primary/30 hover:bg-white/10">
                            Cancel
                        </a>
                        <button type="button"
                                @onclick="SubmitCreateFine"
                                disabled="@IsBusy"
                                class="flex flex-1 items-center justify-center gap-2 rounded-xl border border-primary bg-primary py-3 font-black text-background-dark transition-all hover:shadow-xl hover:shadow-primary/30 disabled:cursor-not-allowed disabled:opacity-40">
                            <span class="material-symbols-outlined">check_circle</span>
                            Create Fine
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public string? UserSearchQuery { get; set; }
    [Parameter] public bool UserSearchResultsVisible { get; set; }
    [Parameter] public bool SearchingUsers { get; set; }
    [Parameter] public IReadOnlyList<LibraryManagementDAL.DTO.Circulation.UserSearchResult> UserSearchResults { get; set; } = Array.Empty<LibraryManagementDAL.DTO.Circulation.UserSearchResult>();
    [Parameter] public int SelectedUserId { get; set; }
    [Parameter] public string SelectedUserName { get; set; } = "---";
    [Parameter] public string SelectedUserEmail { get; set; } = string.Empty;
    [Parameter] public decimal? ManualFineAmount { get; set; }
    [Parameter] public string ManualFineReason { get; set; } = string.Empty;
    [Parameter] public bool IsBusy { get; set; }
    [Parameter] public EventCallback<string?> UserSearchQueryChanged { get; set; }
    [Parameter] public EventCallback<LibraryManagementDAL.DTO.Circulation.UserSearchResult> SelectUser { get; set; }
    [Parameter] public EventCallback ClearSelectedUser { get; set; }
    [Parameter] public EventCallback<string> ManualFineAmountChanged { get; set; }
    [Parameter] public EventCallback<string> ManualFineReasonChanged { get; set; }
    [Parameter] public EventCallback SubmitCreateFine { get; set; }

    private async Task HandleUserSearchInput(ChangeEventArgs e)
    {
        await UserSearchQueryChanged.InvokeAsync(e.Value?.ToString());
    }

    private async Task HandleAmountInput(ChangeEventArgs e)
    {
        await ManualFineAmountChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty);
    }

    private async Task HandleReasonInput(ChangeEventArgs e)
    {
        await ManualFineReasonChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty);
    }
}
