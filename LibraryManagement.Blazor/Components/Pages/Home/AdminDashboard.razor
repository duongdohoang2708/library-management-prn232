@page "/Home/AdminDashboard"
@namespace LibraryManagement.Blazor.Components.Pages
@attribute [Authorize(Roles = "Admin,Manager")]
@inject HomeClientService HomeService
@inject IJSRuntime JS

<PageTitle>AdminDashboard</PageTitle>

<div class="custom-scrollbar flex-1 overflow-y-auto p-8 min-w-0">
    @if (!string.IsNullOrWhiteSpace(model.ErrorMessage))
    {
        <div class="mb-6 rounded-2xl border border-red-500/20 bg-red-500/10 px-5 py-4 text-sm font-bold text-red-300">
            @model.ErrorMessage
        </div>
    }

    <div class="mb-10 flex items-end justify-between">
        <div>
            <h1 class="mb-2 text-4xl font-extrabold tracking-tight text-white">
                Good afternoon, <span class="text-primary">@userName</span> 📑
            </h1>
            <p class="text-lg text-white/50">Here is your high-level system overview.</p>
        </div>
        <div class="text-right">
            <p class="mb-1 text-[10px] font-bold uppercase tracking-widest text-white/40">System Status</p>
            <div class="inline-flex items-center gap-2 rounded-full border border-emerald-500/20 bg-emerald-500/10 px-3 py-1 text-xs font-bold text-emerald-400">
                <span class="h-2 w-2 animate-pulse rounded-full bg-emerald-500"></span>
                All Systems Operational
            </div>
        </div>
    </div>

    <div class="mb-12 grid grid-cols-1 gap-8">
        <div class="group relative flex flex-col overflow-hidden rounded-[2rem] border border-white/10 bg-black/20 p-8 shadow-2xl">
            <div class="pointer-events-none absolute -right-20 -top-20 h-80 w-80 rounded-full bg-primary/5 blur-[100px]"></div>

            <div class="relative z-10 mb-8 flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
                <div>
                    <h3 class="flex items-center gap-3 text-2xl font-black text-white">
                        <span class="material-symbols-outlined rounded-xl bg-primary/10 p-2 text-primary">auto_graph</span>
                        Library Growth & Activity
                    </h3>
                    <p class="mt-1 text-sm text-white/40">
                        Monthly comparison of new member registrations and borrowing transactions.
                    </p>
                </div>
                <div class="flex items-center gap-6">
                    <div class="flex flex-col items-end">
                        <p class="text-[10px] font-bold uppercase tracking-widest text-white/30">Active Transactions</p>
                        <p class="text-xl font-black text-white">@stats.TotalTransactions.ToString("N0")</p>
                    </div>
                    <div class="h-10 w-px bg-white/10"></div>
                    <div class="flex flex-col items-end">
                        <p class="text-[10px] font-bold uppercase tracking-widest text-white/30">Global Users</p>
                        <p class="text-xl font-black text-white">@stats.TotalUsers.ToString("N0")</p>
                    </div>
                </div>
            </div>

            <div class="relative h-[350px] w-full flex-1">
                <canvas id="performanceChart"></canvas>
            </div>
        </div>
    </div>

    <div class="mb-12 grid grid-cols-1 gap-8 lg:grid-cols-2">
        <div class="relative flex flex-col rounded-3xl border border-white/10 bg-black/20 p-6 shadow-2xl lg:col-span-2">
            <h3 class="mb-6 flex items-center gap-2 text-lg font-bold text-white">
                <span class="material-symbols-outlined text-primary">published_with_changes</span>
                Circulation: Borrows vs Returns
            </h3>
            <div class="relative h-[300px] w-full flex-1">
                <canvas id="borrowChart"></canvas>
            </div>
        </div>

        <div class="relative flex flex-col rounded-3xl border border-white/10 bg-black/20 p-6 shadow-2xl">
            <h3 class="mb-6 flex items-center gap-2 text-lg font-bold text-white">
                <span class="material-symbols-outlined text-primary">donut_large</span>
                Books by Category
            </h3>
            <div class="relative flex h-[300px] w-full flex-1 items-center justify-center">
                <canvas id="categoryChart"></canvas>
            </div>
        </div>

        <div class="relative flex flex-col rounded-3xl border border-white/10 bg-black/20 p-6 shadow-2xl">
            <h3 class="mb-6 flex items-center gap-2 text-lg font-bold text-white">
                <span class="material-symbols-outlined text-primary">analytics</span>
                Book Status Distribution
            </h3>
            <div class="relative flex h-[300px] w-full flex-1 items-center justify-center">
                <canvas id="statusChart"></canvas>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
        <div class="flex flex-col overflow-hidden rounded-3xl border border-white/10 bg-white/5 shadow-2xl">
            <div class="flex items-center justify-between border-b border-white/5 p-6">
                <h3 class="flex items-center gap-2 text-lg font-bold text-white">
                    <span class="material-symbols-outlined text-primary">person_add</span>
                    Newest Registrations
                </h3>
            </div>
            <div class="flex-1 p-6">
                <div class="flex flex-col gap-4">
                    @if (stats.RecentUsers.Any())
                    {
                        @foreach (var item in stats.RecentUsers)
                        {
                            <div class="group flex items-center gap-4">
                                <div class="flex h-10 w-10 items-center justify-center rounded-full border border-white/20 bg-white/10 text-sm font-bold text-white shadow-inner transition-all group-hover:bg-primary/20 group-hover:text-primary">
                                    @(item.FullName?.FirstOrDefault() ?? '?')
                                </div>
                                <div>
                                    <h4 class="text-sm font-bold text-white transition-colors group-hover:text-primary">@item.FullName</h4>
                                    <p class="font-mono text-[10px] text-white/40">@item.Email</p>
                                </div>
                                <div class="ml-auto text-right">
                                    <p class="text-[10px] font-bold text-white/60">@item.CreatedAt.ToString("MMM dd")</p>
                                    <p class="text-[9px] uppercase text-white/30">Joined</p>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="py-4 text-center text-sm italic text-white/30">No users found.</p>
                    }
                </div>
            </div>
        </div>

        <div class="flex flex-col overflow-hidden rounded-3xl border border-white/10 bg-white/5 shadow-2xl">
            <div class="flex items-center justify-between border-b border-white/5 p-6">
                <h3 class="flex items-center gap-2 text-lg font-bold text-white">
                    <span class="material-symbols-outlined text-primary">receipt_long</span>
                    Recent Fine Settlements
                </h3>
            </div>
            <div class="flex-1 p-6">
                <div class="flex flex-col gap-4">
                    @if (stats.RecentPayments.Any())
                    {
                        @foreach (var payment in stats.RecentPayments)
                        {
                            <div class="group flex items-center gap-4">
                                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-emerald-500/20 bg-emerald-500/10 text-emerald-400 shadow-inner transition-all group-hover:bg-emerald-500 group-hover:text-background-dark">
                                    <span class="material-symbols-outlined text-[18px]">payments</span>
                                </div>
                                <div>
                                    <h4 class="text-sm font-bold text-white transition-colors group-hover:text-emerald-400">@payment.Amount.ToString("N0") ₫</h4>
                                    <p class="font-mono text-[10px] text-white/40">@payment.UserFullName</p>
                                </div>
                                <div class="ml-auto text-right">
                                    <p class="text-[10px] font-bold text-white/60">@((payment.PaidAt ?? payment.CreatedAt).ToString("MMM dd"))</p>
                                    <span class="rounded border border-emerald-500/20 bg-emerald-500/10 px-1.5 py-0.5 text-[9px] font-black uppercase text-emerald-400">
                                        Paid
                                    </span>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="py-4 text-center text-sm italic text-white/30">No recent payments.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    public Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private AdminDashboardViewModel model = new();
    private LibraryManagementDAL.DTO.Dashboard.DashboardStatsResult stats = new();
    private string userName = "Admin";
    private bool pendingChartRender;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateTask;
        userName = authState.User.FindFirst("FullName")?.Value
            ?? authState.User.Identity?.Name
            ?? "Admin";

        model = await HomeService.GetAdminDashboardAsync();
        stats = model.Stats;
        pendingChartRender = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!pendingChartRender)
        {
            return;
        }

        pendingChartRender = false;
        await JS.InvokeVoidAsync("libraryManagement.dashboard.render", new
        {
            monthlyLabels = stats.MonthlyLabels,
            monthlyBorrows = stats.MonthlyBorrows,
            monthlyReturns = stats.MonthlyReturns,
            monthlyRegistrations = stats.MonthlyRegistrations,
            categoryLabels = stats.CategoryStats.Select(item => item.Label).ToList(),
            categoryCounts = stats.CategoryStats.Select(item => item.Count).ToList(),
            bookStatusLabels = stats.BookStatusStats.Select(item => item.Label).ToList(),
            bookStatusCounts = stats.BookStatusStats.Select(item => item.Count).ToList()
        });
    }
}
