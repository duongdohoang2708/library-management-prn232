@page "/Auth/AccessDenied"
@layout AuthLayout

<PageTitle>Access Denied - Standard Library</PageTitle>

<div class="flex-1 flex items-center justify-center p-8">
    <div class="text-center max-w-md w-full">
        <div class="relative inline-block mb-8">
            <div class="w-28 h-28 rounded-3xl bg-red-500/10 border border-red-500/20 flex items-center justify-center mx-auto shadow-2xl shadow-red-500/10">
                <span class="material-symbols-outlined text-6xl text-red-400">gpp_bad</span>
            </div>
            <div class="absolute -top-2 -right-2 w-8 h-8 bg-red-500 rounded-full flex items-center justify-center shadow-lg shadow-red-500/40">
                <span class="material-symbols-outlined text-white text-sm">close</span>
            </div>
        </div>

        <div class="text-white/10 text-8xl font-black mb-2 leading-none select-none">403</div>

        <h1 class="text-2xl font-black text-white mb-3">Access Denied</h1>
        <p class="text-white/50 text-sm leading-relaxed mb-8">
            This page requires permissions that your account does not have.<br />
            If you believe this is a mistake, please contact the administrator.
        </p>

        @if (userState.IsAuthenticated)
        {
            <div class="glass-card rounded-2xl p-4 mb-6 text-left">
                <p class="text-white/30 text-xs font-semibold uppercase tracking-widest mb-3">Current Account Info</p>
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-primary/20 border border-primary/30 flex items-center justify-center flex-shrink-0">
                        <span class="material-symbols-outlined text-primary text-lg">person</span>
                    </div>
                    <div class="min-w-0">
                        <div class="text-white text-sm font-semibold truncate">@userState.Email</div>
                        <div class="flex gap-1.5 mt-1 flex-wrap">
                            @foreach (var role in userState.Roles)
                            {
                                <span class="px-2 py-0.5 bg-primary/10 border border-primary/20 rounded-full text-primary text-[10px] font-bold">
                                    @role
                                </span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/"
               class="flex items-center justify-center gap-2 bg-primary text-background-dark font-bold py-3 px-6 rounded-xl hover:shadow-lg hover:shadow-primary/30 active:scale-[0.98] transition-all text-sm">
                <span class="material-symbols-outlined text-lg">home</span>
                Back to Home
            </a>

            @if (userState.IsAuthenticated)
            {
                <form method="post" action="/auth/logout" style="display:inline">
                    <button type="submit"
                            class="flex items-center justify-center gap-2 w-full border border-white/10 text-white/70 font-semibold py-3 px-6 rounded-xl hover:bg-white/5 hover:text-white hover:border-white/20 active:scale-[0.98] transition-all text-sm">
                        <span class="material-symbols-outlined text-lg">logout</span>
                        Sign out & try another account
                    </button>
                </form>
            }
            else
            {
                <a href="/Auth/Login"
                   class="flex items-center justify-center gap-2 border border-white/10 text-white/70 font-semibold py-3 px-6 rounded-xl hover:bg-white/5 hover:text-white hover:border-white/20 active:scale-[0.98] transition-all text-sm">
                    <span class="material-symbols-outlined text-lg">login</span>
                    Login
                </a>
            }
        </div>

        <p class="text-white/30 text-xs mt-8">
            Need help?
            <a href="mailto:admin@lms.com" class="text-primary/60 hover:text-primary transition-colors">
                Contact Admin
            </a>
        </p>
    </div>
</div>

@code {
    [CascadingParameter]
    public Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private ShellUserState userState = ShellUserState.Empty;

    protected override async Task OnParametersSetAsync()
    {
        var state = await AuthenticationStateTask;
        userState = ShellUserState.From(state.User);
    }
}
