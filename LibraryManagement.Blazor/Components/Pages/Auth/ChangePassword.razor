@page "/Auth/ChangePassword"
@page "/User/ChangePassword"
@layout AuthLayout
@attribute [Authorize]

<PageTitle>Change Password - LMS Library</PageTitle>

<AuthSplitShell LeftClass="hidden lg:flex flex-col justify-between w-[45%] p-12 relative overflow-hidden border-r border-white/5"
                RightClass="flex-1 flex flex-col justify-center items-center p-8 lg:p-16">
    <LeftContent>
        <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary shadow-lg shadow-primary/30">
                <span class="material-symbols-outlined text-xl font-bold text-background-dark">shield</span>
            </div>
            <span class="text-lg font-bold tracking-tight text-white">Standard Library</span>
        </div>

        <div class="flex flex-col items-center text-center">
            <div class="relative mb-10">
                <div class="flex h-48 w-48 items-center justify-center rounded-3xl border border-white/10 bg-white/5 shadow-2xl shadow-black/50">
                    <span class="material-symbols-outlined text-[96px] text-primary/80">lock_reset</span>
                </div>
                <div class="absolute -right-4 -top-4 flex items-center gap-1.5 rounded-xl bg-primary px-3 py-1.5 text-xs font-black text-background-dark shadow-lg shadow-primary/30">
                    <span class="material-symbols-outlined text-sm">enhanced_encryption</span>
                    Secure
                </div>
            </div>

            <h1 class="mb-4 text-3xl font-black leading-tight text-white">
                Protect your<br />
                <span class="text-primary">Account</span>
            </h1>
            <p class="max-w-xs text-sm leading-relaxed text-white/50">
                We recommend updating your password regularly to ensure the safety of your personal information.
            </p>
        </div>

        <div></div>
    </LeftContent>

    <RightContent>
        <div class="w-full max-w-md">
            <div class="mb-8">
                <h2 class="mb-2 text-3xl font-black text-white">Change Password</h2>
                <p class="text-sm text-white/50">Enter your current password and choose a new one.</p>
            </div>

            @if (!string.IsNullOrWhiteSpace(Success))
            {
                <div class="mb-5 flex items-center gap-3 rounded-xl border border-emerald-500/20 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-400">
                    <span class="material-symbols-outlined text-lg">check_circle</span>
                    @Success
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Error))
            {
                <div class="mb-5 flex items-start gap-3 rounded-xl border border-red-500/20 bg-red-500/10 px-4 py-3 text-sm text-red-400">
                    <span class="material-symbols-outlined mt-0.5 flex-shrink-0 text-lg">error</span>
                    <div>@Error</div>
                </div>
            }

            <form method="post" action="/auth/change-password" id="changePasswordForm" class="space-y-5">
                <div>
                    <label class="mb-2 block text-sm font-semibold text-white/70">Current Password</label>
                    <div class="relative">
                        <span class="material-symbols-outlined pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-lg text-white/30">lock</span>
                        <input name="CurrentPassword" @bind="Model.CurrentPassword" @bind:event="oninput" type="password" class="auth-input !pl-12 !pr-12" placeholder="••••••••" autofocus />
                    </div>
                </div>

                <div>
                    <label class="mb-2 block text-sm font-semibold text-white/70">New Password</label>
                    <div class="relative">
                        <span class="material-symbols-outlined pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-lg text-white/30">lock_open</span>
                        <input name="NewPassword" @bind="Model.NewPassword" @bind:event="oninput" type="password" class="auth-input !pl-12 !pr-12" placeholder="••••••••" />
                    </div>
                </div>

                <div>
                    <label class="mb-2 block text-sm font-semibold text-white/70">Confirm New Password</label>
                    <div class="relative">
                        <span class="material-symbols-outlined pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-lg text-white/30">lock_clock</span>
                        <input name="ConfirmNewPassword" @bind="Model.ConfirmNewPassword" @bind:event="oninput" type="password" class="auth-input !pl-12 !pr-12" placeholder="••••••••" />
                    </div>
                </div>

                <button type="submit" class="btn-primary-auth mt-4 flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-lg">save</span>
                    <span>Save Password</span>
                </button>

                <div class="mt-6 text-center">
                    <a href="/" class="flex items-center justify-center gap-1 text-sm text-white/40 transition-colors hover:text-primary">
                        <span class="material-symbols-outlined text-sm">arrow_back</span>
                        Back to Dashboard
                    </a>
                </div>
            </form>
        </div>
    </RightContent>
</AuthSplitShell>

@code {
    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    [SupplyParameterFromQuery]
    public string? Success { get; set; }

    private ChangePasswordRequestDto Model { get; } = new();
}
