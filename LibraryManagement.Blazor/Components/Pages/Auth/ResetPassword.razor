@page "/Auth/ResetPassword"
@layout AuthLayout

<PageTitle>Reset Password - LMS Library</PageTitle>

<AuthSplitShell LeftClass="hidden lg:flex flex-col justify-between w-[45%] p-12 relative overflow-hidden border-r border-white/5"
                RightClass="flex-1 flex flex-col justify-center items-center p-8 lg:p-16">
    <LeftContent>
        <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary shadow-lg shadow-primary/30">
                <span class="material-symbols-outlined text-xl font-bold text-background-dark">shield</span>
            </div>
            <span class="text-lg font-bold tracking-tight text-white">Standard Library</span>
        </div>

        <div class="flex flex-col items-center text-center">
            <div class="relative mb-10">
                <div class="flex h-48 w-48 items-center justify-center rounded-3xl border border-white/10 bg-white/5 shadow-2xl shadow-black/50">
                    <span class="material-symbols-outlined text-[96px] text-primary/80">key</span>
                </div>
            </div>
            <h1 class="mb-4 text-3xl font-black leading-tight text-white">
                Set your new <br />
                <span class="text-primary">Password</span>
            </h1>
            <p class="max-w-xs text-sm leading-relaxed text-white/50">
                Almost there! Create a strong password to secure your account.
            </p>
        </div>
        <div></div>
    </LeftContent>

    <RightContent>
        <div class="w-full max-w-md">
            <div class="mb-8">
                <h2 class="mb-2 text-3xl font-black text-white">Reset Password</h2>
                <p class="text-sm text-white/50">Please choose a strong, new password.</p>
            </div>

            @if (!string.IsNullOrWhiteSpace(Error))
            {
                <div class="mb-5 flex items-start gap-3 rounded-xl border border-red-500/20 bg-red-500/10 px-4 py-3 text-sm text-red-400">
                    <span class="material-symbols-outlined mt-0.5 flex-shrink-0 text-lg">error</span>
                    <div>@Error</div>
                </div>
            }

            <form method="post" action="/auth/reset-password" id="resetPasswordForm" class="space-y-5">
                <input type="hidden" name="Email" value="@Model.Email" />

                <div>
                    <label class="mb-2 block text-sm font-semibold text-white/70">Verification Code</label>
                    <div class="relative">
                        <span class="material-symbols-outlined pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-lg text-white/30">pin</span>
                        <input name="Token" @bind="Model.Token" @bind:event="oninput" inputmode="numeric" maxlength="6" class="auth-input !pl-12" placeholder="123456" autofocus />
                    </div>
                </div>

                <div>
                    <label class="mb-2 block text-sm font-semibold text-white/70">New Password</label>
                    <div class="relative">
                        <span class="material-symbols-outlined pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-lg text-white/30">lock</span>
                        <input name="NewPassword" @bind="Model.NewPassword" @bind:event="oninput" type="@(showNewPassword ? "text" : "password")" class="auth-input !pl-12 !pr-10" placeholder="••••••••" />
                        <button type="button" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/30 transition-colors hover:text-white" @onclick="ToggleNewPassword">
                            <span class="material-symbols-outlined text-[18px]">@(showNewPassword ? "visibility_off" : "visibility")</span>
                        </button>
                    </div>
                </div>

                <div>
                    <label class="mb-2 block text-sm font-semibold text-white/70">Confirm New Password</label>
                    <div class="relative">
                        <span class="material-symbols-outlined pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-lg text-white/30">verified_user</span>
                        <input name="ConfirmNewPassword" @bind="Model.ConfirmNewPassword" @bind:event="oninput" type="@(showConfirmNewPassword ? "text" : "password")" class="auth-input !pl-12 !pr-10" placeholder="••••••••" />
                        <button type="button" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/30 transition-colors hover:text-white" @onclick="ToggleConfirmNewPassword">
                            <span class="material-symbols-outlined text-[18px]">@(showConfirmNewPassword ? "visibility_off" : "visibility")</span>
                        </button>
                    </div>
                </div>

                <button type="submit" class="btn-primary-auth mt-4 flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-lg">save</span>
                    <span>Save New Password</span>
                </button>
            </form>
        </div>
    </RightContent>
</AuthSplitShell>

@code {
    [SupplyParameterFromQuery]
    public string? Email { get; set; }

    [SupplyParameterFromQuery]
    public string? Token { get; set; }

    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    private ResetPasswordRequestDto Model { get; } = new();
    private bool showNewPassword;
    private bool showConfirmNewPassword;

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(Email))
        {
            Model.Email = Email;
        }

        if (!string.IsNullOrWhiteSpace(Token))
        {
            Model.Token = Token;
        }
    }

    private void ToggleNewPassword() => showNewPassword = !showNewPassword;

    private void ToggleConfirmNewPassword() => showConfirmNewPassword = !showConfirmNewPassword;
}
