@page "/Auth/Register"
@layout AuthLayout

<PageTitle>Register - LMS Library</PageTitle>

<AuthSplitShell LeftClass="hidden lg:flex flex-col justify-between w-[40%] p-12 relative overflow-hidden border-r border-white/5"
                RightClass="flex-1 flex flex-col justify-center items-center p-8 lg:p-12 overflow-y-auto custom-scrollbar">
    <LeftContent>
        <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary shadow-lg shadow-primary/30">
                <span class="material-symbols-outlined text-xl text-background-dark">menu_book</span>
            </div>
            <span class="text-lg font-bold tracking-tight text-white">Standard Library</span>
        </div>

        <div class="flex flex-col">
            <h1 class="mb-4 text-3xl font-black leading-tight text-white">
                Join the community of<br />
                <span class="text-primary">smart readers</span>
            </h1>
            <p class="mb-10 text-sm leading-relaxed text-white/50">
                Thousands of readers are enjoying our massive book collection. Register now and start your journey.
            </p>

            <div class="space-y-4">
                @foreach (var feat in features)
                {
                    <div class="flex items-center gap-3 text-sm">
                        <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg border border-primary/20 bg-primary/10">
                            <span class="material-symbols-outlined text-base text-primary">@feat.Icon</span>
                        </div>
                        <span class="text-white/70">@feat.Text</span>
                    </div>
                }
            </div>
        </div>

        <div class="glass-card rounded-2xl p-5">
            <div class="mb-2 flex items-center gap-1 text-primary">
                @for (var i = 0; i < 5; i++)
                {
                    <span class="material-symbols-outlined fill-1 text-sm">star</span>
                }
            </div>
            <p class="mb-3 text-xs italic leading-relaxed text-white/70">
                "The best library system I've ever used. Fast search, beautiful interface!"
            </p>
            <div class="flex items-center gap-2">
                <div class="flex h-7 w-7 items-center justify-center rounded-full border border-primary/30 bg-primary/20">
                    <span class="text-xs font-bold text-primary">T</span>
                </div>
                <div>
                    <div class="text-xs font-semibold text-white/80">Minh Khoa Tran</div>
                    <div class="text-[10px] text-white/30">Member since 2024</div>
                </div>
            </div>
        </div>
    </LeftContent>

    <RightContent>
        <div class="w-full max-w-lg">
            <div class="mb-8 flex items-center gap-3 lg:hidden">
                <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-primary">
                    <span class="material-symbols-outlined text-lg text-background-dark">menu_book</span>
                </div>
                <span class="font-bold text-white">Standard Library</span>
            </div>

            <div class="mb-8">
                <h2 class="mb-1 text-2xl font-black text-white">Create new account</h2>
                <p class="text-sm text-white/40">Fill in your details to start using the library</p>
            </div>

            @if (!string.IsNullOrWhiteSpace(Error))
            {
                <div class="mb-6 flex items-start gap-3 rounded-xl border border-red-500/20 bg-red-500/10 px-4 py-3 text-sm text-red-400">
                    <span class="material-symbols-outlined mt-0.5 flex-shrink-0 text-lg">error</span>
                    <div>@Error</div>
                </div>
            }

            <form method="post" action="/auth/register" id="registerForm" novalidate class="space-y-5">
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                    <AuthField ContainerClass="space-y-2" LabelClass="block text-xs font-semibold uppercase tracking-wider text-white/60" Icon="badge" IconLeftClass="3.5" IconClass="text-base text-white/25">
                        <LabelContent>Username <span class="text-red-400">*</span></LabelContent>
                        <ChildContent>
                            <input name="Username"
                                   @bind="Model.Username"
                                   @bind:event="oninput"
                                   class="auth-input !pl-11"
                                   placeholder="vd: nguyenvana"
                                   autocomplete="username" />
                        </ChildContent>
                    </AuthField>

                    <AuthField ContainerClass="space-y-2" LabelClass="block text-xs font-semibold uppercase tracking-wider text-white/60" Icon="person" IconLeftClass="3.5" IconClass="text-base text-white/25">
                        <LabelContent>Full Name <span class="text-red-400">*</span></LabelContent>
                        <ChildContent>
                            <input name="FullName"
                                   @bind="Model.FullName"
                                   @bind:event="oninput"
                                   class="auth-input !pl-11"
                                   placeholder="Nguyễn Văn A"
                                   autocomplete="name" />
                        </ChildContent>
                    </AuthField>
                </div>

                <AuthField ContainerClass="space-y-2" LabelClass="block text-xs font-semibold uppercase tracking-wider text-white/60" Icon="alternate_email" IconLeftClass="3.5" IconClass="text-base text-white/25">
                    <LabelContent>Email <span class="text-red-400">*</span></LabelContent>
                    <ChildContent>
                        <input name="Email"
                               @bind="Model.Email"
                               @bind:event="oninput"
                               class="auth-input !pl-11"
                               placeholder="your@email.com"
                               autocomplete="email" />
                    </ChildContent>
                </AuthField>

                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                    <AuthField ContainerClass="space-y-2" LabelClass="block text-xs font-semibold uppercase tracking-wider text-white/60" Icon="lock" IconLeftClass="3.5" IconClass="text-base text-white/25">
                        <LabelContent>Password <span class="text-red-400">*</span></LabelContent>
                        <ChildContent>
                            <input name="Password"
                                   value="@Model.Password"
                                   id="regPassword"
                                   type="@(showRegisterPassword ? "text" : "password")"
                                   class="auth-input !pl-11 !pr-10"
                                   placeholder="Tối thiểu 6 ký tự"
                                   autocomplete="new-password"
                                   @oninput="HandlePasswordInput" />
                            <button type="button"
                                    @onclick="ToggleRegisterPassword"
                                    class="absolute right-3 top-1/2 -translate-y-1/2 text-white/25 transition-colors hover:text-white/60">
                                <span class="material-symbols-outlined text-base">@(showRegisterPassword ? "visibility" : "visibility_off")</span>
                            </button>
                        </ChildContent>
                    </AuthField>

                    <div class="mt-2 flex gap-1" id="strengthBars">
                        @for (var i = 0; i < 4; i++)
                        {
                            <div class="@GetStrengthBarClass(i)"></div>
                        }
                    </div>
                    <p class="@($"mt-1 text-xs transition-colors {strengthLabelClass}")">@strengthLabel</p>

                    <AuthField ContainerClass="space-y-2" LabelClass="block text-xs font-semibold uppercase tracking-wider text-white/60" Icon="lock_check" IconLeftClass="3.5" IconClass="text-base text-white/25">
                        <LabelContent>Confirm Password <span class="text-red-400">*</span></LabelContent>
                        <ChildContent>
                            <input name="ConfirmPassword"
                                   @bind="Model.ConfirmPassword"
                                   @bind:event="oninput"
                                   id="confirmPassword"
                                   type="@(showConfirmPassword ? "text" : "password")"
                                   class="auth-input !pl-11 !pr-10"
                                   placeholder="Nhập lại mật khẩu"
                                   autocomplete="new-password" />
                            <button type="button"
                                    @onclick="ToggleConfirmPassword"
                                    class="absolute right-3 top-1/2 -translate-y-1/2 text-white/25 transition-colors hover:text-white/60">
                                <span class="material-symbols-outlined text-base">@(showConfirmPassword ? "visibility" : "visibility_off")</span>
                            </button>
                        </ChildContent>
                    </AuthField>
                </div>

                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                    <AuthField ContainerClass="space-y-2" LabelClass="block text-xs font-semibold uppercase tracking-wider text-white/60" Icon="phone" IconLeftClass="3.5" IconClass="text-base text-white/25">
                        <LabelContent>Phone Number</LabelContent>
                        <ChildContent>
                            <input name="Phone"
                                   @bind="Model.Phone"
                                   @bind:event="oninput"
                                   class="auth-input !pl-11"
                                   placeholder="0901234567"
                                   autocomplete="tel" />
                        </ChildContent>
                    </AuthField>

                    <AuthField ContainerClass="space-y-2" LabelClass="block text-xs font-semibold uppercase tracking-wider text-white/60" Icon="cake" IconLeftClass="3.5" IconClass="z-10 text-base text-white/25">
                        <LabelContent>Date of Birth</LabelContent>
                        <ChildContent>
                            <input name="DateOfBirth"
                                   value="@DateOfBirthText"
                                   @onchange="UpdateDateOfBirth"
                                   type="date"
                                   class="auth-input !pl-11"
                                   style="color-scheme: dark;" />
                        </ChildContent>
                    </AuthField>
                </div>

                <AuthField ContainerClass="space-y-2" LabelClass="block text-xs font-semibold uppercase tracking-wider text-white/60" Icon="location_on" IconLeftClass="3.5" IconClass="text-base text-white/25">
                    <LabelContent>Address</LabelContent>
                    <ChildContent>
                        <input name="Address"
                               @bind="Model.Address"
                               @bind:event="oninput"
                               class="auth-input !pl-11"
                               placeholder="123 Đường ABC, Quận XYZ, TP.HCM"
                               autocomplete="street-address" />
                    </ChildContent>
                </AuthField>

                <div class="flex items-start gap-3 pt-1">
                    <input type="checkbox"
                           id="agreeTerms"
                           @bind="agreeTerms"
                           required
                           class="mt-0.5 h-4 w-4 flex-shrink-0 cursor-pointer rounded border-white/20 bg-white/5 text-primary focus:ring-primary/40" />
                    <label for="agreeTerms" class="cursor-pointer leading-relaxed text-sm text-white/50">
                        I agree to the
                        <a href="#" class="text-primary hover:underline">Terms of Service</a>
                        and
                        <a href="#" class="text-primary hover:underline">Privacy Policy</a>
                        of Standard Library
                    </label>
                </div>

                @if (showTermsError)
                {
                    <p class="mt-1 flex items-center gap-1 text-xs text-red-400">
                        <span class="material-symbols-outlined text-xs">warning</span> Bạn cần đồng ý với điều khoản sử dụng
                    </p>
                }

                <button type="submit" @onclick="ValidateTerms" id="registerSubmitBtn" class="btn-primary-auth mt-2 flex items-center justify-center gap-2">
                    <span id="regBtnIcon" class="material-symbols-outlined text-lg">person_add</span>
                    <span id="regBtnText">Create Account</span>
                </button>
            </form>

            <p class="mt-6 text-center text-sm text-white/40">
                Already have an account?
                <a href="/Auth/Login" class="ml-1 font-semibold text-primary transition-colors hover:text-primary/80">
                    Log in now
                </a>
            </p>
        </div>
    </RightContent>
</AuthSplitShell>

@code {
    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    private readonly (string Icon, string Text)[] features =
    [
        ("auto_stories", "Access 500K+ books for free"),
        ("history", "Track your borrowing history"),
        ("notifications_active", "Get new book notifications"),
        ("group", "Join the reader community")
    ];

    private RegisterRequestDto Model { get; } = new();
    private bool showRegisterPassword;
    private bool showConfirmPassword;
    private bool agreeTerms;
    private bool showTermsError;
    private int passwordStrength;
    private string strengthLabel = string.Empty;
    private string strengthLabelClass = "text-white/30";

    private string? DateOfBirthText => Model.DateOfBirth?.ToString("yyyy-MM-dd");

    private void ToggleRegisterPassword() => showRegisterPassword = !showRegisterPassword;

    private void ToggleConfirmPassword() => showConfirmPassword = !showConfirmPassword;

    private void UpdateDateOfBirth(ChangeEventArgs args)
    {
        var raw = args.Value?.ToString();
        Model.DateOfBirth = DateTime.TryParse(raw, out var parsed) ? parsed : null;
    }

    private void HandlePasswordInput(ChangeEventArgs args)
    {
        var value = args.Value?.ToString() ?? string.Empty;
        Model.Password = value;
        passwordStrength = 0;
        if (value.Length >= 6) passwordStrength++;
        if (value.Length >= 10) passwordStrength++;
        if (value.Any(char.IsUpper) && value.Any(char.IsLower)) passwordStrength++;
        if (value.Any(char.IsDigit) && value.Any(ch => !char.IsLetterOrDigit(ch))) passwordStrength++;

        (strengthLabel, strengthLabelClass) = passwordStrength switch
        {
            1 => ("Weak", "text-red-400"),
            2 => ("Medium", "text-orange-400"),
            3 => ("Strong", "text-yellow-400"),
            4 => ("Very strong", "text-emerald-400"),
            _ => (string.Empty, "text-white/30")
        };
    }

    private string GetStrengthBarClass(int index)
    {
        var baseClass = "h-1 flex-1 rounded-full transition-all duration-300 ";
        if (index >= passwordStrength)
        {
            return baseClass + "bg-white/10";
        }

        var color = passwordStrength switch
        {
            1 => "bg-red-500",
            2 => "bg-orange-500",
            3 => "bg-yellow-500",
            _ => "bg-emerald-500"
        };
        return baseClass + color;
    }

    private void ValidateTerms(MouseEventArgs _)
    {
        showTermsError = !agreeTerms;
    }
}
