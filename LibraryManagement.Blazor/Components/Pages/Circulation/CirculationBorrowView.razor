@namespace LibraryManagement.Blazor.Components.Pages
<div class="custom-scrollbar flex-1 min-w-0 overflow-y-auto p-8">
    <div class="group mb-8 flex w-fit cursor-pointer items-center gap-3">
        <a href="/Circulation/Index" class="flex items-center gap-3">
            <span class="material-symbols-outlined text-white/40 transition-colors group-hover:text-primary">arrow_back</span>
            <span class="text-sm font-medium tracking-wide text-white/40 transition-colors group-hover:text-primary">Back to list</span>
        </a>
    </div>

    <div class="mx-auto max-w-4xl">
        <div class="relative overflow-hidden rounded-2xl border border-white/10 bg-white/5 shadow-2xl">
            <div class="pointer-events-none absolute -right-20 -top-20 h-64 w-64 rounded-full bg-primary/10 blur-3xl"></div>
            <div class="relative z-10 border-b border-white/5 p-8">
                <h2 class="mb-2 flex items-center gap-3 text-2xl font-bold tracking-tight text-white">
                    <span class="material-symbols-outlined text-3xl text-primary">post_add</span>
                    Create New Loan
                </h2>
                <p class="text-sm text-white/40">Select reader and search for books. Maximum 5 books per transaction.</p>
            </div>

            <div class="relative z-10 bg-black/10 p-8">
                @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                {
                    <div class="mb-6 rounded-xl border border-red-500/20 bg-red-500/10 p-4 text-sm font-medium text-red-500">@ErrorMessage</div>
                }

                <div class="flex flex-col gap-6">
                    <div class="relative flex flex-col gap-2">
                        <label class="flex items-center gap-2 text-sm font-semibold text-white/80">
                            <span class="material-symbols-outlined text-[18px] text-white/40">badge</span>
                            Reader Information (ID or Name)
                        </label>

                        <div class="group relative">
                            <input value="@UserSearchQuery"
                                   @oninput="HandleUserSearchInput"
                                   class="w-full rounded-xl border border-white/10 bg-white/5 py-3.5 pl-4 pr-10 text-lg text-white placeholder:text-white/20 shadow-inner shadow-black/20 transition-all focus:border-primary/40 focus:outline-none focus:ring-2 focus:ring-primary/40"
                                   placeholder="Type ID, name or email to search..."
                                   autocomplete="off" />
                            <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-2xl text-white/20 transition-colors group-focus-within:text-primary">person_search</span>
                        </div>

                        @if (UserSearchResultsVisible)
                        {
                            <div class="absolute left-0 right-0 top-full z-[100] mt-2 overflow-hidden rounded-xl border border-white/10 bg-[#1a232e] shadow-2xl backdrop-blur-xl">
                                <div class="custom-scrollbar max-h-[300px] overflow-y-auto">
                                    @if (SearchingUsers)
                                    {
                                        <div class="p-4 text-center text-sm text-white/40">Searching...</div>
                                    }
                                    else if (UserSearchResults.Any())
                                    {
                                        @foreach (var user in UserSearchResults)
                                        {
                                            <button type="button"
                                                    @onclick="async () => await SelectUser.InvokeAsync(user)"
                                                    class="group flex w-full cursor-pointer items-center justify-between gap-3 border-b border-white/5 px-4 py-3 text-left transition-colors hover:bg-white/5 last:border-0">
                                                <div class="min-w-0">
                                                    <div class="truncate text-sm font-bold text-white transition-colors group-hover:text-primary">@user.FullName</div>
                                                    <div class="truncate font-mono text-[10px] text-white/40">@user.Email</div>
                                                </div>
                                                <div class="rounded bg-white/5 px-2 py-0.5 text-[10px] font-bold text-primary">ID: @user.UserId</div>
                                            </button>
                                        }
                                    }
                                    else
                                    {
                                        <div class="p-4 text-center text-sm text-white/40">No matching users found.</div>
                                    }
                                </div>
                            </div>
                        }

                        @if (SelectedUserId > 0)
                        {
                            <div class="mt-2 flex items-center justify-between rounded-xl border border-primary/30 bg-primary/10 p-3">
                                <div class="flex items-center gap-3">
                                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary/20 text-primary">
                                        <span class="material-symbols-outlined">person</span>
                                    </div>
                                    <div>
                                        <h4 class="text-sm font-bold text-white">@SelectedUserName</h4>
                                        <p class="font-mono text-[11px] text-primary/70">ID: @SelectedUserId | @SelectedUserEmail</p>
                                    </div>
                                </div>
                                <button type="button"
                                        @onclick="async () => await ClearSelectedUser.InvokeAsync()"
                                        class="rounded-lg p-1.5 text-white/40 transition-colors hover:bg-white/5 hover:text-red-400">
                                    <span class="material-symbols-outlined text-sm">close</span>
                                </button>
                            </div>
                        }
                    </div>

                    <div class="flex flex-col gap-3">
                        <div class="flex items-end justify-between">
                            <label class="flex items-center gap-2 text-sm font-semibold text-white/80">
                                <span class="material-symbols-outlined text-[18px] text-white/40">library_books</span>
                                Selected Books
                            </label>
                            <span class="rounded border border-primary/20 bg-primary/10 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-primary/60">
                                @SelectedBarcodes.Count / 5 books
                            </span>
                        </div>

                        <div class="min-h-[60px] rounded-xl border border-dashed border-white/10 p-3 transition-all">
                            @if (SelectedBarcodes.Any())
                            {
                                <div class="flex flex-wrap gap-2">
                                    @foreach (var barcode in SelectedBarcodes)
                                    {
                                        var selected = AvailableCopies.FirstOrDefault(copy => copy.Barcode == barcode);
                                        <div class="inline-flex items-center gap-2 rounded-[10px] border border-white/15 bg-white/5 px-3 py-2 text-xs text-white/80">
                                            <span>@(selected?.BookTitle ?? barcode)</span>
                                            <span class="font-mono text-[10px] tracking-wider text-primary">@barcode</span>
                                            <button type="button"
                                                    @onclick="async () => await ToggleBookSelection.InvokeAsync(barcode)"
                                                    class="flex h-[18px] w-[18px] items-center justify-center rounded-full border border-red-500/30 bg-red-500/15 text-red-400 transition-all hover:bg-red-500/30"
                                                    title="Remove book">
                                                <span class="material-symbols-outlined text-[12px]">close</span>
                                            </button>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="w-full py-2 text-center text-sm text-white/20">No books selected. Search below to add.</p>
                            }
                        </div>
                    </div>

                    <div class="flex flex-col gap-3">
                        <label class="flex items-center gap-2 text-sm font-semibold text-white/80">
                            <span class="material-symbols-outlined text-[18px] text-white/40">search</span>
                            Search Available Books
                        </label>

                        <div class="group relative">
                            <input value="@BookSearchQuery"
                                   @oninput="HandleBookSearchInput"
                                   class="w-full rounded-xl border border-white/10 bg-white/5 py-3 pl-4 pr-12 text-sm text-white placeholder:text-white/20 shadow-inner shadow-black/20 transition-all focus:border-primary/40 focus:outline-none focus:ring-2 focus:ring-primary/40"
                                   placeholder="Type title, author, or barcode to search..."
                                   autocomplete="off" />
                            <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-xl text-white/20 transition-colors group-focus-within:text-primary">manage_search</span>
                        </div>

                        <div class="custom-scrollbar mt-1 grid max-h-[400px] grid-cols-1 gap-3 overflow-y-auto md:grid-cols-2">
                            @foreach (var copy in FilteredAvailableCopies)
                            {
                                var isSelected = SelectedBarcodes.Contains(copy.Barcode);
                                <button type="button"
                                        @onclick="async () => await ToggleBookSelection.InvokeAsync(copy.Barcode)"
                                        class="group/card flex cursor-pointer items-center gap-3 rounded-xl border p-3 text-left transition-all @(isSelected ? "border-primary/50 bg-primary/10" : "border-white/10 bg-white/5 hover:border-primary/40 hover:bg-primary/10")">
                                    <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg border border-white/5 bg-white/5">
                                        <span class="material-symbols-outlined text-white/30 transition-colors group-hover/card:text-primary">book_2</span>
                                    </div>
                                    <div class="min-w-0 flex-1">
                                        <h4 class="truncate text-sm font-semibold text-white transition-colors group-hover/card:text-primary">@copy.BookTitle</h4>
                                        <div class="mt-0.5 flex items-center gap-2">
                                            <span class="text-[10px] text-white/40">@copy.AuthorName</span>
                                            <span class="text-white/10">•</span>
                                            <span class="font-mono text-[10px] tracking-wider text-primary">@copy.Barcode</span>
                                        </div>
                                    </div>
                                    <div class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full border-2 transition-all @(isSelected ? "border-primary bg-primary text-background-dark" : "border-white/20")">
                                        @if (isSelected)
                                        {
                                            <span class="text-xs font-black">✓</span>
                                        }
                                    </div>
                                </button>
                            }
                            @if (!FilteredAvailableCopies.Any())
                            {
                                <div class="col-span-full rounded-xl border border-white/10 bg-white/5 p-6 text-center text-sm text-white/40">No matching available books found.</div>
                            }
                        </div>
                    </div>

                    <div class="mt-6 flex items-center gap-4 border-t border-white/10 pt-6">
                        <a href="/Circulation/Index" class="flex-1 rounded-xl border border-white/10 bg-white/5 py-3.5 text-center font-bold text-white/80 transition-all hover:bg-white/10">
                            Cancel
                        </a>
                        <button type="button"
                                @onclick="SubmitBorrow"
                                disabled="@IsBusy"
                                class="flex flex-[2] items-center justify-center gap-2 rounded-xl border border-primary bg-primary py-3.5 text-lg font-black text-background-dark transition-all hover:shadow-xl hover:shadow-primary/30 disabled:cursor-not-allowed disabled:opacity-40">
                            <span class="material-symbols-outlined">how_to_reg</span>
                            Confirm Loan
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public string? UserSearchQuery { get; set; }
    [Parameter] public bool UserSearchResultsVisible { get; set; }
    [Parameter] public bool SearchingUsers { get; set; }
    [Parameter] public IReadOnlyList<LibraryManagementDAL.DTO.Circulation.UserSearchResult> UserSearchResults { get; set; } = Array.Empty<LibraryManagementDAL.DTO.Circulation.UserSearchResult>();
    [Parameter] public int SelectedUserId { get; set; }
    [Parameter] public string SelectedUserName { get; set; } = "---";
    [Parameter] public string SelectedUserEmail { get; set; } = string.Empty;
    [Parameter] public string? BookSearchQuery { get; set; }
    [Parameter] public IReadOnlyList<LibraryManagementDAL.DTO.Circulation.AvailableCopyResult> AvailableCopies { get; set; } = Array.Empty<LibraryManagementDAL.DTO.Circulation.AvailableCopyResult>();
    [Parameter] public IReadOnlyCollection<string> SelectedBarcodes { get; set; } = Array.Empty<string>();
    [Parameter] public IEnumerable<LibraryManagementDAL.DTO.Circulation.AvailableCopyResult> FilteredAvailableCopies { get; set; } = Array.Empty<LibraryManagementDAL.DTO.Circulation.AvailableCopyResult>();
    [Parameter] public bool IsBusy { get; set; }
    [Parameter] public EventCallback<string?> UserSearchQueryChanged { get; set; }
    [Parameter] public EventCallback<string?> BookSearchQueryChanged { get; set; }
    [Parameter] public EventCallback<LibraryManagementDAL.DTO.Circulation.UserSearchResult> SelectUser { get; set; }
    [Parameter] public EventCallback ClearSelectedUser { get; set; }
    [Parameter] public EventCallback<string> ToggleBookSelection { get; set; }
    [Parameter] public EventCallback SubmitBorrow { get; set; }

    private async Task HandleUserSearchInput(ChangeEventArgs e) => await UserSearchQueryChanged.InvokeAsync(e.Value?.ToString());
    private async Task HandleBookSearchInput(ChangeEventArgs e) => await BookSearchQueryChanged.InvokeAsync(e.Value?.ToString());
}
