@namespace LibraryManagement.Blazor.Components.Pages
<div class="flex flex-1 overflow-hidden">
    <div class="custom-scrollbar flex-1 overflow-y-auto px-8 py-12">
        <div class="mx-auto max-w-5xl pb-20">
            <div class="mb-10 flex flex-wrap items-start justify-between gap-4">
                <div>
                    <h1 class="mb-2 text-4xl font-bold text-white">Notifications</h1>
                    <p class="text-sm text-white/60">
                        View all your recent notifications and updates
                    </p>
                </div>

                @if (IsStaff)
                {
                    <a href="/Notification/SendNotification"
                       class="flex items-center gap-2 rounded-xl bg-primary px-5 py-3 text-sm font-bold uppercase tracking-wider text-background-dark transition-all hover:shadow-xl hover:shadow-primary/30">
                        <span class="material-symbols-outlined text-lg">campaign</span>
                        Send Notification
                    </a>
                }
                else
                {
                    <button type="button"
                            @onclick="MarkAllAsRead"
                            class="rounded-xl bg-primary px-5 py-3 text-sm font-bold uppercase tracking-wider text-background-dark transition-all hover:shadow-xl hover:shadow-primary/30">
                        Mark All as Read
                    </button>
                }
            </div>

            <div class="rounded-2xl border border-white/5 bg-white/5 p-8 shadow-2xl">
                <div class="mb-8 flex flex-wrap items-center justify-between gap-3">
                    <h2 class="text-2xl font-bold text-white">Your Notifications</h2>
                    <span class="text-sm text-white/40">
                        Page @NotificationPage.CurrentPage / @NotificationPage.TotalPages
                    </span>
                </div>

                @if (Notifications.Any())
                {
                    <div class="flex flex-col gap-4">
                        @foreach (var item in Notifications)
                        {
                            <div class="rounded-2xl border @(item.IsRead ? "border-white/5 bg-black/20" : "border-primary/30 bg-primary/10") p-5 transition-all hover:bg-white/5">
                                <div class="flex items-start justify-between gap-4">
                                    <div class="flex items-start gap-4">
                                                <div class="flex h-12 w-12 items-center justify-center rounded-xl @(item.IsRead ? "bg-white/5 text-white/60" : "bg-primary/20 text-primary")">
                                            <span class="material-symbols-outlined">notifications</span>
                                        </div>

                                        <div class="min-w-0 flex-1">
                                            <div class="flex flex-wrap items-center gap-2">
                                                <h3 class="text-lg font-bold text-white">@item.Title</h3>

                                                @if (!IsStaff && !item.IsRead)
                                                {
                                                    <span class="rounded-full bg-primary px-2 py-1 text-[10px] font-bold uppercase tracking-wider text-background-dark">
                                                        New
                                                    </span>
                                                }

                                                @if (!string.IsNullOrWhiteSpace(item.Type))
                                                {
                                            <span class="rounded-full bg-white/5 px-2 py-1 text-[10px] uppercase tracking-wider text-white/60">
                                                        @item.Type
                                                    </span>
                                                }
                                            </div>

                                            <p class="mt-2 whitespace-normal break-words text-sm leading-6 text-white/70">
                                                @item.Message
                                            </p>

                                            <div class="mt-3 flex flex-wrap gap-4 text-xs text-white/40">
                                                @if (item.SentAt is not null)
                                                {
                                                    <span>Sent: @item.SentAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    <div class="shrink-0">
                                        @if (IsStaff)
                                        {
                                            <span class="rounded-full border border-primary/20 bg-primary/10 px-3 py-1 text-xs text-primary">
                                                Sent
                                            </span>
                                        }
                                        else if (item.IsRead)
                                        {
                                            <span class="rounded-full border border-green-400/20 bg-green-400/10 px-3 py-1 text-xs text-green-300">
                                                Read
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="rounded-full border border-yellow-400/20 bg-yellow-400/10 px-3 py-1 text-xs text-yellow-300">
                                                Unread
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    @if (NotificationPage.TotalPages > 1)
                    {
                        var startPage = Math.Max(1, NotificationPage.CurrentPage - 2);
                        var endPage = Math.Min(NotificationPage.TotalPages, NotificationPage.CurrentPage + 2);
                            <div class="mt-8 flex flex-wrap items-center justify-between gap-4 border-t border-white/5 pt-6">
                            <div class="text-sm text-white/40">
                                Trang @NotificationPage.CurrentPage trong @NotificationPage.TotalPages
                            </div>

                            <div class="flex flex-wrap items-center gap-2">
                                @if (NotificationPage.CurrentPage > 1)
                                {
                                    <a href="@BuildHref(NotificationPage.CurrentPage - 1)" class="rounded-xl border border-white/5 bg-white/5 px-4 py-2 text-sm text-white/80 transition-all hover:border-primary/30 hover:bg-white/10 hover:text-white">
                                        Previous
                                    </a>
                                }
                                else
                                {
                                    <span class="cursor-not-allowed rounded-xl border border-white/5 bg-white/5 px-4 py-2 text-sm text-white/20">
                                        Previous
                                    </span>
                                }

                                @for (var i = startPage; i <= endPage; i++)
                                {
                                    if (i == NotificationPage.CurrentPage)
                                    {
                                        <span class="min-w-[42px] rounded-xl bg-primary px-4 py-2 text-center text-sm font-bold text-background-dark">
                                            @i
                                        </span>
                                    }
                                    else
                                    {
                                        <a href="@BuildHref(i)" class="min-w-[42px] rounded-xl border border-white/5 bg-white/5 px-4 py-2 text-center text-sm text-white/80 transition-all hover:border-primary/30 hover:bg-white/10 hover:text-white">
                                            @i
                                        </a>
                                    }
                                }

                                @if (NotificationPage.CurrentPage < NotificationPage.TotalPages)
                                {
                                    <a href="@BuildHref(NotificationPage.CurrentPage + 1)" class="rounded-xl border border-white/5 bg-white/5 px-4 py-2 text-sm text-white/80 transition-all hover:border-primary/30 hover:bg-white/10 hover:text-white">
                                        Next
                                    </a>
                                }
                                else
                                {
                                    <span class="cursor-not-allowed rounded-xl border border-white/5 bg-white/5 px-4 py-2 text-sm text-white/20">
                                        Next
                                    </span>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <SurfacePanel ContainerClass="rounded-2xl border border-dashed border-white/5 bg-black/20 p-12 text-center"
                                 Icon="notifications_off"
                                 IconWrapperClass="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-white/5"
                                 IconClass="text-4xl text-white/30"
                                 Title="No notifications yet"
                                 TitleClass="mb-2 text-xl font-bold text-white"
                                 Message="You don't have any notifications at the moment."
                                 MessageClass="text-sm text-white/50" />
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public bool IsStaff { get; set; }
    [Parameter] public LibraryManagementDAL.DTO.Pagination.PaginationResponseModel<LibraryManagementDAL.Models.Notification> NotificationPage { get; set; } = new();
    [Parameter] public IReadOnlyList<LibraryManagementDAL.Models.Notification> Notifications { get; set; } = Array.Empty<LibraryManagementDAL.Models.Notification>();
    [Parameter] public Func<int, string> BuildHref { get; set; } = default!;
    [Parameter] public EventCallback MarkAllAsRead { get; set; }
}
