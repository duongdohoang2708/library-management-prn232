@model IEnumerable<LibraryManagementDAL.Models.BorrowTransaction>

@{
    ViewData["Title"] = "Quản lý mượn trả";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="flex-1 p-8 min-w-0 overflow-y-auto custom-scrollbar">

    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-4xl font-bold font-display text-white mb-2">Circulation Management</h1>
            <p class="text-white/60">List of active or overdue borrowing transactions</p>
        </div>
        <div class="flex items-center gap-3">
            <a asp-controller="Reservation" asp-action="Index" class="flex items-center gap-2 px-5 py-2.5 bg-white/5 text-white font-bold rounded-xl border border-white/10 hover:bg-white/10 transition-all">
                <span class="material-symbols-outlined text-xl text-primary">bookmarks</span>
                Reservations
            </a>
            <a asp-action="Borrow" class="flex items-center gap-2 px-5 py-2.5 bg-primary text-background-dark font-bold rounded-xl hover:shadow-lg hover:shadow-primary/20 transition-all">
                <span class="material-symbols-outlined text-xl">add</span>
                New Transaction
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-6 px-4 py-3 bg-emerald-500/10 border border-emerald-500/20 rounded-xl flex items-center justify-between">
            <div class="flex items-center gap-3 text-emerald-400">
                <span class="material-symbols-outlined">check_circle</span>
                <span class="font-medium text-sm">@TempData["SuccessMessage"]</span>
            </div>
            <button class="text-white/40 hover:text-white transition-colors" onclick="this.parentElement.remove()">
                <span class="material-symbols-outlined text-lg">close</span>
            </button>
        </div>
    }

    <!-- Search Bar & Filters -->
    <div class="bg-black/20 border border-white/10 rounded-2xl p-6 mb-8 backdrop-blur-md">
        <form method="get" asp-action="Index" id="filterForm" class="flex flex-col md:flex-row gap-4">
            <div class="flex-1 relative">
                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-white/40">search</span>
                <input type="text" name="searchQuery" value="@ViewBag.SearchQuery" 
                       oninput="clearTimeout(this.delay); this.delay = setTimeout(() => { triggerSearch(this.form); }, 500);"
                       placeholder="Transaction ID, User ID, Book..." 
                       class="w-full bg-black/40 border border-white/10 rounded-xl py-3 pl-12 pr-4 text-white focus:outline-none focus:border-primary transition-colors" />
            </div>
            
            <div class="flex gap-4">
                <select name="statusFilter" onchange="triggerSearch(this.form)" class="bg-black/40 border border-white/10 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-primary transition-colors cursor-pointer">
                    <option value="">All Statuses</option>
                    <option value="Borrowing" selected="@(ViewBag.StatusFilter == "Borrowing")">Borrowing</option>
                    <option value="Overdue" selected="@(ViewBag.StatusFilter == "Overdue")">Overdue</option>
                    <option value="Returned" selected="@(ViewBag.StatusFilter == "Returned")">Returned</option>
                </select>

                @if(!string.IsNullOrEmpty(ViewBag.SearchQuery) || !string.IsNullOrEmpty(ViewBag.StatusFilter)) 
                {
                    <a asp-action="Index" class="px-4 py-3 bg-white/5 text-white/60 font-medium rounded-xl hover:bg-white/10 transition-colors flex items-center" title="Clear Filters">
                        <span class="material-symbols-outlined">close</span>
                    </a>
                }
            </div>
        </form>
    </div>

    <!-- Transaction List Card -->
    <div class="bg-white/5 border border-white/10 rounded-2xl overflow-hidden shadow-2xl" id="tableContainer">
        <div class="p-6 border-b border-white/5 bg-black/20 text-white flex items-center justify-between">
            <h3 class="text-lg font-bold flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">receipt_long</span>
                Active Transactions
            </h3>
        </div>

        <div class="overflow-x-auto custom-scrollbar">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-black/20 text-white/40 text-[11px] uppercase tracking-wider font-bold">
                        <th class="p-4 border-b border-white/5">Transaction ID</th>
                        <th class="p-4 border-b border-white/5">Borrower (ID)</th>
                        <th class="p-4 border-b border-white/5">Borrow Date</th>
                        <th class="p-4 border-b border-white/5">Due Date</th>
                        <th class="p-4 border-b border-white/5">Status</th>
                        <th class="p-4 border-b border-white/5 min-w-[200px]">Books Held</th>
                        <th class="p-4 border-b border-white/5 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="text-sm">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            var isOverdue = item.DueDate.Date < DateTime.UtcNow.Date;
                            <tr class="text-white/80 border-b border-white/5 hover:bg-white/5 transition-colors group">
                                <td class="p-4 font-medium text-white">#@item.BorrowTransactionId</td>
                                <td class="p-4">
                                    <div class="font-semibold text-white group-hover:text-primary transition-colors">@item.User?.FullName</div>
                                    <div class="text-[11px] text-white/40">ID: @item.UserId</div>
                                </td>
                                <td class="p-4 text-white/60">@item.BorrowDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="p-4">
                                    <span class="px-2 py-1 rounded-md text-xs font-semibold @(isOverdue ? "bg-red-500/10 text-red-400 border border-red-500/20" : "text-white/80")">
                                        @item.DueDate.ToString("dd/MM/yyyy")
                                    </span>
                                </td>
                                <td class="p-4">
                                    @if(item.Status == "Borrowing" && !isOverdue)
                                    {
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-blue-500/10 text-blue-400 border border-blue-500/20 text-[11px] font-bold uppercase tracking-wider">
                                            <span class="w-1.5 h-1.5 rounded-full bg-blue-400"></span> Borrowing
                                        </span>
                                    }
                                    else if(item.Status == "Overdue" || (item.Status == "Borrowing" && isOverdue))
                                    {
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-red-500/10 text-red-500 border border-red-500/20 text-[11px] font-bold uppercase tracking-wider">
                                            <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span> Overdue
                                        </span>
                                    }
                                    else if(item.Status == "Returned")
                                    {
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 text-[11px] font-bold uppercase tracking-wider">
                                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span> Returned
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-white/10 text-white/60 border border-white/10 text-[11px] font-bold uppercase tracking-wider">
                                            @item.Status
                                        </span>
                                    }
                                </td>
                                <td class="p-4">
                                    <div class="flex flex-col gap-1.5">
                                        @{
                                            var activeDetails = item.BorrowDetails.Where(d => d.ActualReturnDate == null).ToList();
                                        }
                                        @foreach(var detail in activeDetails)
                                        {
                                            <div class="flex items-center gap-2 bg-black/20 p-2 rounded border border-white/5">
                                                <span class="material-symbols-outlined text-white/30 text-sm">book</span>
                                                <div class="min-w-0 flex-1">
                                                    <div class="text-[12px] text-white truncate" title="@detail.BookCopy?.Book?.Title">@detail.BookCopy?.Book?.Title</div>
                                                    <div class="text-[10px] text-primary font-mono tracking-wider">@detail.BookCopy?.Barcode</div>
                                                </div>
                                            </div>
                                        }
                                        @if(!activeDetails.Any())
                                        {
                                            <div class="flex items-center gap-2 bg-emerald-500/5 p-2 rounded border border-emerald-500/10">
                                                <span class="material-symbols-outlined text-emerald-500/40 text-sm">check_circle</span>
                                                <div class="text-[11px] text-emerald-400 font-bold uppercase tracking-widest">All Items Returned</div>
                                            </div>
                                        }
                                    </div>
                                </td>
                                <td class="p-4 align-middle">
                                    <div class="flex justify-end items-center gap-2">
                                        <a asp-controller="Notification"
                                           asp-action="SendNotification"
                                           asp-route-userId="@item.UserId"
                                           class="inline-flex h-10 w-10 items-center justify-center bg-white/5 text-blue-400 hover:bg-blue-500 hover:text-white border border-white/10 hover:border-blue-500 rounded-lg transition-all"
                                           title="Send Notification">
                                            <span class="material-symbols-outlined text-lg">notifications_active</span>
                                        </a>

                                        @if (item.Status != "Returned")
                                        {
                                            <a asp-action="Return"
                                               asp-route-id="@item.BorrowTransactionId"
                                               class="inline-flex h-10 w-10 items-center justify-center bg-white/5 text-primary hover:bg-primary hover:text-background-dark border border-white/10 hover:border-primary rounded-lg transition-all"
                                               title="Process Return">
                                                <span class="material-symbols-outlined text-lg">assignment_return</span>
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="inline-flex h-10 w-10 items-center justify-center text-white/20 border border-white/10 rounded-lg cursor-not-allowed"
                                                  title="Transaction Completed">
                                                <span class="material-symbols-outlined text-lg">check_circle</span>
                                            </span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="p-12 text-center text-white/40">
                                <span class="material-symbols-outlined text-6xl text-white/10 mb-4 block">receipt_long</span>
                                <p class="text-sm">No active borrowing transactions found.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (ViewBag.TotalPages > 1)
        {
            <div class="p-8 border-t border-white/5 bg-black/10 flex items-center justify-between">
                <div class="text-[10px] text-white/30 font-bold uppercase tracking-[0.2em] mb-0 mr-4">
                    Page <span class="text-white">@ViewBag.CurrentPage</span> / <span class="text-white">@ViewBag.TotalPages</span>
                </div>
                <div class="flex items-center gap-3">
                    @if (ViewBag.CurrentPage > 1)
                    {
                        <button type="button" onclick="changePage(@(ViewBag.CurrentPage - 1))" 
                                class="px-6 py-2 rounded-full bg-white/5 border border-white/10 text-white/80 text-xs font-bold hover:bg-white/10 hover:border-white/20 transition-all flex items-center justify-center group shadow-lg">
                            <span class="material-symbols-outlined text-[18px] mr-1 group-hover:-translate-x-1 transition-transform">chevron_left</span>
                            Prev
                        </button>
                    }
                    
                    <div class="flex items-center gap-2 mx-2">
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            if (i == 1 || i == ViewBag.TotalPages || (i >= ViewBag.CurrentPage - 1 && i <= ViewBag.CurrentPage + 1))
                            {
                                <button type="button" onclick="changePage(@i)" 
                                        class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-black transition-all duration-300
                                               @(i == ViewBag.CurrentPage 
                                                 ? "bg-primary text-background-dark shadow-[0_0_20px_rgba(234,179,8,0.3)] ring-4 ring-primary/20" 
                                                 : "bg-transparent text-white/40 hover:text-white border border-white/10 hover:border-white/30")">
                                    @i
                                </button>
                            }
                            else if (i == 2 || i == ViewBag.TotalPages - 1)
                            {
                                @if((i == 2 && ViewBag.CurrentPage > 3) || (i == ViewBag.TotalPages - 1 && ViewBag.CurrentPage < ViewBag.TotalPages - 2))
                                {
                                    <span class="text-white/20 px-1 font-black">...</span>
                                }
                            }
                        }
                    </div>

                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                    {
                        <button type="button" onclick="changePage(@(ViewBag.CurrentPage + 1))" 
                                class="px-6 py-2 rounded-full bg-white/5 border border-white/10 text-white/80 text-xs font-bold hover:bg-white/10 hover:border-white/20 transition-all flex items-center justify-center group shadow-lg">
                            Next
                            <span class="material-symbols-outlined text-[18px] ml-1 group-hover:translate-x-1 transition-transform">chevron_right</span>
                        </button>
                    }
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function triggerSearch(form) {
            const formData = new FormData(form);
            const params = new URLSearchParams(formData);
            
            const tableContainer = document.getElementById('tableContainer');
            if (tableContainer) {
                tableContainer.style.opacity = '0.5';
                tableContainer.style.pointerEvents = 'none';
            }

            fetch(`${form.action}?${params.toString()}`)
            .then(response => response.text())
            .then(html => {
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');
                const newTable = doc.getElementById('tableContainer');
                
                if (tableContainer && newTable) {
                    tableContainer.innerHTML = newTable.innerHTML;
                    tableContainer.style.opacity = '1';
                    tableContainer.style.pointerEvents = 'auto';
                    window.history.replaceState({}, '', `${form.action}?${params.toString()}`);
                }
            })
            .catch(error => {
                console.error("Error fetching data:", error);
                if (tableContainer) {
                    tableContainer.style.opacity = '1';
                    tableContainer.style.pointerEvents = 'auto';
                }
            });
        }

        function changePage(page) {
            const form = document.getElementById('filterForm');
            const formData = new FormData(form);
            const params = new URLSearchParams(formData);
            params.set('page', page);
            
            const tableContainer = document.getElementById('tableContainer');
            if (tableContainer) {
                tableContainer.style.opacity = '0.5';
                tableContainer.style.pointerEvents = 'none';
            }

            fetch(`${form.action}?${params.toString()}`)
            .then(response => response.text())
            .then(html => {
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');
                const newTable = doc.getElementById('tableContainer');
                
                if (tableContainer && newTable) {
                    tableContainer.innerHTML = newTable.innerHTML;
                    tableContainer.style.opacity = '1';
                    tableContainer.style.pointerEvents = 'auto';
                    window.history.replaceState({}, '', `${form.action}?${params.toString()}`);
                    // Scroll to top of table
                    tableContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            })
            .catch(error => {
                console.error("Error fetching data:", error);
                if (tableContainer) {
                    tableContainer.style.opacity = '1';
                    tableContainer.style.pointerEvents = 'auto';
                }
            });
        }
    </script>
}
