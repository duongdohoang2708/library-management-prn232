@model LibraryManagementDAL.DTO.Circulation.ReturnRequest
@using LibraryManagementDAL.Models
@using LibraryManagementDAL.DTO.Circulation

@{
    ViewData["Title"] = "Hoàn trả sách";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    var unreturnedDetails = ViewBag.UnreturnedDetails as List<CirculationBorrowDetailItem>;
}

<div class="flex-1 p-8 min-w-0 overflow-y-auto custom-scrollbar">

    <div class="flex items-center gap-3 mb-8 cursor-pointer w-fit group" onclick="window.history.back()">
        <span class="material-symbols-outlined text-white/40 group-hover:text-primary transition-colors">arrow_back</span>
        <span class="text-sm font-medium text-white/40 group-hover:text-primary transition-colors tracking-wide">Back to list</span>
    </div>
    
    <div class="max-w-4xl mx-auto">
        <div class="bg-white/5 border border-white/10 rounded-2xl overflow-hidden shadow-2xl relative">
            
            <!-- Decorator glow -->
            <div class="absolute -top-20 -right-20 w-64 h-64 bg-primary/10 blur-3xl rounded-full pointer-events-none"></div>

            <div class="p-8 border-b border-white/5 relative z-10">
                <h2 class="text-2xl font-bold tracking-tight text-white mb-2 flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary text-3xl">assignment_return</span>
                    Return Books - Transaction #@ViewBag.TransactionId
                </h2>
                <div class="flex items-center gap-2 mt-3">
                    <span class="text-sm text-white/40">Borrower:</span>
                    <span class="px-2.5 py-1 bg-white/5 border border-white/10 rounded-md text-white font-medium text-sm">
                        @ViewBag.UserFullName (ID: @ViewBag.UserId)
                    </span>
                </div>
            </div>

            <div class="p-8 relative z-10 bg-black/10">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="mb-6 p-4 bg-green-500/10 border border-green-500/20 text-green-400 text-sm rounded-xl font-medium flex items-center gap-3">
                        <span class="material-symbols-outlined">check_circle</span>
                        @TempData["SuccessMessage"]
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="mb-6 p-4 bg-red-500/10 border border-red-500/20 text-red-400 text-sm rounded-xl font-medium flex items-center gap-3">
                        <span class="material-symbols-outlined">error</span>
                        @TempData["ErrorMessage"]
                    </div>
                }

                <form asp-action="Return" asp-route-id="@ViewBag.TransactionId" method="post" class="flex flex-col gap-8">
                    <div asp-validation-summary="ModelOnly" class="p-4 bg-red-500/10 border border-red-500/20 text-red-500 text-sm rounded-xl font-medium hidden"></div>

                    <!-- Books Selection -->
                    <div class="flex flex-col gap-4">
                        <div class="flex items-center justify-between">
                            <label class="text-sm font-semibold text-white/80 flex items-center gap-2">
                                <span class="material-symbols-outlined text-[18px] text-white/40">library_books</span>
                                Select books to return
                            </label>
                            <span class="text-xs text-white/40">By default selects all unreturned books</span>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            @if (unreturnedDetails != null && unreturnedDetails.Any())
                            {
                                var now = DateTime.UtcNow.Date;
                                foreach (var detail in unreturnedDetails)
                                {
                                    var isOverdue = now > detail.DueDate.Date;
                                    var lateDays = isOverdue ? (now - detail.DueDate.Date).Days : 0;
                                    var expectedFine = lateDays * 5000;

                                    <div class="relative flex flex-col p-4 bg-white/5 rounded-xl border border-white/10 group transition-all">
                                        <div class="flex items-start gap-4">
                                            <div class="pt-1">
                                                <input type="checkbox" name="BorrowDetailIds" value="@detail.BorrowDetailId" 
                                                       class="w-5 h-5 rounded border-white/20 bg-black/50 text-primary focus:ring-primary focus:ring-offset-background-dark peer"
                                                       @(Model.BorrowDetailIds.Contains(detail.BorrowDetailId) ? "checked" : "") />
                                            </div>
                                            <div class="flex-1 min-w-0">
                                                <div class="flex items-start justify-between gap-2">
                                                    <div>
                                                        <h4 class="text-sm font-bold text-white mb-1 leading-tight">@detail.BookTitle</h4>
                                                        <p class="text-[11px] text-primary font-mono tracking-wider mb-2">Code: @detail.Barcode</p>
                                                    </div>
                                                    <!-- Quick Report Actions -->
                                                    <div class="flex gap-1">
                                                        <button type="button" 
                                                                onclick="submitReport('@detail.BorrowDetailId', '@BookCopyStatus.Damaged', 50000)"
                                                                class="p-1.5 rounded-lg bg-orange-500/10 border border-orange-500/20 text-orange-400 hover:bg-orange-500/20 hover:border-orange-500/40 transition-all" 
                                                                title="Report Damaged (Fine 50,000)">
                                                            <span class="material-symbols-outlined text-sm">heart_broken</span>
                                                        </button>
                                                        <button type="button" 
                                                                onclick="submitReport('@detail.BorrowDetailId', '@BookCopyStatus.Lost', 100000)"
                                                                class="p-1.5 rounded-lg bg-red-500/10 border border-red-500/20 text-red-400 hover:bg-red-500/20 hover:border-red-500/40 transition-all" 
                                                                title="Report Lost (Fine 100,000)">
                                                            <span class="material-symbols-outlined text-sm">block</span>
                                                        </button>
                                                    </div>
                                                </div>
                                                
                                                @if (isOverdue)
                                                {
                                                    <div class="flex flex-col gap-1 mt-2 p-2 bg-red-500/10 rounded-lg border border-red-500/20">
                                                        <span class="text-[10px] uppercase font-bold text-red-400 tracking-wider">Overdue by @lateDays days</span>
                                                        <span class="text-xs font-bold text-red-300">Expected fine: @expectedFine.ToString("N0") VND</span>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="inline-block px-2 py-0.5 bg-green-500/10 text-green-400 border border-green-500/20 rounded text-[10px] font-bold uppercase tracking-wider">In Time</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                        <span asp-validation-for="BorrowDetailIds" class="text-red-400 text-xs font-semibold mt-1"></span>
                    </div>

                    <!-- Condition Remarks -->
                    <div class="flex flex-col gap-2">
                        <label asp-for="ConditionRemarks" class="text-sm font-semibold text-white/80 flex items-center gap-2">
                            <span class="material-symbols-outlined text-[18px] text-white/40">note_alt</span>
                            Book Condition Notes (Optional)
                        </label>
                        <textarea asp-for="ConditionRemarks" rows="2"
                                  class="w-full bg-white/5 border border-white/10 rounded-xl p-4 text-white placeholder:text-white/20 focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary/40 transition-all text-sm custom-scrollbar" 
                                  placeholder="Notes if the book is torn, wet, missing pages..."></textarea>
                    </div>

                    <!-- Actions -->
                    <div class="flex items-center gap-4 pt-6 border-t border-white/10">
                        <button type="button" onclick="window.history.back()" class="flex-1 py-3 border border-white/10 bg-white/5 hover:bg-white/10 text-white/80 font-bold rounded-xl transition-all text-center">
                            Cancel
                        </button>
                        <button type="submit" class="flex-1 py-3 border border-primary bg-primary hover:bg-primary/90 text-background-dark font-black rounded-xl hover:shadow-xl hover:shadow-primary/30 transition-all flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined">how_to_reg</span>
                            Confirm Return
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <!-- Hidden form for ReportIssue -->
    <form id="reportIssueForm" asp-action="ReportIssue" method="post" style="display:none;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="transactionId" value="@ViewBag.TransactionId" />
        <input type="hidden" name="borrowDetailId" id="reportBorrowDetailId" />
        <input type="hidden" name="status" id="reportStatus" />
        <input type="hidden" name="fineAmount" id="reportFineAmount" />
    </form>

    <script>
        function submitReport(borrowDetailId, status, fineAmount) {
            if (confirm('Bạn có chắc chắn muốn báo cáo sự cố này? Hành động này sẽ áp dụng phí phạt ngay lập tức.')) {
                document.getElementById('reportBorrowDetailId').value = borrowDetailId;
                document.getElementById('reportStatus').value = status;
                document.getElementById('reportFineAmount').value = fineAmount;
                document.getElementById('reportIssueForm').submit();
            }
        }
    </script>
}
