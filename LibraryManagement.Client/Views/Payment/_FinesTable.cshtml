@using LibraryManagementDAL.DTO.Payment
@model List<UserFinesDTO>

<div class="overflow-x-auto">
    <table class="w-full text-left border-collapse">
        <thead>
            <tr class="border-b border-white/10 bg-white/5">
                <th class="py-4 px-6 font-medium text-white/60">User ID</th>
                <th class="py-4 px-6 font-medium text-white/60">Full Name</th>
                <th class="py-4 px-6 font-medium text-white/60">Email</th>
                <th class="py-4 px-6 font-medium text-white/60 text-center">Books Fined</th>
                <th class="py-4 px-6 font-medium text-white/60 text-right">Total Debt</th>
                <th class="py-4 px-6 font-medium text-white/60 text-right">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-white/5 text-white/80">
            @if (Model != null && Model.Any())
            {
                foreach (var user in Model)
                {
                    <tr class="hover:bg-white/[0.02] transition-colors group">
                        <td class="py-4 px-6 whitespace-nowrap">
                            <span class="text-white/60">#@user.UserId</span>
                        </td>
                        <td class="py-4 px-6">
                            <p class="font-medium text-white">@user.FullName</p>
                        </td>
                        <td class="py-4 px-6 text-white/80">
                            @user.Email
                        </td>
                        <td class="py-4 px-6 whitespace-nowrap text-center">
                            <span class="px-3 py-1 bg-red-500/10 text-red-400 rounded-full text-sm border border-red-500/20">
                                @user.UnpaidBookCount books
                            </span>
                        </td>
                        <td class="py-4 px-6 whitespace-nowrap text-right font-bold text-red-400">
                            @user.TotalUnpaidFine.ToString("N0") VNĐ
                        </td>
                        <td class="py-4 px-6 whitespace-nowrap text-right">
                            <a asp-action="Details" asp-route-id="@user.UserId" 
                               class="px-4 py-2 bg-primary text-background-dark hover:bg-primary/90 rounded-lg transition-colors inline-flex items-center gap-2 font-medium">
                                <span class="material-symbols-outlined text-[20px]">payments</span>
                                Collect
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="py-12 text-center text-white/40">
                        <span class="material-symbols-outlined text-5xl mb-4 opacity-50 block">sentiment_satisfied</span>
                        Great! There are currently no members with unpaid fines.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination -->
@if (ViewBag.TotalPages > 1)
{
    <div class="p-8 border-t border-white/5 bg-black/10 flex items-center justify-between">
        <div class="text-[10px] text-white/30 font-bold uppercase tracking-[0.2em] mb-0 mr-4">
            Page <span class="text-white">@ViewBag.CurrentPage</span> / <span class="text-white">@ViewBag.TotalPages</span>
        </div>
        <div class="flex items-center gap-3">
            @if (ViewBag.CurrentPage > 1)
            {
                <button type="button" onclick="changePage(@(ViewBag.CurrentPage - 1))" 
                        class="px-6 py-2 rounded-full bg-white/5 border border-white/10 text-white/80 text-xs font-bold hover:bg-white/10 hover:border-white/20 transition-all flex items-center justify-center group shadow-lg">
                    <span class="material-symbols-outlined text-[18px] mr-1 group-hover:-translate-x-1 transition-transform">chevron_left</span>
                    Prev
                </button>
            }
            
            <div class="flex items-center gap-2 mx-2">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    if (i == 1 || i == ViewBag.TotalPages || (i >= ViewBag.CurrentPage - 1 && i <= ViewBag.CurrentPage + 1))
                    {
                        <button type="button" onclick="changePage(@i)" 
                                class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-black transition-all duration-300
                                       @(i == ViewBag.CurrentPage 
                                         ? "bg-primary text-background-dark shadow-[0_0_20px_rgba(234,179,8,0.3)] ring-4 ring-primary/20" 
                                         : "bg-transparent text-white/40 hover:text-white border border-white/10 hover:border-white/30")">
                            @i
                        </button>
                    }
                    else if (i == 2 || i == ViewBag.TotalPages - 1)
                    {
                        @if((i == 2 && ViewBag.CurrentPage > 3) || (i == ViewBag.TotalPages - 1 && ViewBag.CurrentPage < ViewBag.TotalPages - 2))
                        {
                            <span class="text-white/20 px-1 font-black">...</span>
                        }
                    }
                }
            </div>

            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <button type="button" onclick="changePage(@(ViewBag.CurrentPage + 1))" 
                        class="px-6 py-2 rounded-full bg-white/5 border border-white/10 text-white/80 text-xs font-bold hover:bg-white/10 hover:border-white/20 transition-all flex items-center justify-center group shadow-lg">
                    Next
                    <span class="material-symbols-outlined text-[18px] ml-1 group-hover:translate-x-1 transition-transform">chevron_right</span>
                </button>
            }
        </div>
    </div>
}
