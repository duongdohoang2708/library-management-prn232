@{
    ViewData["Title"] = "Electronic Payment Gateway";
    Layout = null; // Use a blank layout to simulate an external gateway
    
    decimal amount = Convert.ToDecimal(ViewBag.Amount);
    string methodStr = ViewBag.Method?.ToString() ?? "Banking";
    string providerName = methodStr == "Banking" ? "Bank Transfer" : 
                          methodStr == "Momo" ? "MoMo E-Wallet" : "VNPay Gateway";
    
    string logoIcon = methodStr == "Banking" ? "account_balance" : 
                      methodStr == "Momo" ? "account_balance_wallet" : "qr_code_scanner";
}

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Payment Gateway</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <style>
        body { font-family: 'Outfit', sans-serif; background-color: #0f172a; color: white; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        
        @@keyframes scan {
            0% { top: 0; opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { top: 100%; opacity: 0; }
        }
        .scanner-line {
            height: 2px;
            background: #ef4444; /* red-500 */
            width: 100%;
            position: absolute;
            animation: scan 2s infinite linear;
            box-shadow: 0 0 10px #ef4444, 0 0 20px #ef4444;
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">

    <div class="max-w-md w-full bg-slate-800 rounded-3xl shadow-2xl overflow-hidden border border-slate-700">
        
        <!-- Header -->
        <div class="bg-slate-900 p-6 text-center border-b border-slate-700">
            <div class="w-16 h-16 bg-blue-500/20 text-blue-400 rounded-2xl flex items-center justify-center mx-auto mb-4 border border-blue-500/30">
                <span class="material-symbols-outlined text-3xl">@logoIcon</span>
            </div>
            <h1 class="text-2xl font-bold text-white mb-1">@providerName</h1>
            <p class="text-slate-400 text-sm">Secure Library Payment Gateway</p>
        </div>

        <!-- Body -->
        <div class="p-8">
            <div class="text-center mb-8">
                <p class="text-slate-400 mb-2">Amount to pay</p>
                <div class="text-4xl font-bold text-red-400">@amount.ToString("N0") <span class="text-xl text-red-400/70">VND</span></div>
            </div>

            <!-- QR Code Simulation -->
            <div class="relative w-48 h-48 mx-auto bg-white rounded-xl p-3 mb-8 shadow-inner overflow-hidden flex items-center justify-center group cursor-pointer hover:scale-105 transition-transform duration-300" id="qrContainer">
                <div class="absolute inset-0 scanner-line"></div>
                <!-- Mock QR Image using grid -->
                <div class="w-full h-full grid grid-cols-5 gap-1 opacity-80">
                    @for (int i = 0; i < 25; i++)
                    {
                        var isDark = (new Random().Next(0, 2) == 1) ? "bg-black" : "bg-white";
                        <div class="@isDark rounded-sm"></div>
                    }
                </div>
                <!-- Focus marks -->
                <div class="absolute top-2 left-2 w-4 h-4 border-t-4 border-l-4 border-black"></div>
                <div class="absolute top-2 right-2 w-4 h-4 border-t-4 border-r-4 border-black"></div>
                <div class="absolute bottom-2 left-2 w-4 h-4 border-b-4 border-l-4 border-black"></div>
                <!-- Center Logo -->
                <div class="absolute inset-0 flex items-center justify-center">
                    <div class="w-8 h-8 bg-white border-2 border-slate-200 rounded-full flex items-center justify-center">
                        <span class="material-symbols-outlined text-blue-500" style="font-size: 16px;">@logoIcon</span>
                    </div>
                </div>
            </div>

            <p class="text-center text-slate-400 mb-8 max-w-xs mx-auto text-sm leading-relaxed">
                Open the <strong>@providerName</strong> app on your phone and scan the QR Code to complete the payment.
            </p>

            <form asp-action="ConfirmExternalCheckout" method="post" class="mt-4">
                <button type="submit" class="w-full py-4 bg-blue-500 hover:bg-blue-600 text-white rounded-xl font-bold transition-all shadow-lg shadow-blue-500/20 flex flex-col items-center justify-center gap-1 group">
                    <span class="flex items-center gap-2">
                        <span class="material-symbols-outlined group-hover:scale-110 transition-transform">check_circle</span>
                        Simulate Successful Payment
                    </span>
                    <span class="text-xs font-normal text-blue-200 opacity-70">(Demo only - for testing purposes)</span>
                </button>
            </form>
            
            <a asp-action="Details" asp-route-id="@ViewBag.UserId" class="block text-center mt-4 text-slate-400 hover:text-white transition-colors text-sm">
                Back, select another method
            </a>
        </div>
    </div>

</body>
</html>
