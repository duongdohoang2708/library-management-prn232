@model List<LibraryManagementDAL.Models.BorrowDetail>
@{
    ViewData["Title"] = "My Fines";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    var totalFine = Model.Sum(f => (f.FineAmount ?? 0) - (f.FinePaidAmount ?? 0));
}

<div class="flex-1 p-8 min-w-0 overflow-y-auto custom-scrollbar bg-[#0A0F1E]">
    <div class="max-w-5xl mx-auto">
        
        <!-- Header -->
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-12">
            <div>
                <h1 class="text-4xl font-black text-white mb-2">My Fines</h1>
                <p class="text-white/40 font-medium">Manage and pay your outstanding library charges.</p>
            </div>
            
            <div class="p-6 rounded-[2rem] bg-rose-500/10 border border-rose-500/20 backdrop-blur-xl flex items-center gap-6">
                <div class="w-12 h-12 rounded-2xl bg-rose-500/20 flex items-center justify-center text-rose-500">
                    <span class="material-symbols-outlined text-3xl">payments</span>
                </div>
                <div>
                    <p class="text-[10px] font-black text-rose-500/60 uppercase tracking-widest mb-1">Total Outstanding</p>
                    <p class="text-2xl font-black text-white">@totalFine.ToString("N0") <span class="text-xs">VND</span></p>
                </div>
            </div>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="bg-white/5 border border-white/10 rounded-[2.5rem] overflow-hidden backdrop-blur-xl shadow-2xl">
                <form asp-action="Process" method="post" id="paymentForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="userId" value="@Model.First().BorrowTransaction.UserId" />
                    
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="border-b border-white/5 bg-white/[0.02]">
                                    <th class="px-8 py-6">
                                        <div class="flex items-center gap-3">
                                            <input type="checkbox" id="selectAll" class="w-5 h-5 rounded-lg bg-white/5 border-white/10 text-primary focus:ring-primary transition-all cursor-pointer" />
                                            <span class="text-[10px] font-black text-white/30 uppercase tracking-widest">Select</span>
                                        </div>
                                    </th>
                                    <th class="px-8 py-6 text-[10px] font-black text-white/30 uppercase tracking-widest">Book/Reason</th>
                                    <th class="px-8 py-6 text-[10px] font-black text-white/30 uppercase tracking-widest">Due Date</th>
                                    <th class="px-8 py-6 text-[10px] font-black text-white/30 uppercase tracking-widest">Amount</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-white/5">
                                @foreach (var fine in Model)
                                {
                                    var remaining = (fine.FineAmount ?? 0) - (fine.FinePaidAmount ?? 0);
                                    <tr class="hover:bg-white/[0.02] transition-colors group">
                                        <td class="px-8 py-7">
                                            <input type="checkbox" name="selectedFines" value="@fine.BorrowDetailId" data-amount="@remaining" class="fine-checkbox w-5 h-5 rounded-lg bg-white/5 border-white/10 text-primary focus:ring-primary transition-all cursor-pointer" />
                                        </td>
                                        <td class="px-8 py-7">
                                            <div class="flex items-center gap-4">
                                                @if (fine.BookCopy?.Book != null)
                                                {
                                                    <div class="w-10 h-14 rounded-lg overflow-hidden flex-shrink-0 border border-white/10 shadow-lg">
                                                        <img src="@BookImageHelper.Resolve(fine.BookCopy.Book.ImageUrl, fine.BookCopy.Book.Title)"
                                                             alt="@fine.BookCopy.Book.Title"
                                                             onerror="this.onerror=null;this.src='@BookImageHelper.Placeholder';"
                                                             class="w-full h-full object-cover" />
                                                    </div>
                                                    <div>
                                                        <p class="text-white font-bold mb-0.5 group-hover:text-primary transition-colors">@fine.BookCopy.Book.Title</p>
                                                        <p class="text-[10px] text-white/30 font-bold uppercase tracking-widest">Barcode: @fine.BookCopy.Barcode</p>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary border border-primary/20">
                                                        <span class="material-symbols-outlined">warning</span>
                                                    </div>
                                                    <div>
                                                        <p class="text-white font-bold mb-0.5">Manual Charge</p>
                                                        <p class="text-[10px] text-white/30 font-bold uppercase tracking-widest">Check with librarian</p>
                                                    </div>
                                                }
                                            </div>
                                        </td>
                                        <td class="px-8 py-7">
                                            <p class="text-white/60 font-bold">@fine.DueDate.ToString("MMM dd, yyyy")</p>
                                        </td>
                                        <td class="px-8 py-7">
                                            <p class="text-rose-400 font-black">@remaining.ToString("N0") <span class="text-[10px]">VND</span></p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Payment Actions -->
                    <div class="p-8 bg-white/[0.02] border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-8">
                        <div class="flex items-center gap-4">
                            <span class="text-sm font-bold text-white/40">Amount to pay:</span>
                            <span id="selectedAmountDisplay" class="text-3xl font-black text-white">0 <span class="text-sm">VND</span></span>
                            <input type="hidden" name="amount" id="amountInput" value="0" />
                        </div>

                        <div class="flex items-center gap-4 w-full md:w-auto">
                            <select name="method" class="flex-1 md:w-48 px-4 py-4 rounded-2xl bg-white/5 border border-white/10 text-white text-sm font-bold focus:border-primary focus:ring-1 focus:ring-primary outline-none cursor-pointer">
                                <option value="VnPay">VNPAY Online</option>
                            </select>
                            <button type="submit" id="payButton" disabled 
                                    class="flex-1 md:px-10 py-4 bg-primary text-background-dark font-black rounded-2xl shadow-xl shadow-primary/20 hover:scale-105 active:scale-95 transition-all disabled:opacity-30 disabled:hover:scale-100 disabled:cursor-not-allowed">
                                Pay Selected
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        }
        else
        {
            <div class="p-20 rounded-[3rem] border-2 border-dashed border-white/5 flex flex-col items-center justify-center text-center bg-white/[0.01]">
                <div class="w-20 h-20 rounded-full bg-emerald-500/10 flex items-center justify-center text-emerald-500 mb-8 border border-emerald-500/20">
                    <span class="material-symbols-outlined text-4xl">check_circle</span>
                </div>
                <h2 class="text-2xl font-black text-white mb-3">All Settled!</h2>
                <p class="text-white/30 max-w-xs leading-relaxed">Great job! You have no outstanding fines or charges on your account.</p>
                <a href="/Books/ViewBooks" class="mt-10 px-8 py-3 bg-white/5 text-white font-bold rounded-xl border border-white/10 hover:bg-white/10 transition-all">Explore more books</a>
            </div>
        }
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const selectAll = document.getElementById("selectAll");
        const checkboxes = document.querySelectorAll(".fine-checkbox");
        const amountDisplay = document.getElementById("selectedAmountDisplay");
        const amountInput = document.getElementById("amountInput");
        const payButton = document.getElementById("payButton");

        function updateSummary() {
            let total = 0;
            let count = 0;
            checkboxes.forEach(cb => {
                if (cb.checked) {
                    total += parseFloat(cb.dataset.amount);
                    count++;
                }
            });

            amountDisplay.innerHTML = `${total.toLocaleString()} <span class="text-sm">VND</span>`;
            amountInput.value = total;
            payButton.disabled = count === 0;
        }

        if(selectAll) {
            selectAll.addEventListener("change", function() {
                checkboxes.forEach(cb => {
                    cb.checked = selectAll.checked;
                });
                updateSummary();
            });
        }

        checkboxes.forEach(cb => {
            cb.addEventListener("change", function() {
                updateSummary();
                // Update selectAll state
                if(selectAll) {
                    selectAll.checked = [...checkboxes].every(c => c.checked);
                    selectAll.indeterminate = [...checkboxes].some(c => c.checked) && ![...checkboxes].every(c => c.checked);
                }
            });
        });
    });
</script>
