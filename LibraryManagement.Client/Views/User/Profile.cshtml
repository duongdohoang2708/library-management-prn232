@model LibraryManagementDAL.DTO.User.UserProfileDto
@{
    ViewData["Title"] = "Profile";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    var isAdmin = User.IsInRole("Admin");
}

<div class="p-6 lg:p-10 max-w-5xl mx-auto">
    <!-- Header Section -->
    <div class="mb-10 flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <div>
            <h1 class="text-4xl font-black text-slate-900 dark:text-white mb-2 tracking-tight">Account Settings</h1>
            <p class="text-slate-500 dark:text-slate-400 font-medium">
                Manage your profile information and account security.
            </p>
        </div>

        <div class="flex gap-3">
            <a asp-action="ChangePassword"
               class="px-5 py-2.5 rounded-xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-200 font-bold hover:bg-slate-50 dark:hover:bg-slate-700 transition flex items-center gap-2 shadow-sm">
                <span class="material-symbols-outlined text-lg">lock</span>
                Change Password
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-8 p-4 bg-emerald-50 dark:bg-emerald-500/10 border border-emerald-200 dark:border-emerald-500/20 rounded-2xl text-emerald-700 dark:text-emerald-400 flex items-center gap-3 animate-in fade-in slide-in-from-top-4">
            <span class="material-symbols-outlined">check_circle</span>
            <span class="font-bold">@TempData["SuccessMessage"]</span>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="mb-8 p-4 bg-rose-50 dark:bg-rose-500/10 border border-rose-200 dark:border-rose-500/20 rounded-2xl text-rose-700 dark:text-rose-400 flex items-center gap-3 animate-in fade-in slide-in-from-top-4">
            <span class="material-symbols-outlined">error</span>
            <span class="font-bold">@TempData["ErrorMessage"]</span>
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Profile Card -->
        <div class="lg:col-span-1">
            <div class="bg-white dark:bg-slate-800 rounded-3xl p-8 border border-slate-200 dark:border-white/5 shadow-xl shadow-slate-200/50 dark:shadow-none sticky top-10">
                <div class="flex flex-col items-center">
                    <div class="relative group">
                        <div class="w-32 h-32 rounded-full bg-gradient-to-br from-primary to-teal-500 p-1 shadow-2xl shadow-primary/20">
                            <div class="w-full h-full rounded-full bg-white dark:bg-slate-900 flex items-center justify-center overflow-hidden">
                                <span class="material-symbols-outlined text-6xl text-slate-300">person</span>
                            </div>
                        </div>
                    </div>

                    <h2 class="mt-6 text-2xl font-black text-slate-900 dark:text-white">@Model.FullName</h2>
                    <p class="text-primary font-bold">@(isAdmin ? "Administrator" : "Member")</p>

                    <div class="w-full mt-8 pt-8 border-t border-slate-100 dark:border-slate-700 space-y-4">
                        <div class="flex items-center gap-3 text-slate-500 dark:text-slate-400">
                            <span class="material-symbols-outlined text-lg">mail</span>
                            <span class="text-sm font-medium">@Model.Email</span>
                        </div>
                        <div class="flex items-center gap-3 text-slate-500 dark:text-slate-400">
                            <span class="material-symbols-outlined text-lg">phone</span>
                            <span class="text-sm font-medium">@(string.IsNullOrWhiteSpace(Model.Phone) ? "Not updated" : Model.Phone)</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Panel -->
        <div class="lg:col-span-2">
            <div class="bg-white dark:bg-slate-800 rounded-3xl p-8 lg:p-10 border border-slate-200 dark:border-white/5 shadow-xl shadow-slate-200/50 dark:shadow-none">
                @if (isAdmin)
                {
                    <h3 class="text-xl font-black text-slate-900 dark:text-white mb-8 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">visibility</span>
                        Profile Information
                    </h3>

                    <div class="mb-6 p-4 bg-amber-50 dark:bg-amber-500/10 border border-amber-200 dark:border-amber-500/20 rounded-2xl text-amber-700 dark:text-amber-400 flex items-center gap-3">
                        <span class="material-symbols-outlined">info</span>
                        <span class="font-semibold">Administrators can only view profile information.</span>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Full Name</label>
                            <div class="w-full px-5 py-4 rounded-2xl bg-slate-100 dark:bg-slate-900/60 border border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white font-medium">
                                @(string.IsNullOrWhiteSpace(Model.FullName) ? "Not updated" : Model.FullName)
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Phone Number</label>
                            <div class="w-full px-5 py-4 rounded-2xl bg-slate-100 dark:bg-slate-900/60 border border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white font-medium">
                                @(string.IsNullOrWhiteSpace(Model.Phone) ? "Not updated" : Model.Phone)
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Address</label>
                            <div class="w-full px-5 py-4 rounded-2xl bg-slate-100 dark:bg-slate-900/60 border border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white font-medium">
                                @(string.IsNullOrWhiteSpace(Model.Address) ? "Not updated" : Model.Address)
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Date of Birth</label>
                            <div class="w-full px-5 py-4 rounded-2xl bg-slate-100 dark:bg-slate-900/60 border border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white font-medium">
                                @(Model.DateOfBirth.HasValue? Model.DateOfBirth.Value.ToString("dd/MM/yyyy") : "Not updated")
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <h3 class="text-xl font-black text-slate-900 dark:text-white mb-8 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">edit_note</span>
                        Personal Information
                    </h3>

                    <form asp-action="UpdateProfile" method="post" class="space-y-6">
                        @Html.AntiForgeryToken()

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="space-y-2">
                                <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Full Name</label>
                                <input name="FullName"
                                       value="@Model.FullName"
                                       type="text"
                                       class="w-full px-5 py-4 rounded-2xl bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white font-medium focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all"
                                       required />
                            </div>

                            <div class="space-y-2">
                                <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Phone Number</label>
                                <input name="Phone"
                                       value="@Model.Phone"
                                       type="tel"
                                       class="w-full px-5 py-4 rounded-2xl bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white font-medium focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" />
                            </div>

                            <div class="space-y-2">
                                <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Address</label>
                                <input name="Address"
                                       value="@Model.Address"
                                       type="text"
                                       class="w-full px-5 py-4 rounded-2xl bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white font-medium focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" />
                            </div>

                            <div class="space-y-2">
                                <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Date of Birth</label>
                                <input name="DateOfBirth"
                                       value="@(Model.DateOfBirth?.ToString("yyyy-MM-dd"))"
                                       type="date"
                                       class="w-full px-5 py-4 rounded-2xl bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white font-medium focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" />
                            </div>
                        </div>

                        <div class="pt-6">
                            <button type="submit"
                                    class="w-full md:w-auto px-10 py-4 bg-primary text-background-dark font-black rounded-2xl hover:bg-primary-hover shadow-lg shadow-primary/20 transition-all active:scale-[0.98] flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined">save</span>
                                Save Changes
                            </button>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .teal-gradient {
        background: radial-gradient(circle at top right, rgba(13, 148, 136, 0.05), transparent 400px), radial-gradient(circle at bottom left, rgba(13, 148, 136, 0.03), transparent 400px);
    }
</style>