@model IEnumerable<LibraryManagementDAL.DTO.Circulation.CirculationTransactionItem>
@{
    ViewData["Title"] = "Borrow History";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    var transactions = Model?.ToList() ?? new List<LibraryManagementDAL.DTO.Circulation.CirculationTransactionItem>();
}

<div class="p-8">
    <div class="max-w-6xl mx-auto">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="mb-6 px-5 py-4 rounded-2xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 flex items-center gap-3">
                <span class="material-symbols-outlined">check_circle</span>
                <span class="font-bold">@TempData["SuccessMessage"]</span>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="mb-6 px-5 py-4 rounded-2xl bg-rose-500/10 border border-rose-500/20 text-rose-400 flex items-center gap-3">
                <span class="material-symbols-outlined">error</span>
                <span class="font-bold">@TempData["ErrorMessage"]</span>
            </div>
        }

        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10">
            <div>
                <h2 class="text-4xl font-black text-white mb-2 tracking-tight">Borrow History</h2>
                <p class="text-white/40 font-medium">Track the books you have borrowed and their return status.</p>
            </div>

            <div class="flex items-center gap-4 bg-white/5 border border-white/10 rounded-2xl p-2 backdrop-blur-md">
                <div class="flex flex-col px-4 border-r border-white/10">
                    <span class="text-[10px] text-white/30 font-black uppercase tracking-widest">Transactions</span>
                    <span class="text-xl font-black text-primary">@transactions.Count</span>
                </div>
                <div class="flex flex-col px-4">
                    <span class="text-[10px] text-white/30 font-black uppercase tracking-widest">Currently Borrowing</span>
                    <span class="text-xl font-black text-emerald-400">@transactions.Count(t => t.Status == "Borrowing" || t.Status == "Overdue")</span>
                </div>
            </div>
        </div>

        <div class="space-y-6">
            @if (!transactions.Any())
            {
                <div class="bg-white/5 border border-white/10 rounded-3xl p-20 text-center">
                    <div class="w-20 h-20 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-6">
                        <span class="material-symbols-outlined text-4xl text-white/20">history_edu</span>
                    </div>
                    <h3 class="text-xl font-bold text-white mb-2">No Borrow History</h3>
                    <p class="text-white/40 mb-8 max-w-sm mx-auto">You have not made any borrowing transactions in our system.</p>
                    <a asp-action="ViewBooks" asp-controller="Books" class="inline-flex items-center gap-2 px-8 py-3 bg-primary text-background-dark font-black rounded-xl hover:bg-primary-hover transition-all">
                        <span class="material-symbols-outlined">explore</span>
                        Explore Library
                    </a>
                </div>
            }
            else
            {
                foreach (var transaction in transactions)
                {
                    var statusClass = transaction.Status switch
                    {
                        "Borrowing" => "bg-emerald-500/10 text-emerald-400 border-emerald-500/20",
                        "Returned" => "bg-blue-500/10 text-blue-400 border-blue-500/20",
                        "Overdue" => "bg-rose-500/10 text-rose-400 border-rose-500/20",
                        _ => "bg-white/10 text-white/40 border-white/10"
                    };

                    <div class="bg-white/5 border border-white/10 rounded-3xl overflow-hidden hover:border-white/20 transition-all group">
                        <div class="p-6 border-b border-white/5 flex flex-wrap items-center justify-between gap-4 bg-gradient-to-r from-white/5 to-transparent">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-2xl bg-primary/10 border border-primary/20 flex items-center justify-center text-primary">
                                    <span class="material-symbols-outlined">receipt_long</span>
                                </div>
                                <div>
                                    <div class="text-[10px] text-white/30 font-black uppercase tracking-widest mb-0.5">Transaction ID</div>
                                    <div class="font-bold text-white">#@transaction.BorrowTransactionId.ToString().PadLeft(5, '0')</div>
                                </div>
                            </div>

                            <div class="flex items-center gap-8">
                                <div>
                                    <div class="text-[10px] text-white/30 font-black uppercase tracking-widest mb-0.5 text-right">Borrow Date</div>
                                    <div class="font-bold text-white/80">@transaction.BorrowDate.ToString("dd/MM/yyyy")</div>
                                </div>
                                <div>
                                    <div class="text-[10px] text-white/30 font-black uppercase tracking-widest mb-0.5 text-right">Due Date</div>
                                    <div class="font-bold @(transaction.Status == "Overdue" ? "text-rose-400" : "text-white/80")">@transaction.DueDate.ToString("dd/MM/yyyy")</div>
                                </div>
                                <div>
                                    <span class="px-3 py-1.5 rounded-lg border text-[10px] font-black uppercase tracking-wider @statusClass">
                                        @transaction.Status
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="p-6">
                            <div class="space-y-4">
                                @foreach (var detail in transaction.BorrowDetails)
                                {
                                    @await Html.PartialAsync("_BorrowDetailCard", detail)
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<div id="renewalRequestModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70 p-4">
    <div class="w-full max-w-md bg-[#0b1220] border border-white/10 rounded-2xl shadow-2xl p-6">
        <div class="flex items-start justify-between gap-4 mb-5">
            <div>
                <h3 class="text-xl font-bold text-white mb-1">Renewal Request</h3>
                <p id="renewalModalBookTitle" class="text-sm text-white/50"></p>
            </div>
            <button type="button" onclick="closeRenewalRequestModal()" class="text-white/40 hover:text-white transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <div class="space-y-3 text-sm">
            <div class="flex justify-between gap-4 p-3 rounded-xl bg-white/5 border border-white/5">
                <span class="text-white/40">Status</span>
                <span id="renewalModalStatus" class="font-bold text-white text-right"></span>
            </div>
            <div class="flex justify-between gap-4 p-3 rounded-xl bg-white/5 border border-white/5">
                <span class="text-white/40">Requested</span>
                <span id="renewalModalRequestedAt" class="font-bold text-white/80 text-right"></span>
            </div>
            <div class="flex justify-between gap-4 p-3 rounded-xl bg-white/5 border border-white/5">
                <span class="text-white/40">Due date at request</span>
                <span id="renewalModalCurrentDue" class="font-bold text-white/80 text-right"></span>
            </div>
            <div id="renewalModalNewDueRow" class="hidden flex justify-between gap-4 p-3 rounded-xl bg-emerald-500/5 border border-emerald-500/10">
                <span class="text-emerald-400/70">New due date</span>
                <span id="renewalModalNewDue" class="font-bold text-emerald-400 text-right"></span>
            </div>
            <div id="renewalModalReviewedRow" class="hidden flex justify-between gap-4 p-3 rounded-xl bg-white/5 border border-white/5">
                <span class="text-white/40">Reviewed</span>
                <span id="renewalModalReviewedAt" class="font-bold text-white/80 text-right"></span>
            </div>
            <div id="renewalModalReasonRow" class="hidden p-3 rounded-xl bg-rose-500/5 border border-rose-500/10">
                <p class="text-[10px] text-rose-400/60 font-black uppercase tracking-widest mb-1">Rejection reason</p>
                <p id="renewalModalReason" class="text-rose-300/90"></p>
            </div>
        </div>

        <form id="renewalCancelForm" method="post" class="hidden mt-6" onsubmit="return confirm('Cancel this renewal request?')">
            @Html.AntiForgeryToken()
            <button type="submit" class="w-full px-4 py-3 bg-white/5 hover:bg-rose-500/10 text-white/60 hover:text-rose-400 border border-white/10 hover:border-rose-500/20 rounded-xl font-bold text-sm transition-all flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-lg">close</span>
                Cancel Request
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openRenewalRequestModal(btn) {
            const statusRaw = btn.dataset.statusRaw;
            document.getElementById('renewalModalBookTitle').textContent = btn.dataset.bookTitle;
            document.getElementById('renewalModalStatus').textContent = btn.dataset.status;
            document.getElementById('renewalModalRequestedAt').textContent = btn.dataset.requestedAt;
            document.getElementById('renewalModalCurrentDue').textContent = btn.dataset.currentDue;

            const newDueRow = document.getElementById('renewalModalNewDueRow');
            if (btn.dataset.newDue) {
                newDueRow.classList.remove('hidden');
                document.getElementById('renewalModalNewDue').textContent = btn.dataset.newDue;
            } else {
                newDueRow.classList.add('hidden');
            }

            const reviewedRow = document.getElementById('renewalModalReviewedRow');
            if (btn.dataset.reviewedAt) {
                reviewedRow.classList.remove('hidden');
                document.getElementById('renewalModalReviewedAt').textContent = btn.dataset.reviewedAt;
            } else {
                reviewedRow.classList.add('hidden');
            }

            const reasonRow = document.getElementById('renewalModalReasonRow');
            if (btn.dataset.rejectionReason) {
                reasonRow.classList.remove('hidden');
                document.getElementById('renewalModalReason').textContent = btn.dataset.rejectionReason;
            } else {
                reasonRow.classList.add('hidden');
            }

            const cancelForm = document.getElementById('renewalCancelForm');
            if (statusRaw === 'Pending') {
                cancelForm.classList.remove('hidden');
                cancelForm.action = '/RenewalRequest/Cancel/' + btn.dataset.requestId;
            } else {
                cancelForm.classList.add('hidden');
            }

            const modal = document.getElementById('renewalRequestModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeRenewalRequestModal() {
            const modal = document.getElementById('renewalRequestModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }
    </script>
}
