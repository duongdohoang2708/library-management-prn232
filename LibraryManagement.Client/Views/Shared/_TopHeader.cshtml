@{
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var userName = User.FindFirst("Username")?.Value ?? User.Identity?.Name ?? "";
    var displayFullName = User.FindFirst("FullName")?.Value ?? userName;
    var userEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "";
    var displayName = !string.IsNullOrWhiteSpace(displayFullName) ? displayFullName : userEmail;
    var displayUsername = !string.IsNullOrWhiteSpace(userName) ? userName : userEmail;
    var userRoles = User.Claims
        .Where(c => c.Type == System.Security.Claims.ClaimTypes.Role)
        .Select(c => c.Value)
        .ToList();
    var primaryRole = userRoles.FirstOrDefault() ?? "Member";
    var roleBadgeClass = primaryRole == "Admin"
        ? "bg-primary/20 text-primary border-primary/30"
        : "bg-white/10 text-white/70 border-white/20";
    var avatarLetter = string.IsNullOrWhiteSpace(displayName)
        ? "?"
        : displayName.Substring(0, 1).ToUpperInvariant();
}

<header class="h-20 border-b border-white/10 flex items-center justify-between px-8 sticky top-0 bg-background-dark/80 backdrop-blur-md z-40">

    <!-- LOGO SECTION -->
    <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-3xl font-bold">library_books</span>
        <span class="text-primary font-black text-2xl tracking-tighter">LMS Standard</span>
    </div>

    <!-- RIGHT SIDE -->
    <div class="flex items-center gap-6 ml-8">

        @if (isAuthenticated)
        {
            <!-- Notification -->
            <div class="relative">
                <!-- Bell -->
                <button id="notificationButton"
                        class="relative p-2 text-white/60 hover:text-primary transition-colors">
                    <span class="material-symbols-outlined">notifications</span>
                    <!-- Badge -->
                    <span id="notificationBadge"
                            class="hidden absolute -top-1 -right-1 bg-primary text-xs text-white rounded-full px-1.5 py-0.5">
                        0
                    </span>
                </button>
                <!-- Dropdown -->
                <div id="notificationDropdown"
                        class="hidden absolute right-0 mt-3 w-80 bg-[#1e1e1e] rounded-xl shadow-lg border border-white/10 z-50 overflow-hidden">
                    <!-- Header -->
                    <div class="p-3 border-b border-white/10 text-sm font-semibold text-white flex justify-between items-center bg-white/5">
                        <span>Notifications</span>
                        <button onclick="markAllNotificationsAsRead(event)" class="text-xs text-primary hover:underline font-bold">Mark all read</button>
                    </div>
                    <!-- Notification List -->
                    <div id="notificationList" class="max-h-60 overflow-y-auto">
                        <div class="p-4 text-center text-sm text-white/40">Loading...</div>
                    </div>
                    <div class="p-2 border-t border-white/10 text-center bg-white/5">
                        <a href="/Notification" class="text-xs text-primary hover:underline font-bold">View all notifications</a>
                    </div>
                </div>
            </div>
        }

        @if (isAuthenticated && User.IsInRole("Member"))
        {
            <!-- My Reading List Icon -->
            <a href="/UserAction/BorrowCart" class="relative p-2 text-white/60 hover:text-primary transition-colors" title="My Reading List">
                <span class="material-symbols-outlined">bookmarks</span>
                <span class="cart-badge hidden absolute -top-1 -right-1 bg-primary text-xs text-white font-black rounded-full px-1.5 py-0.5 min-w-[18px] text-center leading-tight">0</span>
            </a>
        }

        @if (isAuthenticated)
        {
            <!-- USER INFO WITH DROPDOWN -->
            <div class="relative">
                <div id="userMenuButton" class="flex items-center gap-3 px-4 py-2 bg-white/5 border border-white/10 rounded-xl hover:bg-white/8 hover:border-primary/30 transition-all cursor-pointer relative z-50">
                    <div>
                        <div class="text-sm font-semibold text-white leading-tight">@displayName</div>
                        <div class="flex items-center gap-1 mt-0.5">
                            <span class="px-1.5 py-0.5 rounded-md border text-[10px] font-bold @roleBadgeClass">
                                @primaryRole
                            </span>
                        </div>
                    </div>
                    <span id="userMenuChevron" class="material-symbols-outlined text-white/20 transition-transform text-lg">expand_more</span>
                </div>

                <!-- Dropdown Content -->
                <div id="userMenuDropdown" class="hidden absolute right-0 top-full mt-2 w-80 bg-[#1a1c1e] border border-white/10 rounded-2xl shadow-2xl z-50 overflow-hidden animate-in fade-in slide-in-from-top-2 duration-200">
                    <!-- User details header -->
                    <div class="p-6 bg-white/5 border-b border-white/10">
                        <div class="flex flex-col items-center text-center">
                            <div class="relative mb-3">
                                <div class="w-20 h-20 rounded-full bg-primary/20 border-2 border-primary/30 flex items-center justify-center text-primary text-3xl font-black shadow-lg">
                                    @avatarLetter
                                </div>
                                <div class="absolute bottom-0 right-0 w-5 h-5 bg-emerald-500 border-4 border-[#1a1c1e] rounded-full" title="Active now"></div>
                            </div>
                            <div class="text-white font-bold text-xl mb-0.5">@displayFullName</div>
                            <div class="text-primary/80 text-sm font-medium mb-1 tracking-tight italic">@@@displayUsername</div>
                            <div class="text-white/40 text-xs mb-4">@userEmail</div>
                            
                            <div class="flex flex-wrap justify-center gap-1.5 mb-2">
                                @foreach (var role in userRoles)
                                {
                                    <span class="px-2.5 py-1 bg-primary text-background-dark rounded-md text-[10px] font-black uppercase tracking-wider">
                                        @role
                                    </span>
                                }
                            </div>
                            
                            <a href="/User/Profile" class="mt-4 px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-xs font-bold rounded-lg transition-all flex items-center gap-2">
                                <span class="material-symbols-outlined text-sm">person</span>
                                Edit Profile
                            </a>
                        </div>
                    </div>

                    <!-- Detailed Info Body -->
                    <div class="p-4 bg-black/20">
                        <a href="/User/Profile" class="flex items-center gap-3 p-3 rounded-xl bg-white/5 hover:bg-white/10 transition-all">
                            <span class="material-symbols-outlined text-primary text-lg">manage_accounts</span>
                            <div class="flex-1">
                                <div class="text-[10px] text-white/30 uppercase font-bold tracking-widest">Personal Information</div>
                                <div class="text-sm text-white/80">View and update your profile details</div>
                            </div>
                        </a>
                    </div>
                    
                    <!-- Simplified Actions -->
                    <div class="p-2 border-t border-white/5">
                        <a href="/Auth/ChangePassword" class="w-full flex items-center justify-center gap-3 p-3 text-sm font-bold text-white/70 hover:text-white hover:bg-white/5 rounded-xl transition-all mb-1">
                            <span class="material-symbols-outlined text-lg">password</span>
                            <span>Change Password</span>
                        </a>
                        <form asp-controller="Auth" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="w-full flex items-center justify-center gap-3 p-3 text-sm font-bold text-red-400 hover:bg-red-500/10 rounded-xl transition-all group/logout">
                                <span class="material-symbols-outlined text-lg group-hover:rotate-12 transition-transform">logout</span>
                                <span>Sign Out</span>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
        else
        {
            <!-- LOGIN -->
            <a href="/Auth/Login"
                class="bg-primary hover:bg-primary/90 text-background-dark px-5 py-2 rounded-lg font-bold text-sm flex items-center gap-2 transition-all active:scale-95">
                <span class="material-symbols-outlined text-lg">login</span>
                Login
            </a>

            <!-- REGISTER -->
            <a href="/Auth/Register"
                class="border border-white/20 text-white/70 hover:text-white hover:border-white/40 px-5 py-2 rounded-lg font-semibold text-sm flex items-center gap-2 transition-all active:scale-95">
                Register
            </a>
        }
    </div>

</header>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Update cart badge from localStorage
        try {
            const cart = JSON.parse(localStorage.getItem("lms_borrow_cart")) || [];
            document.querySelectorAll(".cart-badge").forEach(el => {
                el.textContent = cart.length;
                el.classList.toggle("hidden", cart.length === 0);
            });
        } catch (e) {}

        const btn = document.getElementById("notificationButton");
        const dropdown = document.getElementById("notificationDropdown");
        const badge = document.getElementById("notificationBadge");

        if (btn) {
            // Load notifications initially
            loadNotifications();

            btn.addEventListener("click", () => {
                dropdown.classList.toggle("hidden");
            });
        }

        const userBtn = document.getElementById("userMenuButton");
        const userDropdown = document.getElementById("userMenuDropdown");
        const userChevron = document.getElementById("userMenuChevron");

        if (userBtn && userDropdown) {
            userBtn.addEventListener("click", (e) => {
                e.stopPropagation();
                const isHidden = userDropdown.classList.contains("hidden");
                
                if (dropdown && !dropdown.classList.contains("hidden")) {
                    dropdown.classList.add("hidden");
                }

                if (isHidden) {
                    userDropdown.classList.remove("hidden");
                    userChevron.classList.add("rotate-180");
                } else {
                    userDropdown.classList.add("hidden");
                    userChevron.classList.remove("rotate-180");
                }
            });

            document.addEventListener("click", (e) => {
                if (!userDropdown.contains(e.target) && !userBtn.contains(e.target)) {
                    userDropdown.classList.add("hidden");
                    userChevron.classList.remove("rotate-180");
                }
                if (dropdown && !dropdown.contains(e.target) && !btn.contains(e.target)) {
                    dropdown.classList.add("hidden");
                }
            });
        }
    });

    async function loadNotifications() {
        try {
            const res = await fetch('/Notification/GetLatestNotifications');
            if (!res.ok) return;
            const data = await res.json();
            
            const badge = document.getElementById("notificationBadge");
            if (badge) {
                if (data.unreadCount > 0) {
                    badge.innerText = data.unreadCount;
                    badge.classList.remove("hidden");
                } else {
                    badge.classList.add("hidden");
                }
            }

            const list = document.getElementById("notificationList");
            if (list) {
                list.innerHTML = "";
                if (!data.items || data.items.length === 0) {
                    list.innerHTML = `<div class="p-4 text-center text-sm text-white/40">No notifications</div>`;
                    return;
                }

                data.items.forEach(n => {
                    const item = document.createElement("div");
                    item.className = `p-3 border-b border-white/10 transition-all cursor-pointer ${n.isRead ? 'hover:bg-white/5 text-white/70' : 'bg-primary/10 text-white font-semibold'}`;
                    
                    const date = new Date(n.createdAt);
                    const formattedDate = date.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) + ' ' + date.toLocaleDateString([], {day: '2-digit', month: '2-digit'});

                    item.innerHTML = `
                        <div class="flex flex-col gap-1">
                            <span class="text-sm">${escapeHtml(n.message)}</span>
                            <span class="text-xs text-white/40">${formattedDate}</span>
                        </div>
                    `;

                    item.onclick = async (e) => {
                        e.stopPropagation();
                        if (!n.isRead) {
                            await markNotificationAsRead(n.notificationId);
                        }
                    };
                    list.appendChild(item);
                });
            }
        } catch (err) {
            console.error("Error loading notifications:", err);
        }
    }

    async function markNotificationAsRead(id) {
        try {
            const res = await fetch(`/Notification/MarkAsRead?id=${id}`, { method: 'POST' });
            if (res.ok) {
                await loadNotifications();
            }
        } catch (err) {
            console.error(err);
        }
    }

    async function markAllNotificationsAsRead(e) {
        if (e) e.stopPropagation();
        try {
            const res = await fetch('/Notification/MarkAllAsReadJson', { method: 'POST' });
            if (res.ok) {
                await loadNotifications();
            }
        } catch (err) {
            console.error(err);
        }
    }

    function escapeHtml(str) {
        return str
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }
</script>
