@model List<LibraryManagementDAL.Models.Notification>

<div id="notificationList" class="max-h-80 overflow-y-auto">

    @if (Model == null || !Model.Any())
    {
        <div class="p-4 text-sm text-white/40 text-center">
            No notifications
        </div>
    }
    else
    {
        @foreach (var n in Model)
        {
            <div class="p-3 border-b border-white/10 transition-all cursor-pointer
                 @(n.IsRead ? "hover:bg-white/5 text-white/70" : "bg-primary/10 text-white")"
                 onclick="markAsRead(@n.NotificationId, this)">

                <div class="flex flex-col gap-1">

                    <div class="flex items-center justify-between">

                        <span class="text-sm @(n.IsRead ? "" : "font-semibold")">
                            @n.Message
                        </span>

                        @if (!n.IsRead)
                        {
                            <span class="text-[10px] bg-primary text-black px-2 py-0.5 rounded-full badge">
                                NEW
                            </span>
                        }

                    </div>

                    <span class="text-xs text-white/40">
                        @n.CreatedAt.ToLocalTime().ToString("HH:mm dd/MM")
                    </span>

                </div>
            </div>
        }
    }
</div>
<script>
function markAsRead(id, element) {
    fetch('/Notification/MarkAsRead?id=' + id, {
        method: 'POST'
    })
    .then(res => {
        if (res.ok) {

            // đổi UI ngay lập tức
            element.classList.remove('bg-primary/10');
            element.classList.add('hover:bg-white/5', 'text-white/70');

            // remove badge NEW
            const badge = element.querySelector('.badge');
            if (badge) badge.remove();

        }
    });
}
</script>