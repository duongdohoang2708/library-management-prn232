@{
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var userName = User.Identity?.Name ?? "";
    var initials = string.IsNullOrEmpty(userName) ? "?" :
                   userName.Contains("@") ? userName[0].ToString().ToUpper() :
                   string.Join("", userName.Split(' ').Take(2).Select(w => w[0])).ToUpper();
    var userRoles = User.Claims.Where(c => c.Type == System.Security.Claims.ClaimTypes.Role).Select(c => c.Value).ToList();
    var primaryRole = userRoles.FirstOrDefault() ?? "Staff";
    var isAdminOrManager = userRoles.Any(r => r == "Admin" || r == "Manager");
    var isLibrarian = userRoles.Any(r => r == "Librarian");
    var homeAction = isAdminOrManager ? "AdminDashboard" : (isLibrarian ? "Dashboard" : "Index");

    // Active controller helpers
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    string nav(string c) => controller == c ? "p-3 bg-primary text-background-dark rounded-xl shadow-lg shadow-primary/20" : "p-3 text-white/60 hover:text-primary hover:bg-white/5 rounded-xl transition-all";
    string navAction(string c, string a) => controller == c && action == a ? "p-3 bg-primary text-background-dark rounded-xl shadow-lg shadow-primary/20" : "p-3 text-white/60 hover:text-primary hover:bg-white/5 rounded-xl transition-all";
}

<aside class="fixed left-0 top-0 h-full w-20 flex flex-col items-center py-8 border-r border-white/10 bg-black/20 backdrop-blur-xl z-50 justify-between">

    <!-- Top: Logo -->
    <div>
        <a asp-controller="Home" asp-action="@homeAction" class="block mb-8 text-primary" title="Admin Dashboard">
            <span class="material-symbols-outlined text-4xl font-bold">admin_panel_settings</span>
        </a>

        <!-- Nav icons -->
        <nav class="flex flex-col gap-3">
            @if (isAdminOrManager)
            {
                <!-- Dashboard (Admin / Manager) -->
                <a asp-controller="Home" asp-action="AdminDashboard"
                   class="@navAction("Home", "AdminDashboard") relative group"
                   title="System Statistics">
                    <span class="material-symbols-outlined">dashboard</span>
                    <span class="absolute left-full ml-3 px-2.5 py-1.5 bg-black/90 text-white text-xs rounded-lg font-medium
                                 whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-all duration-200 border border-white/10
                                 shadow-xl translate-x-1 group-hover:translate-x-0">
                        System Statistics
                    </span>
                </a>
            }
            else if (isLibrarian)
            {
                <!-- Dashboard (Librarian Specific) -->
                <a asp-controller="Home" asp-action="Dashboard"
                   class="@navAction("Home", "Dashboard") relative group"
                   title="Overview">
                    <span class="material-symbols-outlined">dashboard</span>
                    <span class="absolute left-full ml-3 px-2.5 py-1.5 bg-black/90 text-white text-xs rounded-lg font-medium
                                 whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-all duration-200 border border-white/10
                                 shadow-xl translate-x-1 group-hover:translate-x-0">
                        Overview
                    </span>
                </a>
            }

            @if (isLibrarian)
            {
                <!-- Manage Books List (Đầu sách) -->
                <a asp-controller="Books" asp-action="AllBooks"
                   class="@nav("Books") relative group"
                   title="Manage Books List">
                    <span class="material-symbols-outlined">auto_stories</span>
                    <span class="absolute left-full ml-3 px-2.5 py-1.5 bg-black/90 text-white text-xs rounded-lg font-medium
                                 whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-all duration-200 border border-white/10
                                 shadow-xl translate-x-1 group-hover:translate-x-0">
                        Manage Books List
                    </span>
                </a>
                <a asp-controller="Catalog" asp-action="Index"
                   class="@nav("Catalog") relative group"
                   title="Catalog Data">
                    <span class="material-symbols-outlined">category</span>
                    <span class="absolute left-full ml-3 px-2.5 py-1.5 bg-black/90 text-white text-xs rounded-lg font-medium
                                 whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-all duration-200 border border-white/10
                                 shadow-xl translate-x-1 group-hover:translate-x-0">
                        Catalog Data
                    </span>
                </a>
                <!-- Inventory (Physical Books) -->
                <a asp-controller="Inventory" asp-action="Index"
                   class="@nav("Inventory") relative group"
                   title="Physical Inventory">
                    <span class="material-symbols-outlined">inventory_2</span>
                    <span class="absolute left-full ml-3 px-2.5 py-1.5 bg-black/90 text-white text-xs rounded-lg font-medium
                                 whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-all duration-200 border border-white/10
                                 shadow-xl translate-x-1 group-hover:translate-x-0">
                        Physical Inventory
                    </span>
                </a>

                <!-- Circulation -->
                <a asp-controller="Circulation" asp-action="Index"
                   class="@nav("Circulation") relative group"
                   title="Circulation">
                    <span class="material-symbols-outlined">compare_arrows</span>
                    <span class="absolute left-full ml-3 px-2.5 py-1.5 bg-black/90 text-white text-xs rounded-lg font-medium
                                 whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-all duration-200 border border-white/10
                                 shadow-xl translate-x-1 group-hover:translate-x-0">
                        Circulation
                    </span>
                </a>
                
                <!-- Payment -->
                <a asp-controller="Payment" asp-action="Index"
                   class="@nav("Payment") relative group"
                   title="Fees & Fines">
                    <span class="material-symbols-outlined">point_of_sale</span>
                    <span class="absolute left-full ml-3 px-2.5 py-1.5 bg-black/90 text-white text-xs rounded-lg font-medium
                                 whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-all duration-200 border border-white/10
                                 shadow-xl translate-x-1 group-hover:translate-x-0">
                        Fees & Fines
                    </span>
                </a>
            }


            @if (isLibrarian)
            {
                <!-- Notifications -->
                <a asp-controller="Notification" asp-action="Index"
                   class="@nav("Notification") relative group" title="Notifications">
                    <span class="material-symbols-outlined">notifications</span>
                    <span class="absolute left-full ml-3 px-2.5 py-1.5 bg-black/90 text-white text-xs rounded-lg font-medium
                             whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-all duration-200 border border-white/10
                             shadow-xl translate-x-1 group-hover:translate-x-0">
                        Notifications
                    </span>
                </a>
            }

            @if (isAdminOrManager)
            {
                <!-- Users Management -->
                <a asp-controller="User" asp-action="AllUsers"
                   class="@navAction("User", "AllUsers") relative group"
                   title="Readers & Users">
                    <span class="material-symbols-outlined">group</span>
                    <span class="absolute left-full ml-3 px-2.5 py-1.5 bg-black/90 text-white text-xs rounded-lg font-medium
                                 whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-all duration-200 border border-white/10
                                 shadow-xl translate-x-1 group-hover:translate-x-0">
                        Readers &amp; Users
                    </span>
                </a>

                <a asp-controller="Reports" asp-action="Index"
                   class="@nav("Reports") relative group"
                   title="Advanced Reports">
                    <span class="material-symbols-outlined">summarize</span>
                    <span class="absolute left-full ml-3 px-2.5 py-1.5 bg-black/90 text-white text-xs rounded-lg font-medium
                                 whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-all duration-200 border border-white/10
                                 shadow-xl translate-x-1 group-hover:translate-x-0">
                        Advanced Reports
                    </span>
                </a>

                <a asp-controller="Audit" asp-action="Index"
                   class="@nav("Audit") relative group"
                   title="Audit Logs">
                    <span class="material-symbols-outlined">manage_search</span>
                    <span class="absolute left-full ml-3 px-2.5 py-1.5 bg-black/90 text-white text-xs rounded-lg font-medium
                                 whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-all duration-200 border border-white/10
                                 shadow-xl translate-x-1 group-hover:translate-x-0">
                        Audit Logs
                    </span>
                </a>

                <a asp-controller="SystemSettings" asp-action="Index"
                   class="@nav("SystemSettings") relative group"
                   title="System Settings">
                    <span class="material-symbols-outlined">settings</span>
                    <span class="absolute left-full ml-3 px-2.5 py-1.5 bg-black/90 text-white text-xs rounded-lg font-medium
                                 whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-all duration-200 border border-white/10
                                 shadow-xl translate-x-1 group-hover:translate-x-0">
                        System Settings
                    </span>
                </a>
            }
        </nav>
    </div>

    <!-- Bottom: User avatar + logout -->
    <div class="flex flex-col items-center gap-3">
        @if (isAuthenticated)
        {
            <!-- Logout button -->
            <form asp-action="Logout" asp-controller="Auth" method="post">
                @Html.AntiForgeryToken()
                <button type="submit"
                        title="Logout"
                        class="p-3 text-white/40 hover:text-red-400 hover:bg-red-500/10 rounded-xl transition-all relative group">
                    <span class="material-symbols-outlined">logout</span>
                    <span class="absolute left-full ml-3 px-2.5 py-1.5 bg-black/90 text-red-300 text-xs rounded-lg font-medium
                                 whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-all duration-200 border border-red-500/20
                                 shadow-xl translate-x-1 group-hover:translate-x-0">
                        Logout
                    </span>
                </button>
            </form>

            <!-- Avatar with initials or role indicator -->
            <div class="relative group cursor-pointer">
                <div class="w-11 h-11 rounded-full border-2 border-primary overflow-hidden bg-primary/20 flex items-center justify-center transition-all group-hover:border-primary">
                    <span class="text-primary font-bold text-sm">@initials</span>
                </div>
                <!-- Admin star indicator -->
                <div class="absolute -top-1 -right-1 w-4 h-4 bg-primary rounded-full flex items-center justify-center border border-background-dark">
                    <span class="material-symbols-outlined text-background-dark" style="font-size:10px">star</span>
                </div>

                <!-- Hover tooltip -->
                <div class="absolute bottom-full left-full ml-3 mb-0 p-3 bg-black/95 rounded-xl border border-white/10 shadow-2xl
                            opacity-0 group-hover:opacity-100 pointer-events-none transition-all duration-200 translate-y-1 group-hover:translate-y-0
                            whitespace-nowrap min-w-max">
                    <p class="text-white text-xs font-semibold">@userName</p>
                    <div class="flex gap-1 mt-1.5 flex-wrap">
                        @foreach (var role in userRoles)
                        {
                            <span class="px-1.5 py-0.5 bg-primary/10 text-primary text-[10px] font-bold rounded-md border border-primary/20">@role</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</aside>
