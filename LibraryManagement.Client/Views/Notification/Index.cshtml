@using LibraryManagementDAL.DTO.Pagination
@model PaginationResponseModel<LibraryManagementDAL.Models.Notification>
@{
    ViewData["Title"] = "Notification";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";

    var notifications = Model?.Items ?? new List<LibraryManagementDAL.Models.Notification>();
    var currentPage = Model?.CurrentPage ?? 1;
    var totalPages = Model?.TotalPages ?? 1;
}

<div class="flex-1 flex overflow-hidden">
    <div class="flex-1 px-8 py-12 overflow-y-auto custom-scrollbar">
        <div class="max-w-5xl mx-auto pb-20">

            <div class="mb-10 flex items-start justify-between gap-4 flex-wrap">
                <div>
                    <h1 class="text-4xl font-bold font-display text-white mb-2">Notifications</h1>
                    <p class="text-white/60 text-sm">
                        View all your recent notifications and updates
                    </p>
                </div>

                @if (User.IsInRole("Librarian") || User.IsInRole("Manager") || User.IsInRole("Admin"))
                {
                    <a asp-action="SendNotification"
                       asp-controller="Notification"
                       class="px-5 py-3 rounded-xl bg-primary text-background-dark font-bold hover:shadow-xl hover:shadow-primary/30 transition-all text-sm uppercase tracking-wider flex items-center gap-2">
                        <span class="material-symbols-outlined text-lg">campaign</span>
                        Send Notification
                    </a>
                }
                else
                {
                    <form asp-action="MarkAllAsRead" asp-controller="Notification" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                class="px-5 py-3 rounded-xl bg-primary text-background-dark font-bold hover:shadow-xl hover:shadow-primary/30 transition-all text-sm uppercase tracking-wider">
                            Mark All as Read
                        </button>
                    </form>
                }
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="mb-6 rounded-xl border border-green-400/20 bg-green-400/10 px-4 py-3 text-green-300 text-sm">
                    @TempData["Success"]
                </div>
            }

            <div class="bg-white/5 p-8 rounded-2xl border border-white/10 shadow-2xl">
                <div class="flex items-center justify-between mb-8 flex-wrap gap-3">
                    <h2 class="text-white text-2xl font-bold">Your Notifications</h2>
                    <span class="text-white/40 text-sm">
                        Page @currentPage / @totalPages
                    </span>
                </div>

                @if (notifications.Any())
                {
                    <div class="flex flex-col gap-4">
                        @foreach (var item in notifications)
                        {
                            <div class="rounded-2xl border @(item.IsRead ? "border-white/10 bg-black/20" : "border-primary/30 bg-primary/10") p-5 transition-all hover:bg-white/5">
                                <div class="flex items-start justify-between gap-4">
                                    <div class="flex items-start gap-4">
                                        <div class="w-12 h-12 rounded-xl flex items-center justify-center @(item.IsRead ? "bg-white/10 text-white/60" : "bg-primary/20 text-primary")">
                                            <span class="material-symbols-outlined">notifications</span>
                                        </div>

                                        <div class="flex-1 min-w-0">
                                            <div class="flex items-center gap-2 flex-wrap">
                                                <h3 class="text-white font-bold text-lg">@item.Title</h3>

                                                @if (!(User.IsInRole("Librarian") || User.IsInRole("Manager") || User.IsInRole("Admin")) && !item.IsRead)
                                                {
                                                    <span class="px-2 py-1 text-[10px] rounded-full bg-primary text-background-dark font-bold uppercase tracking-wider">
                                                        New
                                                    </span>
                                                }

                                                @if (!string.IsNullOrWhiteSpace(item.Type))
                                                {
                                                    <span class="px-2 py-1 text-[10px] rounded-full bg-white/10 text-white/60 uppercase tracking-wider">
                                                        @item.Type
                                                    </span>
                                                }
                                            </div>

                                            <p class="text-white/70 text-sm mt-2 leading-6 break-words whitespace-normal">
                                                @item.Message
                                            </p>

                                            <div class="mt-3 flex flex-wrap gap-4 text-xs text-white/40">
                                                @if (item.SentAt != null)
                                                {
                                                    <span>Sent: @item.SentAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    <div class="shrink-0">
                                        @if (User.IsInRole("Librarian") || User.IsInRole("Manager") || User.IsInRole("Admin"))
                                        {
                                            <span class="text-xs text-blue-300 bg-blue-400/10 border border-blue-400/20 px-3 py-1 rounded-full">
                                                Sent
                                            </span>
                                        }
                                        else
                                        {
                                            @if (item.IsRead)
                                            {
                                                <span class="text-xs text-green-300 bg-green-400/10 border border-green-400/20 px-3 py-1 rounded-full">
                                                    Read
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-xs text-yellow-300 bg-yellow-400/10 border border-yellow-400/20 px-3 py-1 rounded-full">
                                                    Unread
                                                </span>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    @if (totalPages > 1)
                    {
                        <div class="mt-8 pt-6 border-t border-white/10 flex items-center justify-between gap-4 flex-wrap">
                            <div class="text-sm text-white/40">
                                Trang @currentPage trong @totalPages
                            </div>

                            <div class="flex items-center gap-2 flex-wrap">
                                @if (currentPage > 1)
                                {
                                    <a asp-action="Index"
                                       asp-route-page="@(currentPage - 1)"
                                       class="px-4 py-2 rounded-xl border border-white/10 bg-white/5 text-white/80 hover:bg-white/10 hover:text-white transition-all text-sm">
                                        Previous
                                    </a>
                                }
                                else
                                {
                                    <span class="px-4 py-2 rounded-xl border border-white/5 bg-white/5 text-white/20 cursor-not-allowed text-sm">
                                        Previous
                                    </span>
                                }

                                @{
                                    var startPage = Math.Max(1, currentPage - 2);
                                    var endPage = Math.Min(totalPages, currentPage + 2);
                                }

                                @for (int i = startPage; i <= endPage; i++)
                                {
                                    if (i == currentPage)
                                    {
                                        <span class="min-w-[42px] text-center px-4 py-2 rounded-xl bg-primary text-background-dark font-bold text-sm">
                                            @i
                                        </span>
                                    }
                                    else
                                    {
                                        <a asp-action="Index"
                                           asp-route-page="@i"
                                           class="min-w-[42px] text-center px-4 py-2 rounded-xl border border-white/10 bg-white/5 text-white/80 hover:bg-white/10 hover:text-white transition-all text-sm">
                                            @i
                                        </a>
                                    }
                                }

                                @if (currentPage < totalPages)
                                {
                                    <a asp-action="Index"
                                       asp-route-page="@(currentPage + 1)"
                                       class="px-4 py-2 rounded-xl border border-white/10 bg-white/5 text-white/80 hover:bg-white/10 hover:text-white transition-all text-sm">
                                        Next
                                    </a>
                                }
                                else
                                {
                                    <span class="px-4 py-2 rounded-xl border border-white/5 bg-white/5 text-white/20 cursor-not-allowed text-sm">
                                        Next
                                    </span>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="rounded-2xl border border-dashed border-white/10 bg-black/20 p-12 text-center">
                        <div class="w-16 h-16 mx-auto rounded-2xl bg-white/5 flex items-center justify-center mb-4">
                            <span class="material-symbols-outlined text-white/30 text-4xl">notifications_off</span>
                        </div>

                        <h3 class="text-white text-xl font-bold mb-2">No notifications yet</h3>
                        <p class="text-white/50 text-sm">You don't have any notifications at the moment.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>