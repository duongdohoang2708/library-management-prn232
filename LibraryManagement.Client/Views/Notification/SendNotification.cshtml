@model LibraryManagementDAL.DTO.Notification.NotificationCreateRequest

@{
    ViewData["Title"] = "Send Notification";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="flex-1 flex overflow-hidden">
    <div class="flex-1 px-8 py-12 overflow-y-auto custom-scrollbar">
        <div class="max-w-3xl mx-auto pb-20">

            <div class="mb-10">
                <h1 class="text-4xl font-bold font-display text-white mb-2">Send Notification</h1>
                <p class="text-white/60 text-sm">
                    Search member by ID, name or email and send a custom notification
                </p>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="mb-6 rounded-xl border border-red-400/20 bg-red-400/10 px-4 py-3 text-red-300 text-sm">
                    @TempData["Error"]
                </div>
            }

            <div class="bg-white/5 p-8 rounded-2xl border border-white/10 shadow-2xl relative overflow-visible">
                <div class="absolute -top-20 -right-20 w-64 h-64 bg-primary/10 blur-3xl rounded-full pointer-events-none"></div>

                <div class="relative z-10">
                    <h2 class="text-white text-2xl font-bold mb-8 flex items-center gap-3">
                        <span class="material-symbols-outlined text-primary text-3xl">notifications_active</span>
                        Notification Details
                    </h2>

                    <form asp-action="SendNotification" asp-controller="Notification" method="post" class="flex flex-col gap-6">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly"
                             class="p-4 bg-red-500/10 border border-red-500/20 text-red-400 text-sm rounded-xl font-medium">
                        </div>

                        <!-- User Search -->
                        <div class="flex flex-col gap-2 relative">
                            <label class="text-sm font-semibold text-white/80 flex items-center gap-2">
                                <span class="material-symbols-outlined text-[18px] text-white/40">person_search</span>
                                Member Information (ID / Name / Email)
                            </label>

                            <div class="relative group">
                                <input type="text"
                                       id="userSearchInput"
                                       class="w-full bg-black/30 border border-white/10 rounded-xl py-3.5 pl-4 pr-10 text-white placeholder:text-white/20 focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary/40 transition-all shadow-inner shadow-black/20"
                                       placeholder="Type ID, name or email to search..."
                                       autocomplete="off" />

                                <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-white/20 group-focus-within:text-primary transition-colors text-2xl">
                                    manage_search
                                </span>

                                <!-- Hidden input bind vào DTO -->
                                <input asp-for="UserId" type="hidden" id="selectedUserId" />
                            </div>

                            <!-- Search Results -->
                            <div id="userSearchResults"
                                 class="absolute top-full left-0 right-0 mt-2 bg-[#1a232e] border border-white/10 rounded-xl shadow-2xl z-[100] hidden overflow-hidden backdrop-blur-xl">
                                <div id="userResultsList" class="max-h-[300px] overflow-y-auto custom-scrollbar">
                                </div>
                            </div>

                            <!-- Selected User -->
                            <div id="selectedUserCard"
                                 class="@(Model.UserId > 0 ? "" : "hidden") mt-2 p-3 bg-primary/10 border border-primary/30 rounded-xl flex items-center justify-between animate-fadeIn">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center text-primary">
                                        <span class="material-symbols-outlined">person</span>
                                    </div>
                                    <div>
                                        <h4 id="displayUserName" class="text-sm font-bold text-white">
                                            @(ViewBag.SelectedUserName ?? "---")
                                        </h4>
                                        <p id="displayUserInfo" class="text-[11px] text-primary/70 font-mono">
                                            @(Model.UserId > 0
                                                ? $"ID: {Model.UserId} • {ViewBag.SelectedUserEmail}"
                                                : "ID: ---")
                                        </p>
                                    </div>
                                </div>

                                <button type="button"
                                        onclick="clearSelectedUser()"
                                        class="p-1.5 hover:bg-white/5 rounded-lg text-white/40 hover:text-red-400 transition-colors">
                                    <span class="material-symbols-outlined text-sm">close</span>
                                </button>
                            </div>

                            <span asp-validation-for="UserId" class="text-red-400 text-xs font-semibold mt-1"></span>
                        </div>

                        <!-- Title -->
                        <div class="flex flex-col gap-2">
                            <label asp-for="Title" class="text-sm font-semibold text-white/80 flex items-center gap-2">
                                <span class="material-symbols-outlined text-[18px] text-white/40">title</span>
                                Title
                            </label>
                            <input asp-for="Title"
                                   class="w-full p-3 rounded-xl bg-black/30 text-white border border-white/10 focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary/40 transition-all shadow-inner shadow-black/20" />
                            <span asp-validation-for="Title" class="text-red-400 text-sm"></span>
                        </div>

                        <!-- Message -->
                        <div class="flex flex-col gap-2">
                            <label asp-for="Message" class="text-sm font-semibold text-white/80 flex items-center gap-2">
                                <span class="material-symbols-outlined text-[18px] text-white/40">edit_note</span>
                                Message
                            </label>
                            <textarea asp-for="Message"
                                      rows="5"
                                      class="w-full p-3 rounded-xl bg-black/30 text-white border border-white/10 focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary/40 transition-all shadow-inner shadow-black/20"></textarea>
                            <span asp-validation-for="Message" class="text-red-400 text-sm"></span>
                        </div>

                        <!-- Type -->
                        <div class="flex flex-col gap-2">
                            <label asp-for="Type" class="text-sm font-semibold text-white/80 flex items-center gap-2">
                                <span class="material-symbols-outlined text-[18px] text-white/40">category</span>
                                Type
                            </label>
                            <select asp-for="Type"
                                    class="w-full p-3 rounded-xl bg-black/30 text-white border border-white/10 focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary/40 transition-all shadow-inner shadow-black/20">
                                <option value="General">General</option>
                                <option value="Manual">Manual</option>
                                <option value="Warning">Warning</option>
                            </select>
                            <span asp-validation-for="Type" class="text-red-400 text-sm"></span>
                        </div>

                        <!-- Actions -->
                        <div class="mt-4 flex justify-end gap-3 pt-6 border-t border-white/10">
                            <a asp-action="Index"
                               asp-controller="Notification"
                               class="px-8 py-3 rounded-xl border border-white/10 text-white/50 hover:text-white hover:bg-white/5 transition-all text-sm uppercase font-bold tracking-wider flex items-center">
                                Cancel
                            </a>

                            <button type="submit"
                                    class="bg-primary px-8 py-3 rounded-xl text-background-dark font-black hover:shadow-xl hover:shadow-primary/30 transition-all text-sm uppercase tracking-wider">
                                Send Notification
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .animate-fadeIn {
        animation: fadeIn 0.2s ease forwards;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: scale(0.95);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const userSearchInput = document.getElementById('userSearchInput');
        const userSearchResults = document.getElementById('userSearchResults');
        const userResultsList = document.getElementById('userResultsList');
        const selectedUserIdInput = document.getElementById('selectedUserId');
        const selectedUserCard = document.getElementById('selectedUserCard');
        const displayUserName = document.getElementById('displayUserName');
        const displayUserInfo = document.getElementById('displayUserInfo');

        if (selectedUserIdInput.value) 
        {
            userSearchInput.placeholder = 'Selected: ' + displayUserName.textContent;
        }

        let searchTimeout = null;

        userSearchInput.addEventListener('input', function () {
            clearTimeout(searchTimeout);
            const query = this.value.trim();

            if (query.length < 1) {
                userSearchResults.classList.add('hidden');
                return;
            }

            searchTimeout = setTimeout(async () => {
                try {
                    const response = await fetch(`/Circulation/SearchUsers?query=${encodeURIComponent(query)}`);
                    const users = await response.json();

                    if (users.length > 0) {
                        renderUserResults(users);
                        userSearchResults.classList.remove('hidden');
                    } else {
                        userResultsList.innerHTML = `
                            <div class="p-4 text-white/40 text-center text-sm">
                                Không tìm thấy người dùng nào
                            </div>
                        `;
                        userSearchResults.classList.remove('hidden');
                    }
                } catch (error) {
                    console.error('Error fetching users:', error);
                    userResultsList.innerHTML = `
                        <div class="p-4 text-red-400 text-center text-sm">
                            Có lỗi khi tìm kiếm người dùng
                        </div>
                    `;
                    userSearchResults.classList.remove('hidden');
                }
            }, 300);
        });

        function renderUserResults(users) {
            userResultsList.innerHTML = users.map(user => `
                <div class="px-4 py-3 hover:bg-white/5 cursor-pointer border-b border-white/5 last:border-0 transition-colors group"
                     onclick="selectUser(${user.userId}, '${escapeJs(user.fullName)}', '${escapeJs(user.email)}')">
                    <div class="flex items-center justify-between gap-3">
                        <div class="min-w-0">
                            <div class="text-sm font-bold text-white group-hover:text-primary transition-colors truncate">
                                ${user.fullName}
                            </div>
                            <div class="text-[10px] text-white/40 font-mono truncate">
                                ${user.email}
                            </div>
                        </div>
                        <div class="px-2 py-0.5 bg-white/5 rounded text-[10px] text-primary font-bold whitespace-nowrap">
                            ID: ${user.userId}
                        </div>
                    </div>
                </div>
            `).join('');
        }

        function selectUser(id, name, email) {
            selectedUserIdInput.value = id;
            displayUserName.textContent = name;
            displayUserInfo.textContent = `ID: ${id} • ${email}`;

            selectedUserCard.classList.remove('hidden');
            userSearchResults.classList.add('hidden');
            userSearchInput.value = '';
            userSearchInput.placeholder = 'Selected: ' + name;
        }

        function clearSelectedUser() {
            selectedUserIdInput.value = '';
            selectedUserCard.classList.add('hidden');
            displayUserName.textContent = '---';
            displayUserInfo.textContent = 'ID: ---';
            userSearchInput.value = '';
            userSearchInput.placeholder = 'Type ID, name or email to search...';
        }

        document.addEventListener('click', (e) => {
            if (!userSearchInput.contains(e.target) && !userSearchResults.contains(e.target)) {
                userSearchResults.classList.add('hidden');
            }
        });

        function escapeJs(value) {
            if (!value) return '';
            return value
                .replace(/\\/g, '\\\\')
                .replace(/'/g, "\\'")
                .replace(/"/g, '&quot;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;');
        }
    </script>
}