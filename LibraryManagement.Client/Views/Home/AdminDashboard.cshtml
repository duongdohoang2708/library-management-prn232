@using LibraryManagementDAL.DTO.Dashboard
@using LibraryManagement.Client.DTO.Admin
@{
    ViewData["Title"] = "System Administration Panel";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";

    var recentUsers = ViewBag.RecentUsers as List<DashboardUserItem> ?? new List<DashboardUserItem>();
    var recentAuditLogs = ViewBag.RecentAuditLogs as List<AuditLogItemDto> ?? new List<AuditLogItemDto>();
    var policy = ViewBag.LibraryPolicy as LibraryPolicySettingsDto ?? new LibraryPolicySettingsDto();

    var monthlyLabels = ViewBag.MonthlyLabels as List<string> ?? new List<string>();
    var monthlyRegistrations = ViewBag.MonthlyRegistrations as List<int> ?? new List<int>();
}

<div class="flex-1 p-8 min-w-0 overflow-y-auto custom-scrollbar">

    @if (ViewBag.DashboardDataError != null)
    {
        <div class="mb-6 rounded-2xl border border-red-500/20 bg-red-500/10 px-5 py-4 text-sm font-bold text-red-300">
            @ViewBag.DashboardDataError
        </div>
    }

    <div class="mb-10 flex justify-between items-end">
        <div>
            <h1 class="text-4xl font-extrabold text-white tracking-tight mb-2">
                Good afternoon, <span class="text-primary">@User.Identity?.Name</span> 👑
            </h1>
            <p class="text-white/50 text-lg">System Administration Control Panel</p>
        </div>
        <div class="text-right">
            <p class="text-[10px] font-bold text-white/40 uppercase tracking-widest mb-1">System Status</p>
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-xs font-bold">
                <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                All Systems Operational
            </div>
        </div>
    </div>

    <!-- Stat Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        <div class="bg-white/5 border border-white/10 p-6 rounded-3xl relative overflow-hidden group hover:border-primary/40 transition-all shadow-xl shadow-black/20">
            <div class="absolute -right-6 -bottom-6 w-24 h-24 bg-primary/10 rounded-full blur-2xl group-hover:bg-primary/20 transition-all"></div>
            <div class="flex items-center gap-4 mb-4">
                <div class="p-3 bg-primary/20 rounded-2xl text-primary">
                    <span class="material-symbols-outlined text-3xl">group</span>
                </div>
                <div>
                    <p class="text-[11px] font-bold text-white/40 uppercase tracking-widest">Global Users</p>
                    <h3 class="text-3xl font-black text-white">@(((int?)ViewBag.TotalUsers ?? 0).ToString("N0"))</h3>
                </div>
            </div>
            <a asp-controller="User" asp-action="AllUsers" class="text-[10px] text-primary/70 font-bold bg-primary/5 w-fit px-2 py-0.5 rounded border border-primary/20 hover:bg-primary/15 transition-all block">
                Manage System Users &rarr;
            </a>
        </div>

        <div class="bg-white/5 border border-white/10 p-6 rounded-3xl relative overflow-hidden group hover:border-blue-500/40 transition-all shadow-xl shadow-black/20">
            <div class="absolute -right-6 -bottom-6 w-24 h-24 bg-blue-500/10 rounded-full blur-2xl group-hover:bg-blue-500/20 transition-all"></div>
            <div class="flex items-center gap-4 mb-4">
                <div class="p-3 bg-blue-500/20 rounded-2xl text-blue-400">
                    <span class="material-symbols-outlined text-3xl">compare_arrows</span>
                </div>
                <div>
                    <p class="text-[11px] font-bold text-white/40 uppercase tracking-widest">Transactions</p>
                    <h3 class="text-3xl font-black text-white">@(((int?)ViewBag.TotalTransactions ?? 0).ToString("N0"))</h3>
                </div>
            </div>
            <a asp-controller="Reports" asp-action="Index" class="text-[10px] text-blue-400/70 font-bold bg-blue-500/5 w-fit px-2 py-0.5 rounded border border-blue-500/20 hover:bg-blue-500/15 transition-all block">
                View Reports &rarr;
            </a>
        </div>

        <div class="bg-white/5 border border-white/10 p-6 rounded-3xl relative overflow-hidden group hover:border-purple-500/40 transition-all shadow-xl shadow-black/20">
            <div class="absolute -right-6 -bottom-6 w-24 h-24 bg-purple-500/10 rounded-full blur-2xl group-hover:bg-purple-500/20 transition-all"></div>
            <div class="flex items-center gap-4 mb-4">
                <div class="p-3 bg-purple-500/20 rounded-2xl text-purple-400">
                    <span class="material-symbols-outlined text-3xl">auto_stories</span>
                </div>
                <div>
                    <p class="text-[11px] font-bold text-white/40 uppercase tracking-widest">Library Book Catalog</p>
                    <h3 class="text-3xl font-black text-white">@(((int?)ViewBag.TotalBooks ?? 0).ToString("N0"))</h3>
                </div>
            </div>
            <div class="text-[10px] text-purple-400/70 font-bold bg-purple-500/5 w-fit px-2 py-0.5 rounded border border-purple-500/20">
                Managed by Librarians
            </div>
        </div>

        <div class="bg-white/5 border border-white/10 p-6 rounded-3xl relative overflow-hidden group hover:border-green-500/40 transition-all shadow-xl shadow-black/20">
            <div class="absolute -right-6 -bottom-6 w-24 h-24 bg-green-500/10 rounded-full blur-2xl group-hover:bg-green-500/20 transition-all"></div>
            <div class="flex items-center gap-4 mb-4">
                <div class="p-3 bg-green-500/20 rounded-2xl text-green-400">
                    <span class="material-symbols-outlined text-3xl">payments</span>
                </div>
                <div>
                    <p class="text-[11px] font-bold text-white/40 uppercase tracking-widest">Total Unpaid Fines</p>
                    <h3 class="text-3xl font-black text-white">@(((decimal?)ViewBag.TotalUnpaidFines ?? 0).ToString("N0")) đ</h3>
                </div>
            </div>
            <div class="text-[10px] text-green-400/70 font-bold bg-green-500/5 w-fit px-2 py-0.5 rounded border border-green-500/20">
                Fines Overview
            </div>
        </div>
    </div>

    <!-- Quick Actions Panel -->
    <div class="bg-white/5 border border-white/10 p-8 rounded-3xl relative overflow-hidden mb-12 shadow-2xl">
        <h3 class="text-xl font-black text-primary mb-6 flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">terminal</span>
            System Actions & Management
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
            <a asp-controller="User" asp-action="AllUsers" class="flex flex-col items-center justify-center p-6 bg-white/5 hover:bg-primary hover:text-background-dark border border-white/10 rounded-2xl transition-all text-center group">
                <span class="material-symbols-outlined text-3xl text-primary group-hover:text-background-dark mb-2">person_add</span>
                <span class="font-bold text-sm">Manage Users</span>
            </a>
            <a asp-controller="Reports" asp-action="Index" class="flex flex-col items-center justify-center p-6 bg-white/5 hover:bg-blue-500 hover:text-background-dark border border-white/10 rounded-2xl transition-all text-center group">
                <span class="material-symbols-outlined text-3xl text-blue-400 group-hover:text-background-dark mb-2">summarize</span>
                <span class="font-bold text-sm">Advanced Reports</span>
            </a>
            <a asp-controller="Audit" asp-action="Index" class="flex flex-col items-center justify-center p-6 bg-white/5 hover:bg-amber-500 hover:text-background-dark border border-white/10 rounded-2xl transition-all text-center group">
                <span class="material-symbols-outlined text-3xl text-amber-400 group-hover:text-background-dark mb-2">manage_search</span>
                <span class="font-bold text-sm">Security Audit Logs</span>
            </a>
            <a asp-controller="SystemSettings" asp-action="Index" class="flex flex-col items-center justify-center p-6 bg-white/5 hover:bg-purple-500 hover:text-background-dark border border-white/10 rounded-2xl transition-all text-center group">
                <span class="material-symbols-outlined text-3xl text-purple-400 group-hover:text-background-dark mb-2">settings</span>
                <span class="font-bold text-sm">System Settings</span>
            </a>
            <form asp-controller="SystemSettings" asp-action="RunDueReminders" method="post" class="h-full">
                @Html.AntiForgeryToken()
                <button type="submit" class="w-full h-full flex flex-col items-center justify-center p-6 bg-white/5 hover:bg-emerald-500 hover:text-background-dark border border-white/10 rounded-2xl transition-all text-center group">
                    <span class="material-symbols-outlined text-3xl text-emerald-400 group-hover:text-background-dark mb-2">notifications_active</span>
                    <span class="font-bold text-sm">Trigger Reminders</span>
                </button>
            </form>
        </div>
    </div>

    <!-- Main Content Area -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Left Content (Recent Audit Logs) -->
        <div class="lg:col-span-2 flex flex-col gap-8">
            <div class="bg-black/20 border border-white/10 rounded-3xl overflow-hidden flex flex-col shadow-2xl">
                <div class="p-6 border-b border-white/5 bg-white/5 flex items-center justify-between">
                    <h3 class="text-lg font-bold text-white flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">security</span>
                        Recent Audit Logs (Latest Activity)
                    </h3>
                    <a asp-controller="Audit" asp-action="Index" class="text-xs font-bold text-primary hover:underline">Full Log &rarr;</a>
                </div>
                <div class="flex-1 overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="bg-white/5 text-[10px] uppercase font-bold tracking-widest text-white/40">
                            <tr>
                                <th class="px-6 py-4">Timestamp</th>
                                <th class="px-6 py-4">Actor</th>
                                <th class="px-6 py-4">Action</th>
                                <th class="px-6 py-4">Entity</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/5">
                            @foreach (var log in recentAuditLogs)
                            {
                                <tr class="hover:bg-white/[0.02] transition-colors group">
                                    <td class="px-6 py-4 text-xs font-mono text-white/60">@log.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                    <td class="px-6 py-4 text-xs">
                                        <div class="font-bold text-white">@log.ActorName</div>
                                        <span class="px-1.5 py-0.5 bg-primary/10 text-primary text-[8px] font-bold rounded-md border border-primary/20">@log.ActorRole</span>
                                    </td>
                                    <td class="px-6 py-4 text-xs text-white/80 font-semibold truncate max-w-[200px]" title="@log.Summary">
                                        @log.Action
                                    </td>
                                    <td class="px-6 py-4 text-xs text-white/40">@log.EntityName (@log.EntityId)</td>
                                </tr>
                            }
                            @if (!recentAuditLogs.Any())
                            {
                                <tr>
                                    <td colspan="4" class="px-6 py-8 text-center text-sm text-white/30 italic">No recent system logs.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- System Growth Chart -->
            <div class="bg-black/20 border border-white/10 p-6 rounded-3xl flex flex-col shadow-2xl relative">
                <h3 class="text-lg font-bold text-white mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">trending_up</span>
                    Monthly User Registrations Trend
                </h3>
                <div class="flex-1 w-full h-[250px] relative">
                    <canvas id="growthChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Right Content (Registrations + Active Policies) -->
        <div class="flex flex-col gap-8">
            
            <!-- System Policy Overview -->
            <div class="bg-black/20 border border-white/10 p-6 rounded-3xl flex flex-col shadow-2xl">
                <h3 class="text-sm font-bold text-white/60 uppercase tracking-widest mb-6 flex items-center justify-between">
                    System Policy Settings
                    <span class="material-symbols-outlined text-primary">policy</span>
                </h3>
                <div class="space-y-4">
                    <div class="flex justify-between items-center py-2 border-b border-white/5">
                        <span class="text-xs text-white/55">Default Loan Days</span>
                        <span class="text-xs font-bold text-white bg-white/5 px-2.5 py-1 rounded-lg">@policy.DefaultLoanDays Days</span>
                    </div>
                    <div class="flex justify-between items-center py-2 border-b border-white/5">
                        <span class="text-xs text-white/55">Renew Duration</span>
                        <span class="text-xs font-bold text-white bg-white/5 px-2.5 py-1 rounded-lg">@policy.RenewDays Days</span>
                    </div>
                    <div class="flex justify-between items-center py-2 border-b border-white/5">
                        <span class="text-xs text-white/55">Reservation Hold Duration</span>
                        <span class="text-xs font-bold text-white bg-white/5 px-2.5 py-1 rounded-lg">@policy.ReservationHoldDays Days</span>
                    </div>
                    <div class="flex justify-between items-center py-2 border-b border-white/5">
                        <span class="text-xs text-white/55">Max Borrowed Books Limit</span>
                        <span class="text-xs font-bold text-white bg-white/5 px-2.5 py-1 rounded-lg">@policy.MaxOpenBorrowedBooks Books</span>
                    </div>
                    <div class="flex justify-between items-center py-2 border-b border-white/5">
                        <span class="text-xs text-white/55">Overdue Fine Per Day</span>
                        <span class="text-xs font-bold text-amber-400 bg-amber-500/10 px-2.5 py-1 rounded-lg border border-amber-500/20">@policy.OverdueFinePerDay.ToString("N0") đ</span>
                    </div>
                    <div class="flex justify-between items-center py-2 border-b border-white/5">
                        <span class="text-xs text-white/55">Damaged Book Fine</span>
                        <span class="text-xs font-bold text-red-400 bg-red-500/10 px-2.5 py-1 rounded-lg border border-red-500/20">@policy.DamagedFine.ToString("N0") đ</span>
                    </div>
                    <div class="flex justify-between items-center py-2">
                        <span class="text-xs text-white/55">Lost Book Fine</span>
                        <span class="text-xs font-bold text-red-500 bg-red-500/20 px-2.5 py-1 rounded-lg border border-red-500/30">@policy.LostFine.ToString("N0") đ</span>
                    </div>
                </div>
                <a asp-controller="SystemSettings" asp-action="Index" class="mt-6 text-[10px] font-black text-center text-primary uppercase tracking-[0.2em] hover:tracking-[0.3em] transition-all block">
                    Modify Policies
                </a>
            </div>

            <!-- Newest Registrations -->
            <div class="bg-white/5 border border-white/10 rounded-3xl flex flex-col shadow-2xl overflow-hidden p-6">
                <h3 class="text-sm font-bold text-white/60 uppercase tracking-widest mb-6 flex items-center justify-between">
                    New Members (Users)
                    <span class="material-symbols-outlined text-primary">person_add</span>
                </h3>
                <div class="flex flex-col gap-4">
                    @foreach (var u in recentUsers)
                    {
                        <div class="flex items-center gap-4 group">
                            <div class="w-10 h-10 rounded-full bg-white/10 border border-white/20 flex items-center justify-center text-white font-bold text-sm shadow-inner group-hover:bg-primary/20 group-hover:text-primary transition-all">
                                @(u.FullName?[0].ToString() ?? "?")
                            </div>
                            <div>
                                <h4 class="text-xs font-bold text-white group-hover:text-primary transition-colors">@u.FullName</h4>
                                <p class="text-[9px] text-white/40 font-mono truncate max-w-[120px]">@u.Email</p>
                            </div>
                            <div class="ml-auto text-right">
                                <p class="text-[9px] font-bold text-white/60">@u.CreatedAt.ToString("MMM dd")</p>
                                <span class="text-[8px] px-1 py-0.25 bg-white/5 border border-white/10 text-white/55 rounded uppercase tracking-wider">User</span>
                            </div>
                        </div>
                    }

                    @if (!recentUsers.Any())
                    {
                        <p class="text-xs text-white/30 text-center italic py-4">No users found.</p>
                    }
                </div>
                <a asp-controller="User" asp-action="AllUsers" class="mt-6 text-[10px] font-black text-center text-primary uppercase tracking-[0.2em] hover:tracking-[0.3em] transition-all block">
                    Manage Users
                </a>
            </div>

        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            Chart.defaults.color = 'rgba(255, 255, 255, 0.4)';
            Chart.defaults.font.family = "'Inter', sans-serif";

            const perfLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(monthlyLabels));
            const registrationData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(monthlyRegistrations));

            const ctxGrowth = document.getElementById('growthChart').getContext('2d');

            new Chart(ctxGrowth, {
                type: 'line',
                data: {
                    labels: perfLabels,
                    datasets: [
                        {
                            label: 'New Member Registrations',
                            data: registrationData,
                            borderColor: '#eab308',
                            backgroundColor: 'rgba(234, 179, 8, 0.1)',
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3,
                            pointBackgroundColor: '#eab308',
                            pointRadius: 5
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top', align: 'end' },
                        tooltip: { backgroundColor: 'rgba(0,0,0,0.8)', padding: 12 }
                    },
                    scales: {
                        y: {
                            grid: { color: 'rgba(255,255,255,0.05)' },
                            ticks: { precision: 0 }
                        },
                        x: {
                            grid: { display: false }
                        }
                    }
                }
            });
        });
    </script>
}
