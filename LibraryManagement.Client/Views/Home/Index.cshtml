@model List<LibraryManagementDAL.Models.Book>
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    var popularBooks = ViewBag.PopularBooks as List<LibraryManagementDAL.Models.Book>;
}

<div class="flex-1 flex overflow-hidden bg-[#0A0F1E] relative">
    <!-- Ambient Background -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden z-0">
        <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full mix-blend-screen filter blur-[150px] opacity-30 animate-blob" style="background-color: #10B981;"></div>
        <div class="absolute top-[20%] right-[-10%] w-[50%] h-[50%] rounded-full mix-blend-screen filter blur-[150px] opacity-20 animate-blob animation-delay-2000" style="background-color: #14B8A6;"></div>
        <div class="absolute bottom-[-20%] left-[20%] w-[60%] h-[60%] rounded-full mix-blend-screen filter blur-[150px] opacity-20 animate-blob animation-delay-4000" style="background-color: #3B82F6;"></div>
        <div class="absolute inset-0 opacity-[0.03] mix-blend-overlay" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>
    </div>

    <!-- Main Scrollable Content -->
    <div class="flex-1 p-8 min-w-0 overflow-y-auto custom-scrollbar relative z-10">
        
        @{
            var spotlightBooks = popularBooks?.Take(5).ToList() ?? new List<LibraryManagementDAL.Models.Book>();
        }

        <!-- Welcome Hero & Spotlight Carousel -->
        <div class="relative mb-6 rounded-3xl overflow-hidden group min-h-[360px] flex items-center shadow-2xl" id="spotlightCarousel">
            @if (spotlightBooks.Any())
            {
                var index = 0;
                foreach (var spotlightBook in spotlightBooks)
                {
                    <div class="spotlight-item absolute inset-0 w-full h-full transition-opacity duration-1000 @(index == 0 ? "opacity-100 z-10" : "opacity-0 z-0 pointer-events-none")" data-index="@index">
                        <!-- Blurred Background -->
                        <div class="absolute inset-0 z-0">
                            <img src="@BookImageHelper.Resolve(spotlightBook.ImageUrl, spotlightBook.Title)" class="w-full h-full object-cover opacity-30 blur-2xl scale-110 transform" />
                            <div class="absolute inset-0 bg-gradient-to-r from-background-dark via-background-dark/80 to-transparent"></div>
                            <div class="absolute inset-0 bg-gradient-to-t from-background-dark via-background-dark/50 to-transparent"></div>
                        </div>

                        <div class="relative z-10 flex flex-col md:flex-row items-center gap-8 p-8 md:p-12 w-full h-full">
                            <!-- Text Content -->
                            <div class="flex-1">
                                <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/20 text-primary text-[10px] font-black tracking-widest uppercase mb-4 border border-primary/30 backdrop-blur-md shadow-[0_0_15px_rgba(16,185,129,0.2)]">
                                    <span class="material-symbols-outlined text-xs">local_fire_department</span> Spotlight
                                </span>
                                <h1 class="text-4xl md:text-5xl font-black text-white mb-4 leading-tight drop-shadow-lg">
                                    @spotlightBook.Title
                                </h1>
                                <p class="text-white/70 text-sm md:text-base max-w-xl mb-8 line-clamp-3 leading-relaxed">
                                    @(spotlightBook.Description ?? "Dive into this week's most highly recommended read. Explore our vast collection of literature and research materials directly from your personalized digital dashboard.")
                                </p>
                                
                                <div class="flex items-center gap-4">
                                    <a href="@Url.Action("Details", "Books", new { id = spotlightBook.BookId })" class="px-6 py-3 rounded-xl bg-primary text-background-dark font-black text-xs uppercase tracking-widest hover:scale-105 transition-transform shadow-[0_0_20px_rgba(16,185,129,0.4)]">
                                        Read Now
                                    </a>
                                </div>
                            </div>

                            <!-- Book Cover -->
                            <div class="hidden md:block flex-shrink-0 relative group-hover:-translate-y-2 transition-transform duration-700">
                                <div class="w-48 aspect-[3/4.5] rounded-2xl overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.5)] border border-white/10 relative z-10">
                                    <img src="@BookImageHelper.Resolve(spotlightBook.ImageUrl, spotlightBook.Title)" class="w-full h-full object-cover" />
                                </div>
                                <div class="absolute -inset-4 bg-primary/20 blur-3xl rounded-full z-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                            </div>
                        </div>
                    </div>
                    index++;
                }
                
                <!-- Carousel Indicators -->
                <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 flex gap-2">
                    @for (int i = 0; i < spotlightBooks.Count; i++)
                    {
                        <div class="carousel-dot w-2 h-2 rounded-full cursor-pointer transition-all duration-300 @(i == 0 ? "bg-primary w-6" : "bg-white/30 hover:bg-white/50")" data-index="@i"></div>
                    }
                </div>
            }
            else
            {
                <!-- Fallback Hero -->
                <div class="absolute inset-0 z-0 bg-gradient-to-br from-primary/20 via-primary/5 to-transparent border border-white/5"></div>
                <div class="relative z-10 p-8 md:p-12 w-full">
                    <span class="inline-block px-3 py-1 rounded-full bg-primary/20 text-primary text-[10px] font-black tracking-widest uppercase mb-3 border border-primary/30 backdrop-blur-md">
                        Library Management System
                    </span>
                    <h1 class="text-3xl md:text-5xl font-black text-white mb-2 leading-tight">Your Personal <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-teal-400">Knowledge Sanctuary</span></h1>
                    <p class="text-white/50 max-w-lg text-sm md:text-base">Access the world's best collection of literature and research materials from your digital dashboard.</p>
                </div>
            }
        </div>

        <!-- Quick Stats / Actions Bar -->
        <div class="mb-16 grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="bg-white/5 border border-white/5 rounded-2xl p-4 flex items-center gap-4 hover:bg-white/10 hover:border-primary/30 transition-all cursor-pointer group backdrop-blur-md">
                <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined">menu_book</span>
                </div>
                <div>
                    <div class="text-2xl font-black text-white">10k+</div>
                    <div class="text-[10px] font-bold text-white/40 uppercase tracking-widest">Books</div>
                </div>
            </div>
            <div class="bg-white/5 border border-white/5 rounded-2xl p-4 flex items-center gap-4 hover:bg-white/10 hover:border-blue-500/30 transition-all cursor-pointer group backdrop-blur-md">
                <div class="w-12 h-12 rounded-full bg-blue-500/10 flex items-center justify-center text-blue-400 group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined">category</span>
                </div>
                <div>
                    <div class="text-2xl font-black text-white">@(ViewBag.Categories != null ? ((IEnumerable<dynamic>)ViewBag.Categories).Count() : 0)+</div>
                    <div class="text-[10px] font-bold text-white/40 uppercase tracking-widest">Genres</div>
                </div>
            </div>
            <div class="bg-white/5 border border-white/5 rounded-2xl p-4 flex items-center gap-4 hover:bg-white/10 hover:border-amber-500/30 transition-all cursor-pointer group backdrop-blur-md">
                <div class="w-12 h-12 rounded-full bg-amber-500/10 flex items-center justify-center text-amber-400 group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined">star</span>
                </div>
                <div>
                    <div class="text-2xl font-black text-white">4.8</div>
                    <div class="text-[10px] font-bold text-white/40 uppercase tracking-widest">Avg Rating</div>
                </div>
            </div>
            <a href="@Url.Action("ViewBooks", "Books")" class="bg-gradient-to-br from-primary/20 to-teal-500/10 border border-primary/20 rounded-2xl p-4 flex flex-col justify-center items-center gap-1 hover:from-primary/30 hover:to-teal-500/20 transition-all group backdrop-blur-md shadow-[0_10px_20px_rgba(16,185,129,0.1)]">
                <span class="material-symbols-outlined text-primary group-hover:-translate-y-1 transition-transform">search</span>
                <span class="text-[10px] font-black text-primary uppercase tracking-widest">Explore Library</span>
            </a>
        </div>

        <!-- Recommended Section -->
        <section class="mb-16">
            <div class="flex items-center justify-between mb-8 px-2">
                <div class="flex items-center gap-4">
                    <div class="w-1.5 h-10 bg-primary rounded-full shadow-[0_0_20px_rgba(16,185,129,0.5)]"></div>
                    <h2 class="text-3xl font-black text-white tracking-tight">Recommended</h2>
                </div>
                <a asp-controller="Books" asp-action="ViewBooks" class="group flex items-center gap-2 text-primary font-black text-sm hover:gap-3 transition-all">
                    Explores All
                    <span class="material-symbols-outlined text-lg">arrow_right_alt</span>
                </a>
            </div>
            
            <!-- Horizontal Scroll Container -->
            <div class="flex overflow-x-auto custom-scrollbar gap-6 pb-6 snap-x snap-mandatory relative z-20">
                @if (Model != null && Model.Any())
                {
                    foreach (var book in Model)
                    {
                        <div class="snap-start flex-shrink-0 w-[380px] md:w-[460px] bg-white/5 border border-white/10 p-5 rounded-[2rem] group hover:bg-white/10 hover:border-primary/40 hover:shadow-[0_10px_30px_rgba(16,185,129,0.1)] transition-all cursor-pointer flex gap-6 h-[180px] md:h-[200px] relative overflow-hidden">
                            <!-- Background Glow on Hover -->
                            <div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

                            <!-- Cover -->
                            <div class="w-24 md:w-32 flex-shrink-0 aspect-[3/4.5] rounded-xl overflow-hidden shadow-lg group-hover:-translate-y-2 transition-transform relative z-10">
                                <img src="@BookImageHelper.Resolve(book.ImageUrl, book.Title)" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" onerror="this.onerror=null;this.src='@BookImageHelper.Placeholder';" />
                            </div>
                            
                            <!-- Info -->
                            <div class="flex flex-col justify-center flex-1 min-w-0 relative z-10 py-1">
                                <div class="text-[10px] text-primary bg-primary/10 px-2.5 py-1 rounded-full w-fit uppercase tracking-widest font-black mb-3 line-clamp-1 border border-primary/20">
                                    @book.Category?.CategoryName
                                </div>
                                <h4 class="text-base md:text-lg font-black text-white mb-2 group-hover:text-primary transition-colors line-clamp-2 leading-snug" title="@book.Title">
                                    <a href="@Url.Action("Details", "Books", new { id = book.BookId })">@book.Title</a>
                                </h4>
                                <p class="text-[11px] md:text-sm text-white/50 font-bold mb-auto line-clamp-1">@book.Author?.Name</p>
                                
                                <div class="flex items-center justify-between mt-3">
                                    <div class="flex items-center text-amber-400 text-xs">
                                        @{
                                            var rating = book.BookReviews?.Any() == true ? Math.Round(book.BookReviews.Average(r => r.Rating), 1) : 0;
                                        }
                                        <span class="material-symbols-outlined text-[16px]">star</span>
                                        <span class="text-[11px] font-bold text-white ml-1">@(rating > 0 ? rating.ToString("0.0") : "New")</span>
                                    </div>
                                    <span class="text-[10px] text-white/40 font-bold bg-white/5 px-2.5 py-1 rounded-md border border-white/5">
                                        @book.PublishYear
                                    </span>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </section>

        <!-- Subjects Section -->
        <section class="mb-20">
            <h2 class="text-xl font-black mb-8 text-white flex items-center gap-4">
                <span class="w-12 h-0.5 bg-white/10 rounded-full"></span>
                Browse Genres
            </h2>

            <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4 auto-rows-[120px] grid-flow-row-dense">
                @if (ViewBag.Categories != null)
                {
                    var index = 0;
                    var categoryList = ((IEnumerable<dynamic>)ViewBag.Categories).ToList();
                    
                    foreach (var c in categoryList)
                    {
                        var isSelected = ViewBag.Category == c.CategoryName;
                        var isLarge = index == 0 || index == 4;
                        var isWide = index == 8 || index == 9;
                        
                        string bentoClass = "col-span-1 row-span-1";
                        if (index == 0) bentoClass = "col-span-2 row-span-2 lg:col-start-1 lg:row-start-1";
                        else if (index == 8) bentoClass = "col-span-2 row-span-1 lg:col-start-1 lg:row-start-3";
                        else if (index == 9) bentoClass = "col-span-2 row-span-1 lg:col-start-5 lg:row-start-1";
                        else if (index == 4) bentoClass = "col-span-2 row-span-2 lg:col-start-5 lg:row-start-2";

                        var bgClass = isLarge ? "bg-gradient-to-br from-primary/20 to-teal-900/40 border-primary/20" : "bg-white/5 border-white/5";
                        var iconSize = isLarge ? "text-5xl" : "text-3xl";

                        <a href="@Url.Action("ViewBooks", "Books", new { category = c.CategoryName })"
                           class="@bentoClass group relative overflow-hidden rounded-3xl">
                            <div class="absolute inset-0 border transition-all duration-500 rounded-3xl group-hover:border-primary/40 @(isSelected ? "border-primary shadow-[0_0_20px_rgba(16,185,129,0.3)]" : "border-transparent")"></div>
                            <div class="w-full h-full p-6 @bgClass transition-all duration-500 flex flex-col items-center justify-center gap-4 group-hover:scale-105">
                                <span class="material-symbols-outlined @iconSize text-white/80 transition-transform duration-500 group-hover:rotate-12 group-hover:text-primary">
                                    @(isSelected ? "explore" : (isLarge ? "local_library" : "auto_stories"))
                                </span>
                                <span class="text-[10px] font-black uppercase tracking-[0.15em] text-center text-white/80 group-hover:text-white line-clamp-2">@c.CategoryName</span>
                            </div>
                        </a>
                        index++;
                    }


                }
            </div>
        </section>
        
        <!-- Trending Authors Section -->
        <section class="mb-20">
            <h2 class="text-xl font-black mb-8 text-white flex items-center gap-4">
                <span class="w-12 h-0.5 bg-white/10 rounded-full"></span>
                Trending Authors
            </h2>
            <div class="flex gap-8 overflow-x-auto pb-4 custom-scrollbar">
                @{
                    var trendingAuthors = Model?.Select(b => b.Author).Where(a => a != null).GroupBy(a => a.AuthorId).Select(g => g.First()).Take(8).ToList();
                    if (trendingAuthors != null && trendingAuthors.Any())
                    {
                        foreach (var author in trendingAuthors)
                        {
                            var authorInitial = string.IsNullOrWhiteSpace(author.Name) ? "A" : author.Name.Substring(0, 1);
                            <div class="flex flex-col items-center gap-3 group cursor-pointer flex-shrink-0 w-24">
                                <div class="w-20 h-20 rounded-full border-2 border-white/10 bg-gradient-to-br from-primary/20 to-teal-900/40 flex items-center justify-center text-2xl font-black text-white/50 group-hover:border-primary group-hover:text-primary transition-all duration-500 shadow-lg group-hover:shadow-[0_0_20px_rgba(16,185,129,0.3)] relative overflow-hidden">
                                    <span class="absolute inset-0 flex items-center justify-center">@authorInitial</span>
                                </div>
                                <span class="text-xs font-bold text-white/70 text-center group-hover:text-white transition-colors line-clamp-2">@author.Name</span>
                            </div>
                        }
                    }
                }
            </div>
        </section>
        
        <!-- Popular Books (With Reviews) -->
        <section class="mb-12">
            <div class="flex items-end justify-between mb-10 px-2">
                <div>
                     <span class="text-primary text-[10px] font-black uppercase tracking-[0.3em] mb-3 block">Top Rated</span>
                     <h2 class="text-4xl font-black text-white leading-tight">Popular Collections</h2>
                </div>
                <div class="hidden md:flex gap-4">
                    <div class="p-3 rounded-2xl bg-white/5 border border-white/10 text-white/30"><span class="material-symbols-outlined">star</span></div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 xl:grid-cols-6 gap-10">
                @if (popularBooks != null)
                {
                    foreach (var book in popularBooks)
                    {
                        var reviews = book.BookReviews ?? new List<BookReview>();
                        var avgRating = reviews.Any() ? Math.Round(reviews.Average(r => r.Rating), 1) : 0;
                        var totalReviews = reviews.Count;
                        var latestReview = reviews.OrderByDescending(r => r.CreatedAt).FirstOrDefault();
                        var latestReviewerName = latestReview?.User?.FullName ?? latestReview?.Account?.FullName ?? "Reader";
                        var latestReviewerInitial = string.IsNullOrWhiteSpace(latestReviewerName) ? "R" : latestReviewerName.Substring(0, 1);

                        <div class="group flex flex-col">
                            <!-- Premium Book Card -->
                            <div class="relative aspect-[3/4.4] rounded-[2.5rem] overflow-hidden mb-6 shadow-2xl transition-all duration-700 group-hover:-translate-y-3 group-hover:shadow-[0_40px_80px_rgba(0,0,0,0.6)]">
                                <img class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
                                     alt="@book.Title"
                                     src="@BookImageHelper.Resolve(book.ImageUrl, book.Title)"
                                     onerror="this.onerror=null;this.src='@BookImageHelper.Placeholder';" />
                                
                                <!-- Star Badge -->
                                <div class="absolute top-6 right-6 px-3 py-1.5 rounded-2xl bg-black/40 backdrop-blur-xl border border-white/10 flex items-center gap-1.5 shadow-2xl">
                                    <span class="material-symbols-outlined text-amber-400 text-sm fill-current">star</span>
                                    <span class="text-sm font-black text-white">@avgRating</span>
                                </div>

                                <!-- Hover Content: Latest Review -->
                                <div class="absolute inset-x-0 bottom-0 p-8 bg-gradient-to-t from-black via-black/90 to-transparent translate-y-full group-hover:translate-y-0 transition-transform duration-500">
                                    @if (latestReview != null)
                                    {
                                        <div class="mb-6">
                                            <div class="flex items-center gap-2 mb-3">
                                                <div class="w-6 h-6 rounded-full bg-primary/20 flex items-center justify-center text-[10px] text-primary font-bold">@latestReviewerInitial</div>
                                                <span class="text-[10px] font-black text-white/50 uppercase tracking-widest">Latest Review</span>
                                            </div>
                                            <p class="text-white text-xs italic line-clamp-3 leading-relaxed">"@latestReview.Comment"</p>
                                        </div>
                                    }
                                    <div class="flex flex-col gap-3">
                                        <a href="@Url.Action("Details", "Books", new { id = book.BookId })"
                                           class="w-full py-3 bg-white text-background-dark text-[10px] font-black rounded-xl text-center shadow-lg hover:scale-105 transition-transform block uppercase tracking-widest">
                                            View details
                                        </a>
                                        <a href="@Url.Action("Index", "Review", new { bookId = book.BookId })"
                                           class="w-full py-3 bg-primary/20 backdrop-blur-md border border-primary/30 text-primary text-[10px] font-black rounded-xl text-center shadow-lg hover:bg-primary hover:text-black transition-all block uppercase tracking-widest">
                                            Write Review
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <div class="px-3">
                                <h3 class="text-xl font-black text-white truncate group-hover:text-primary transition-colors">
                                    <a href="@Url.Action("Details", "Books", new { id = book.BookId })">@book.Title</a>
                                </h3>
                                <div class="flex items-center justify-between mt-2">
                                    <p class="text-xs text-white/40 font-bold uppercase tracking-widest">@book.Author?.Name</p>
                                    <span class="text-[10px] font-black text-white/20">@totalReviews Reviews</span>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </section>
    </div>
</div>

<style>
    .fill-current {
        font-variation-settings: 'FILL' 1;
    }
    @@keyframes blob {
        0% { transform: translate(0px, 0px) scale(1); }
        33% { transform: translate(30px, -50px) scale(1.1); }
        66% { transform: translate(-20px, 20px) scale(0.9); }
        100% { transform: translate(0px, 0px) scale(1); }
    }
    .animate-blob {
        animation: blob 20s infinite alternate;
    }
    .animation-delay-2000 {
        animation-delay: 2s;
    }
    .animation-delay-4000 {
        animation-delay: 4s;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Spotlight Carousel Logic
        const items = document.querySelectorAll('.spotlight-item');
        const dots = document.querySelectorAll('.carousel-dot');
        let currentSpotlightIndex = 0;
        let carouselInterval;

        function showSpotlight(index) {
            items.forEach((item, i) => {
                if (i === index) {
                    item.classList.remove('opacity-0', 'z-0', 'pointer-events-none');
                    item.classList.add('opacity-100', 'z-10');
                } else {
                    item.classList.remove('opacity-100', 'z-10');
                    item.classList.add('opacity-0', 'z-0', 'pointer-events-none');
                }
            });
            dots.forEach((dot, i) => {
                if (i === index) {
                    dot.classList.remove('bg-white/30', 'w-2');
                    dot.classList.add('bg-primary', 'w-6');
                } else {
                    dot.classList.remove('bg-primary', 'w-6');
                    dot.classList.add('bg-white/30', 'w-2');
                }
            });
        }

        function nextSpotlight() {
            if(items.length === 0) return;
            currentSpotlightIndex = (currentSpotlightIndex + 1) % items.length;
            showSpotlight(currentSpotlightIndex);
        }

        if(items.length > 1) {
            carouselInterval = setInterval(nextSpotlight, 3000); // 3 seconds

            // Allow clicking dots
            dots.forEach((dot, i) => {
                dot.addEventListener('click', () => {
                    clearInterval(carouselInterval);
                    currentSpotlightIndex = i;
                    showSpotlight(currentSpotlightIndex);
                    carouselInterval = setInterval(nextSpotlight, 3000);
                });
            });
            
            // Pause on hover
            const carousel = document.getElementById('spotlightCarousel');
            if(carousel) {
                carousel.addEventListener('mouseenter', () => clearInterval(carouselInterval));
                carousel.addEventListener('mouseleave', () => carouselInterval = setInterval(nextSpotlight, 3000));
            }
        }

    });
</script>
