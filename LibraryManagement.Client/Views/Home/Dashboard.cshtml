@using LibraryManagementDAL.DTO.Dashboard
@{
    ViewData["Title"] = "Librarian Dashboard";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";

    var recentUsers = ViewBag.RecentUsers as List<DashboardUserItem> ?? new List<DashboardUserItem>();
    var recentPayments = ViewBag.RecentPayments as List<DashboardPaymentItem> ?? new List<DashboardPaymentItem>();

    var monthlyLabels = ViewBag.MonthlyLabels as List<string> ?? new List<string>();
    var monthlyBorrows = ViewBag.MonthlyBorrows as List<int> ?? new List<int>();
    var monthlyReturns = ViewBag.MonthlyReturns as List<int> ?? new List<int>();
    var monthlyRegistrations = ViewBag.MonthlyRegistrations as List<int> ?? new List<int>();

    var categoryLabels = ViewBag.CategoryLabels as List<string> ?? new List<string>();
    var categoryCounts = ViewBag.CategoryCounts as List<int> ?? new List<int>();

    var bookStatusLabels = ViewBag.BookStatusLabels as List<string> ?? new List<string>();
    var bookStatusCounts = ViewBag.BookStatusCounts as List<int> ?? new List<int>();
}

<div class="flex-1 p-8 min-w-0 overflow-y-auto custom-scrollbar">

    @if (ViewBag.DashboardDataError != null)
    {
        <div class="mb-6 rounded-2xl border border-red-500/20 bg-red-500/10 px-5 py-4 text-sm font-bold text-red-300">
            @ViewBag.DashboardDataError
        </div>
    }

    <div class="mb-10 flex justify-between items-end">
        <div>
            <h1 class="text-4xl font-extrabold text-white tracking-tight mb-2">
                Good afternoon, <span class="text-primary">@User.Identity?.Name</span> 📚
            </h1>
            <p class="text-white/50 text-lg">Here is your librarian operational overview.</p>
        </div>
        <div class="text-right">
            <p class="text-[10px] font-bold text-white/40 uppercase tracking-widest mb-1">System Status</p>
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-xs font-bold">
                <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                All Systems Operational
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-8 mb-12">
        <div class="bg-black/20 border border-white/10 p-8 rounded-[2rem] flex flex-col shadow-2xl relative overflow-hidden group">
            <div class="absolute -right-20 -top-20 w-80 h-80 bg-primary/5 rounded-full blur-[100px] pointer-events-none"></div>

            <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-8 relative z-10">
                <div>
                    <h3 class="text-2xl font-black text-white flex items-center gap-3">
                        <span class="material-symbols-outlined text-primary p-2 bg-primary/10 rounded-xl">auto_graph</span>
                        Library Growth & Activity
                    </h3>
                    <p class="text-white/40 text-sm mt-1">
                        Monthly comparison of new member registrations and borrowing transactions.
                    </p>
                </div>
                <div class="flex items-center gap-6">
                    <div class="flex flex-col items-end">
                        <p class="text-[10px] font-bold text-white/30 uppercase tracking-widest">Active Transactions</p>
                        <p class="text-xl font-black text-white">@(((int?)ViewBag.TotalTransactions ?? 0).ToString("N0"))</p>
                    </div>
                    <div class="w-px h-10 bg-white/10"></div>
                    <div class="flex flex-col items-end">
                        <p class="text-[10px] font-bold text-white/30 uppercase tracking-widest">Global Users</p>
                        <p class="text-xl font-black text-white">@(((int?)ViewBag.TotalUsers ?? 0).ToString("N0"))</p>
                    </div>
                </div>
            </div>

            <div class="flex-1 w-full h-[350px] relative">
                <canvas id="performanceChart"></canvas>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
        <div class="lg:col-span-2 bg-black/20 border border-white/10 p-6 rounded-3xl flex flex-col shadow-2xl relative">
            <h3 class="text-lg font-bold text-white mb-6 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">published_with_changes</span>
                Circulation: Borrows vs Returns
            </h3>
            <div class="flex-1 w-full h-[300px] relative">
                <canvas id="borrowChart"></canvas>
            </div>
        </div>

        <div class="bg-black/20 border border-white/10 p-6 rounded-3xl flex flex-col shadow-2xl relative">
            <h3 class="text-lg font-bold text-white mb-6 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">donut_large</span>
                Books by Category
            </h3>
            <div class="flex-1 w-full h-[300px] relative flex justify-center items-center">
                <canvas id="categoryChart"></canvas>
            </div>
        </div>

        <div class="bg-black/20 border border-white/10 p-6 rounded-3xl flex flex-col shadow-2xl relative">
            <h3 class="text-lg font-bold text-white mb-6 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">analytics</span>
                Book Status Distribution
            </h3>
            <div class="flex-1 w-full h-[300px] relative flex justify-center items-center">
                <canvas id="statusChart"></canvas>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

        <div class="bg-white/5 border border-white/10 rounded-3xl flex flex-col shadow-2xl overflow-hidden">
            <div class="p-6 border-b border-white/5 flex items-center justify-between">
                <h3 class="text-lg font-bold text-white flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">person_add</span>
                    Newest Registrations
                </h3>
            </div>
            <div class="p-6 flex-1">
                <div class="flex flex-col gap-4">
                    @foreach (var u in recentUsers)
                    {
                        <div class="flex items-center gap-4 group">
                            <div class="w-10 h-10 rounded-full bg-white/10 border border-white/20 flex items-center justify-center text-white font-bold text-sm shadow-inner group-hover:bg-primary/20 group-hover:text-primary transition-all">
                                @(u.FullName?[0].ToString() ?? "?")
                            </div>
                            <div>
                                <h4 class="text-sm font-bold text-white group-hover:text-primary transition-colors">@u.FullName</h4>
                                <p class="text-[10px] text-white/40 font-mono">@u.Email</p>
                            </div>
                            <div class="ml-auto text-right">
                                <p class="text-[10px] font-bold text-white/60">@u.CreatedAt.ToString("MMM dd")</p>
                                <p class="text-[9px] text-white/30 uppercase">Joined</p>
                            </div>
                        </div>
                    }

                    @if (!recentUsers.Any())
                    {
                        <p class="text-sm text-white/30 text-center italic py-4">No users found.</p>
                    }
                </div>
            </div>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-3xl flex flex-col shadow-2xl overflow-hidden">
            <div class="p-6 border-b border-white/5 flex items-center justify-between">
                <h3 class="text-lg font-bold text-white flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">receipt_long</span>
                    Recent Fine Settlements
                </h3>
            </div>
            <div class="p-6 flex-1">
                <div class="flex flex-col gap-4">
                    @foreach (var p in recentPayments)
                    {
                        <div class="flex items-center gap-4 group">
                            <div class="w-10 h-10 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 shadow-inner group-hover:bg-emerald-500 group-hover:text-background-dark transition-all">
                                <span class="material-symbols-outlined text-[18px]">payments</span>
                            </div>
                            <div>
                                <h4 class="text-sm font-bold text-white group-hover:text-emerald-400 transition-colors">@p.Amount.ToString("N0") đ</h4>
                                <p class="text-[10px] text-white/40 font-mono">@p.UserFullName</p>
                            </div>
                            <div class="ml-auto text-right">
                                <p class="text-[10px] font-bold text-white/60">@(p.PaidAt?.ToString("MMM dd") ?? p.CreatedAt.ToString("MMM dd"))</p>
                                <span class="text-[9px] font-black uppercase text-emerald-400 bg-emerald-500/10 px-1.5 py-0.5 rounded border border-emerald-500/20">
                                    Paid
                                </span>
                            </div>
                        </div>
                    }

                    @if (!recentPayments.Any())
                    {
                        <p class="text-sm text-white/30 text-center italic py-4">No recent payments.</p>
                    }
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            Chart.defaults.color = 'rgba(255, 255, 255, 0.4)';
            Chart.defaults.font.family = "'Inter', sans-serif";

            const perfLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(monthlyLabels));
            const borrowActivityData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(monthlyBorrows));
            const userData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(monthlyRegistrations));

            const ctxPerf = document.getElementById('performanceChart').getContext('2d');

            new Chart(ctxPerf, {
                type: 'bar',
                data: {
                    labels: perfLabels,
                    datasets: [
                        {
                            label: 'New Members',
                            data: userData,
                            backgroundColor: 'rgba(234, 179, 8, 0.4)',
                            borderColor: '#eab308',
                            borderWidth: 2,
                            borderRadius: 12,
                            yAxisID: 'yUsers',
                        },
                        {
                            label: 'Borrowing Activity',
                            data: borrowActivityData,
                            type: 'line',
                            borderColor: '#3b82f6',
                            backgroundColor: 'transparent',
                            borderWidth: 4,
                            pointBackgroundColor: '#3b82f6',
                            pointRadius: 6,
                            tension: 0.4,
                            yAxisID: 'yActivity',
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top', align: 'end' },
                        tooltip: { backgroundColor: 'rgba(0,0,0,0.8)', padding: 12 }
                    },
                    scales: {
                        yActivity: {
                            type: 'linear',
                            position: 'left',
                            grid: { color: 'rgba(255,255,255,0.05)' },
                            ticks: { precision: 0 }
                        },
                        yUsers: {
                            type: 'linear',
                            position: 'right',
                            grid: { display: false },
                            ticks: { precision: 0 }
                        },
                        x: {
                            grid: { display: false }
                        }
                    }
                }
            });

            const circLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(monthlyLabels));
            const circBorrowData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(monthlyBorrows));
            const circReturnData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(monthlyReturns));

            const ctxCirc = document.getElementById('borrowChart').getContext('2d');

            new Chart(ctxCirc, {
                type: 'line',
                data: {
                    labels: circLabels,
                    datasets: [
                        {
                            label: 'Borrows',
                            data: circBorrowData,
                            borderColor: '#3b82f6',
                            backgroundColor: 'rgba(59, 130, 246, 0.1)',
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3,
                            pointRadius: 4
                        },
                        {
                            label: 'Returns',
                            data: circReturnData,
                            borderColor: '#10b981',
                            backgroundColor: 'rgba(16, 185, 129, 0.1)',
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3,
                            pointRadius: 4
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top', align: 'end' }
                    },
                    scales: {
                        y: {
                            grid: { color: 'rgba(255,255,255,0.05)' },
                            ticks: { precision: 0 }
                        },
                        x: {
                            grid: { display: false }
                        }
                    }
                }
            });

            const catLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(categoryLabels));
            const catData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(categoryCounts));

            const ctxCategory = document.getElementById('categoryChart').getContext('2d');

            const dynamicColors = [
                '#eab308',
                '#3b82f6',
                '#10b981',
                '#a855f7',
                '#ec4899',
                '#f97316',
                '#14b8a6',
                '#64748b'
            ];

            new Chart(ctxCategory, {
                type: 'doughnut',
                data: {
                    labels: catLabels,
                    datasets: [{
                        data: catData,
                        backgroundColor: dynamicColors,
                        borderWidth: 2,
                        borderColor: '#1e293b',
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%',
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 20,
                                usePointStyle: true,
                                pointStyle: 'circle'
                            }
                        },
                        tooltip: {
                            backgroundColor: 'rgba(0,0,0,0.8)',
                            padding: 12,
                            cornerRadius: 8,
                        }
                    }
                }
            });

            const statusLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(bookStatusLabels));
            const statusData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(bookStatusCounts));

            const ctxStatus = document.getElementById('statusChart').getContext('2d');

            const statusColors = [
                '#10b981',
                '#3b82f6',
                '#f59e0b',
                '#f43f5e',
                '#ef4444'
            ];

            new Chart(ctxStatus, {
                type: 'doughnut',
                data: {
                    labels: statusLabels,
                    datasets: [{
                        data: statusData,
                        backgroundColor: statusColors.slice(0, statusLabels.length),
                        borderWidth: 2,
                        borderColor: '#1e293b',
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%',
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 20,
                                usePointStyle: true,
                                pointStyle: 'circle'
                            }
                        },
                        tooltip: {
                            backgroundColor: 'rgba(0,0,0,0.8)',
                            padding: 12,
                            cornerRadius: 8,
                        }
                    }
                }
            });

        });
    </script>
}