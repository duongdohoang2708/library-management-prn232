@model LibraryManagement.Client.DTO.Auth.ChangePasswordRequestDto
@{
    ViewData["Title"] = "Change Password - LMS Library";
    ViewData["Description"] = "Secure your account by updating your password";
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
}

<!-- Left Branding Panel -->
<div class="hidden lg:flex flex-col justify-between w-[45%] p-12 relative overflow-hidden border-r border-white/5">
    <!-- Top logo -->
    <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center shadow-lg shadow-primary/30">
            <span class="material-symbols-outlined text-background-dark text-xl font-bold">shield</span>
        </div>
        <span class="text-white font-bold text-lg tracking-tight">Standard Library</span>
    </div>

    <!-- Center Illustration -->
    <div class="flex flex-col items-center text-center">
        <!-- Decorative visual -->
        <div class="relative mb-10">
            <div class="w-48 h-48 rounded-3xl bg-white/5 border border-white/10 flex items-center justify-center shadow-2xl shadow-black/50">
                <span class="material-symbols-outlined text-[96px] text-primary/80">lock_reset</span>
            </div>
            <!-- Floating badges -->
            <div class="absolute -top-4 -right-4 bg-primary text-background-dark text-xs font-black px-3 py-1.5 rounded-xl shadow-lg shadow-primary/30 flex items-center gap-1.5">
                <span class="material-symbols-outlined text-sm">enhanced_encryption</span>
                Secure
            </div>
        </div>

        <h1 class="text-3xl font-black text-white mb-4 leading-tight">
            Protect your<br/>
            <span class="text-primary">Account</span>
        </h1>
        <p class="text-white/50 text-sm leading-relaxed max-w-xs">
            We recommend updating your password regularly to ensure the safety of your personal information.
        </p>
    </div>
    
    <div></div> <!-- Spacer -->
</div>

<!-- Right Form Panel -->
<div class="flex-1 flex flex-col justify-center items-center p-8 lg:p-16">

    <div class="w-full max-w-md">

        <!-- Header -->
        <div class="mb-8">
            <h2 class="text-3xl font-black text-white mb-2">Change Password</h2>
            <p class="text-white/50 text-sm">Enter your current password and choose a new one.</p>
        </div>

        <!-- Success Message -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="mb-5 flex items-center gap-3 bg-emerald-500/10 border border-emerald-500/20 rounded-xl px-4 py-3 text-emerald-400 text-sm">
                <span class="material-symbols-outlined text-lg">check_circle</span>
                @TempData["SuccessMessage"]
            </div>
        }

        <!-- Validation Summary -->
        @{
            var hasErrors = ViewContext.ModelState.Values.Any(v => v.Errors.Any());
        }
        @if (hasErrors)
        {
            <div class="mb-5 flex items-start gap-3 bg-red-500/10 border border-red-500/20 rounded-xl px-4 py-3 text-red-400 text-sm">
                <span class="material-symbols-outlined text-lg flex-shrink-0 mt-0.5">error</span>
                <div>
                    @foreach (var state in ViewContext.ModelState.Values)
                    {
                        foreach (var error in state.Errors)
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    }
                </div>
            </div>
        }

        <!-- Change Password Form -->
        <form asp-action="ChangePassword" asp-controller="Auth" method="post" id="changePasswordForm" class="space-y-5">
            @Html.AntiForgeryToken()

            <!-- Current Password -->
            <div>
                <label asp-for="CurrentPassword" class="block text-sm font-semibold text-white/70 mb-2">
                    Current Password
                </label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-white/30 text-lg pointer-events-none">lock</span>
                    <input asp-for="CurrentPassword"
                           type="password"
                           id="currentPasswordInput"
                           class="auth-input !pl-12 !pr-12"
                           placeholder="••••••••"
                           autofocus />
                </div>
                <span asp-validation-for="CurrentPassword" class="field-error"></span>
            </div>

            <!-- New Password -->
            <div>
                <label asp-for="NewPassword" class="block text-sm font-semibold text-white/70 mb-2">
                    New Password
                </label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-white/30 text-lg pointer-events-none">lock_open</span>
                    <input asp-for="NewPassword"
                           type="password"
                           id="newPasswordInput"
                           class="auth-input !pl-12 !pr-12"
                           placeholder="••••••••" />
                </div>
                <span asp-validation-for="NewPassword" class="field-error"></span>
            </div>

            <!-- Confirm New Password -->
            <div>
                <label asp-for="ConfirmNewPassword" class="block text-sm font-semibold text-white/70 mb-2">
                    Confirm New Password
                </label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-white/30 text-lg pointer-events-none">lock_clock</span>
                    <input asp-for="ConfirmNewPassword"
                           type="password"
                           id="confirmNewPasswordInput"
                           class="auth-input !pl-12 !pr-12"
                           placeholder="••••••••" />
                </div>
                <span asp-validation-for="ConfirmNewPassword" class="field-error"></span>
            </div>

            <!-- Submit -->
            <button type="submit" id="submitBtn" class="btn-primary-auth flex items-center justify-center gap-2 mt-4">
                <span id="btnIcon" class="material-symbols-outlined text-lg">save</span>
                <span id="btnText">Save Password</span>
            </button>
            
            <div class="text-center mt-6">
                <a href="/" class="text-white/40 hover:text-primary transition-colors text-sm flex items-center justify-center gap-1">
                    <span class="material-symbols-outlined text-sm">arrow_back</span>
                    Back to Dashboard
                </a>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.getElementById('changePasswordForm').addEventListener('submit', function () {
            const btn = document.getElementById('submitBtn');
            const icon = document.getElementById('btnIcon');
            const btnText = document.getElementById('btnText');
            btn.disabled = true;
            btn.classList.add('opacity-80');
            icon.textContent = 'progress_activity';
            icon.classList.add('animate-spin');
            btnText.textContent = "Processing...";
        });
    </script>
}
