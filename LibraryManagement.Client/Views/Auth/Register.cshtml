@model LibraryManagement.Client.DTO.Auth.RegisterRequestDto
@{
    ViewData["Title"] = "Register - LMS Library";
    ViewData["Description"] = "Create a new account on the LMS library system";
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
    int currentStep = 1;
}

<!-- Left Branding Panel -->
<div class="hidden lg:flex flex-col justify-between w-[40%] p-12 relative overflow-hidden border-r border-white/5">

    <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center shadow-lg shadow-primary/30">
            <span class="material-symbols-outlined text-background-dark text-xl">menu_book</span>
        </div>
        <span class="text-white font-bold text-lg tracking-tight">Standard Library</span>
    </div>

    <div class="flex flex-col">
        <h1 class="text-3xl font-black text-white mb-4 leading-tight">
            Join the community of<br/>
            <span class="text-primary">smart readers</span>
        </h1>
        <p class="text-white/50 text-sm leading-relaxed mb-10">
            Thousands of readers are enjoying our massive book collection. Register now and start your journey.
        </p>

        <!-- Feature list -->
        <div class="space-y-4">
            @foreach (var feat in new[] {
                ("auto_stories", "Access 500K+ books for free"),
                ("history", "Track your borrowing history"),
                ("notifications_active", "Get new book notifications"),
                ("group", "Join the reader community"),
            })
            {
                <div class="flex items-center gap-3 text-sm">
                    <div class="w-8 h-8 rounded-lg bg-primary/10 border border-primary/20 flex items-center justify-center flex-shrink-0">
                        <span class="material-symbols-outlined text-primary text-base">@feat.Item1</span>
                    </div>
                    <span class="text-white/70">@feat.Item2</span>
                </div>
            }
        </div>
    </div>

    <!-- Testimonial -->
    <div class="glass-card rounded-2xl p-5">
        <div class="flex items-center gap-1 text-primary mb-2">
            @for (int i = 0; i < 5; i++) { <span class="material-symbols-outlined text-sm fill-1">star</span> }
        </div>
        <p class="text-white/70 text-xs leading-relaxed italic mb-3">
            "The best library system I've ever used. Fast search, beautiful interface!"
        </p>
        <div class="flex items-center gap-2">
            <div class="w-7 h-7 rounded-full bg-primary/20 border border-primary/30 flex items-center justify-center">
                <span class="text-primary text-xs font-bold">T</span>
            </div>
            <div>
                <div class="text-white/80 text-xs font-semibold">Minh Khoa Tran</div>
                <div class="text-white/30 text-[10px]">Member since 2024</div>
            </div>
        </div>
    </div>
</div>

<!-- Right Form Panel -->
<div class="flex-1 flex flex-col justify-center items-center p-8 lg:p-12 overflow-y-auto custom-scrollbar">
    <div class="w-full max-w-lg">

        <!-- Mobile logo -->
        <div class="flex items-center gap-3 mb-8 lg:hidden">
            <div class="w-9 h-9 bg-primary rounded-xl flex items-center justify-center">
                <span class="material-symbols-outlined text-background-dark text-lg">menu_book</span>
            </div>
            <span class="text-white font-bold">Standard Library</span>
        </div>

        <!-- Header -->
        <div class="mb-8">
            <h2 class="text-2xl font-black text-white mb-1">Create new account</h2>
            <p class="text-white/40 text-sm">Fill in your details to start using the library</p>
        </div>

        <!-- Validation Errors -->
        @if (ViewContext.ModelState.Values.Any(v => v.Errors.Any()))
        {
            <div class="mb-6 flex items-start gap-3 bg-red-500/10 border border-red-500/20 rounded-xl px-4 py-3 text-red-400 text-sm">
                <span class="material-symbols-outlined text-lg flex-shrink-0 mt-0.5">error</span>
                <div>
                    @foreach (var state in ViewContext.ModelState.Values)
                    {
                        foreach (var error in state.Errors)
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    }
                </div>
            </div>
        }

        <!-- Form -->
        <form asp-action="Register" asp-controller="Auth" method="post" id="registerForm" novalidate class="space-y-5">
            @Html.AntiForgeryToken()

            <!-- Row 1: Username + FullName -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-semibold text-white/60 mb-2 uppercase tracking-wider">
                        Username <span class="text-red-400">*</span>
                    </label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3.5 top-1/2 -translate-y-1/2 text-white/25 text-base pointer-events-none">badge</span>
                        <input asp-for="Username"
                               class="auth-input !pl-11"
                               placeholder="vd: nguyenvana"
                               autocomplete="username" />
                    </div>
                    <span asp-validation-for="Username" class="field-error"></span>
                </div>

                <div>
                    <label class="block text-xs font-semibold text-white/60 mb-2 uppercase tracking-wider">
                        Full Name <span class="text-red-400">*</span>
                    </label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3.5 top-1/2 -translate-y-1/2 text-white/25 text-base pointer-events-none">person</span>
                        <input asp-for="FullName"
                               class="auth-input !pl-11"
                               placeholder="Nguyễn Văn A"
                               autocomplete="name" />
                    </div>
                    <span asp-validation-for="FullName" class="field-error"></span>
                </div>
            </div>

            <!-- Email -->
            <div>
                <label class="block text-xs font-semibold text-white/60 mb-2 uppercase tracking-wider">
                    Email <span class="text-red-400">*</span>
                </label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3.5 top-1/2 -translate-y-1/2 text-white/25 text-base pointer-events-none">alternate_email</span>
                    <input asp-for="Email"
                           class="auth-input !pl-11"
                           placeholder="your@email.com"
                           autocomplete="email" />
                </div>
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <!-- Row 2: Password + Confirm -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-semibold text-white/60 mb-2 uppercase tracking-wider">
                        Password <span class="text-red-400">*</span>
                    </label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3.5 top-1/2 -translate-y-1/2 text-white/25 text-base pointer-events-none">lock</span>
                        <input asp-for="Password"
                               id="regPassword"
                               type="password"
                               class="auth-input !pl-11 !pr-10"
                               placeholder="Tối thiểu 6 ký tự"
                               autocomplete="new-password"
                               oninput="checkPasswordStrength(this.value)" />
                        <button type="button" onclick="togglePwd('regPassword','regPwdIcon')"
                                class="absolute right-3 top-1/2 -translate-y-1/2 text-white/25 hover:text-white/60 transition-colors">
                            <span class="material-symbols-outlined text-base" id="regPwdIcon">visibility_off</span>
                        </button>
                    </div>
                    <!-- Password strength -->
                    <div class="mt-2 flex gap-1" id="strengthBars">
                        <div class="h-1 flex-1 rounded-full bg-white/10 strength-bar" id="bar1"></div>
                        <div class="h-1 flex-1 rounded-full bg-white/10 strength-bar" id="bar2"></div>
                        <div class="h-1 flex-1 rounded-full bg-white/10 strength-bar" id="bar3"></div>
                        <div class="h-1 flex-1 rounded-full bg-white/10 strength-bar" id="bar4"></div>
                    </div>
                    <p class="text-white/30 text-xs mt-1" id="strengthLabel"></p>
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>

                <div>
                    <label class="block text-xs font-semibold text-white/60 mb-2 uppercase tracking-wider">
                        Confirm Password <span class="text-red-400">*</span>
                    </label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3.5 top-1/2 -translate-y-1/2 text-white/25 text-base pointer-events-none">lock_check</span>
                        <input asp-for="ConfirmPassword"
                               id="confirmPassword"
                               type="password"
                               class="auth-input !pl-11 !pr-10"
                               placeholder="Nhập lại mật khẩu"
                               autocomplete="new-password"
                               oninput="checkConfirmMatch()" />
                        <button type="button" onclick="togglePwd('confirmPassword','confirmPwdIcon')"
                                class="absolute right-3 top-1/2 -translate-y-1/2 text-white/25 hover:text-white/60 transition-colors">
                            <span class="material-symbols-outlined text-base" id="confirmPwdIcon">visibility_off</span>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="field-error"></span>
                </div>
            </div>

            <!-- Row 3: Phone + DOB -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-semibold text-white/60 mb-2 uppercase tracking-wider">Phone Number</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3.5 top-1/2 -translate-y-1/2 text-white/25 text-base pointer-events-none">phone</span>
                        <input asp-for="Phone"
                               class="auth-input !pl-11"
                               placeholder="0901234567"
                               autocomplete="tel" />
                    </div>
                    <span asp-validation-for="Phone" class="field-error"></span>
                </div>

                <div>
                    <label class="block text-xs font-semibold text-white/60 mb-2 uppercase tracking-wider">Date of Birth</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3.5 top-1/2 -translate-y-1/2 text-white/25 text-base pointer-events-none z-10">cake</span>
                        <input asp-for="DateOfBirth"
                               type="date"
                               class="auth-input !pl-11"
                               style="color-scheme: dark;" />
                    </div>
                    <span asp-validation-for="DateOfBirth" class="field-error"></span>
                </div>
            </div>

            <!-- Address -->
            <div>
                <label class="block text-xs font-semibold text-white/60 mb-2 uppercase tracking-wider">Address</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3.5 top-1/2 -translate-y-1/2 text-white/25 text-base pointer-events-none">location_on</span>
                    <input asp-for="Address"
                           class="auth-input !pl-11"
                           placeholder="123 Đường ABC, Quận XYZ, TP.HCM"
                           autocomplete="street-address" />
                </div>
                <span asp-validation-for="Address" class="field-error"></span>
            </div>

            <!-- Terms -->
            <div class="flex items-start gap-3 pt-1">
                <input type="checkbox" id="agreeTerms" required
                       class="w-4 h-4 rounded border-white/20 bg-white/5 text-primary focus:ring-primary/40 cursor-pointer mt-0.5 flex-shrink-0" />
                <label for="agreeTerms" class="text-sm text-white/50 cursor-pointer leading-relaxed">
                    I agree to the
                    <a href="#" class="text-primary hover:underline">Terms of Service</a>
                    and
                    <a href="#" class="text-primary hover:underline">Privacy Policy</a>
                    of Standard Library
                </label>
            </div>

            <!-- Submit -->
            <button type="submit" id="registerSubmitBtn" class="btn-primary-auth flex items-center justify-center gap-2 mt-2">
                <span id="regBtnIcon" class="material-symbols-outlined text-lg">person_add</span>
                <span id="regBtnText">Create Account</span>
            </button>
        </form>

        <!-- Login link -->
        <p class="text-center text-white/40 text-sm mt-6">
            Already have an account?
            <a asp-action="Login" asp-controller="Auth"
               class="text-primary font-semibold hover:text-primary/80 transition-colors ml-1">
                Log in now
            </a>
        </p>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Toggle password visibility
        function togglePwd(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.textContent = 'visibility';
            } else {
                input.type = 'password';
                icon.textContent = 'visibility_off';
            }
        }

        // Password strength meter
        function checkPasswordStrength(value) {
            const bars = [document.getElementById('bar1'), document.getElementById('bar2'),
                          document.getElementById('bar3'), document.getElementById('bar4')];
            const label = document.getElementById('strengthLabel');
            let score = 0;
            if (value.length >= 6) score++;
            if (value.length >= 10) score++;
            if (/[A-Z]/.test(value) && /[a-z]/.test(value)) score++;
            if (/[0-9]/.test(value) && /[^A-Za-z0-9]/.test(value)) score++;

            const colors = ['bg-red-500', 'bg-orange-500', 'bg-yellow-500', 'bg-emerald-500'];
            const labels = ['', 'Yếu', 'Trung bình', 'Khá mạnh', 'Mạnh'];
            const labelColors = ['', 'text-red-400', 'text-orange-400', 'text-yellow-400', 'text-emerald-400'];

            bars.forEach((bar, i) => {
                bar.className = 'h-1 flex-1 rounded-full transition-all duration-300';
                if (i < score) bar.classList.add(colors[score - 1]);
                else bar.classList.add('bg-white/10');
            });
            label.textContent = labels[score];
            label.className = `text-xs mt-1 transition-colors ${labelColors[score]}`;
        }

        // Check confirm password match
        function checkConfirmMatch() {
            const pwd = document.getElementById('regPassword').value;
            const confirm = document.getElementById('confirmPassword');
            if (confirm.value && confirm.value !== pwd) {
                confirm.classList.add('border-red-500/50');
                confirm.classList.remove('border-white/10');
            } else {
                confirm.classList.remove('border-red-500/50');
                confirm.classList.add('border-white/10');
            }
        }

        // Terms checkbox enforcement
        document.getElementById('registerForm').addEventListener('submit', function (e) {
            if (!document.getElementById('agreeTerms').checked) {
                e.preventDefault();
                const msg = document.getElementById('termsError') || document.createElement('p');
                msg.id = 'termsError';
                msg.className = 'text-red-400 text-xs mt-1 flex items-center gap-1';
                msg.innerHTML = '<span class="material-symbols-outlined text-xs">warning</span> Bạn cần đồng ý với điều khoản sử dụng';
                document.getElementById('agreeTerms').closest('div').appendChild(msg);
                return;
            }
            // Loading state
            const btn = document.getElementById('registerSubmitBtn');
            const icon = document.getElementById('regBtnIcon');
            const text = document.getElementById('regBtnText');
            btn.disabled = true;
            btn.classList.add('opacity-80');
            icon.textContent = 'progress_activity';
            icon.classList.add('animate-spin');
            text.textContent = 'Đang tạo tài khoản...';
        });
    </script>
}
