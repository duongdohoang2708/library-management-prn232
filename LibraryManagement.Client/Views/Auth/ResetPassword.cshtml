@model LibraryManagementDAL.DTO.Auth.ResetPasswordRequestDto
@{
    ViewData["Title"] = "Reset Password - LMS Library";
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
}

<!-- Left Branding Panel -->
<div class="hidden lg:flex flex-col justify-between w-[45%] p-12 relative overflow-hidden border-r border-white/5">
    <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center shadow-lg shadow-primary/30">
            <span class="material-symbols-outlined text-background-dark text-xl font-bold">shield</span>
        </div>
        <span class="text-white font-bold text-lg tracking-tight">Standard Library</span>
    </div>

    <div class="flex flex-col items-center text-center">
        <div class="relative mb-10">
            <div class="w-48 h-48 rounded-3xl bg-white/5 border border-white/10 flex items-center justify-center shadow-2xl shadow-black/50">
                <span class="material-symbols-outlined text-[96px] text-primary/80">key</span>
            </div>
        </div>
        <h1 class="text-3xl font-black text-white mb-4 leading-tight">
            Set your new <br/>
            <span class="text-primary">Password</span>
        </h1>
        <p class="text-white/50 text-sm leading-relaxed max-w-xs">
            Almost there! Create a strong password to secure your account.
        </p>
    </div>
    <div></div>
</div>

<!-- Right Form Panel -->
<div class="flex-1 flex flex-col justify-center items-center p-8 lg:p-16">
    <div class="w-full max-w-md">

        <!-- Header -->
        <div class="mb-8">
            <h2 class="text-3xl font-black text-white mb-2">Reset Password</h2>
            <p class="text-white/50 text-sm">Please choose a strong, new password.</p>
        </div>

        <!-- Validation Summary -->
        @{ var hasErrors = ViewContext.ModelState.Values.Any(v => v.Errors.Any()); }
        @if (hasErrors)
        {
            <div class="mb-5 flex items-start gap-3 bg-red-500/10 border border-red-500/20 rounded-xl px-4 py-3 text-red-400 text-sm">
                <span class="material-symbols-outlined text-lg flex-shrink-0 mt-0.5">error</span>
                <div>
                    @foreach (var state in ViewContext.ModelState.Values)
                    {
                        foreach (var error in state.Errors)
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    }
                </div>
            </div>
        }

        <!-- Error Summary (from Controller) -->
        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>

        <!-- Reset Password Form -->
        <form asp-action="ResetPassword" asp-controller="Auth" method="post" id="resetPasswordForm" class="space-y-5">
            @Html.AntiForgeryToken()

            <!-- Hidden Fields required for reset -->
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Token" />

            <div>
                <label asp-for="NewPassword" class="block text-sm font-semibold text-white/70 mb-2">New Password</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-white/30 text-lg pointer-events-none">lock</span>
                    <input asp-for="NewPassword" type="password" class="auth-input !pl-12 !pr-10" placeholder="••••••••" autofocus />
                    <button type="button" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/30 hover:text-white transition-colors" onclick="togglePassword(this)">
                        <span class="material-symbols-outlined text-[18px]">visibility</span>
                    </button>
                </div>
                <span asp-validation-for="NewPassword" class="field-error"></span>
            </div>

            <div>
                <label asp-for="ConfirmNewPassword" class="block text-sm font-semibold text-white/70 mb-2">Confirm New Password</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-white/30 text-lg pointer-events-none">verified_user</span>
                    <input asp-for="ConfirmNewPassword" type="password" class="auth-input !pl-12 !pr-10" placeholder="••••••••" />
                    <button type="button" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/30 hover:text-white transition-colors" onclick="togglePassword(this)">
                        <span class="material-symbols-outlined text-[18px]">visibility</span>
                    </button>
                </div>
                <span asp-validation-for="ConfirmNewPassword" class="field-error"></span>
            </div>

            <button type="submit" id="submitBtn" class="btn-primary-auth flex items-center justify-center gap-2 mt-4">
                <span id="btnIcon" class="material-symbols-outlined text-lg">save</span>
                <span id="btnText">Save New Password</span>
            </button>
            
        </form>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function togglePassword(btn) {
            const input = btn.previousElementSibling;
            const icon = btn.querySelector('span');
            if (input.type === 'password') {
                input.type = 'text';
                icon.textContent = 'visibility_off';
            } else {
                input.type = 'password';
                icon.textContent = 'visibility';
            }
        }

        document.getElementById('resetPasswordForm').addEventListener('submit', function () {
            const btn = document.getElementById('submitBtn');
            const icon = document.getElementById('btnIcon');
            const btnText = document.getElementById('btnText');
            btn.disabled = true;
            btn.classList.add('opacity-80');
            icon.textContent = 'progress_activity';
            icon.classList.add('animate-spin');
            btnText.textContent = "Processing...";
        });
    </script>
}
