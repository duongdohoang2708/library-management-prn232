@model List<BookReview>
@using LibraryManagementDAL.Models
@using System.Security.Claims
@{
    var book = ViewBag.Book as Book;
    var userReview = ViewBag.UserReview as BookReview;
    var userIdClaim = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    bool isAuthenticated = !string.IsNullOrEmpty(userIdClaim);
    
    ViewData["Title"] = $"Reviews - {book?.Title}";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="flex-1 flex flex-col min-w-0 overflow-y-auto custom-scrollbar bg-[#0A0F1E] pb-20">
    
    <!-- Header Section -->
    <div class="relative h-[250px] w-full overflow-hidden mb-10">
        <div class="absolute inset-0 z-0">
            <img src="@(string.IsNullOrEmpty(book.ImageUrl) ? "https://images.unsplash.com/photo-1543005139-ed1fbede6f0b?q=80&w=1000&auto=format&fit=crop" : book.ImageUrl)" 
                 class="w-full h-full object-cover blur-2xl opacity-20 scale-110" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#0A0F1E] via-transparent to-transparent"></div>
        </div>

        <div class="relative z-10 h-full max-w-5xl mx-auto px-8 flex items-end pb-10">
            <div class="flex gap-8 items-center">
                <div class="w-32 h-44 rounded-2xl overflow-hidden shadow-2xl flex-shrink-0 border border-white/10">
                    <img src="@(string.IsNullOrEmpty(book.ImageUrl) ? "https://images.unsplash.com/photo-1543005139-ed1fbede6f0b?q=80&w=1000&auto=format&fit=crop" : book.ImageUrl)" 
                         class="w-full h-full object-cover" />
                </div>
                <div>
                     <nav class="flex mb-4 text-xs font-bold text-white/30 uppercase tracking-widest gap-2">
                        <a asp-controller="Home" asp-action="Index" class="hover:text-primary transition-colors">Home</a>
                        <span>/</span>
                        <a asp-controller="Books" asp-action="Details" asp-route-id="@book.BookId" class="hover:text-primary transition-colors">Details</a>
                        <span>/</span>
                        <span class="text-white/60">Reviews</span>
                    </nav>
                    <h1 class="text-4xl font-black text-white leading-tight mb-2">@book.Title</h1>
                    <p class="text-primary font-bold">by @book.Author?.Name</p>
                </div>
            </div>
        </div>
    </div>

    <div class="max-w-5xl mx-auto w-full px-8 grid grid-cols-1 lg:grid-cols-3 gap-12">
        
        <!-- Review Submission Form -->
        <div class="lg:col-span-1">
            <div class="sticky top-10 p-8 rounded-[2.5rem] bg-white/5 border border-white/10 backdrop-blur-xl h-fit shadow-2xl">
                @if (isAuthenticated)
                {
                    <h2 class="text-xl font-black text-white mb-2">@(userReview != null ? "Your Review" : "Write a Review")</h2>
                    <p class="text-white/40 text-xs mb-8">Tell us what you think about this book.</p>

                    <form asp-action="SubmitReview" method="post" class="space-y-6">
                        <input type="hidden" name="bookId" value="@book.BookId" />
                        
                        <div>
                            <label class="block text-[10px] font-black text-white/40 uppercase tracking-widest mb-4 text-center">Select Stars</label>
                            <div class="flex justify-center gap-2" id="star-rating">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    var currentRating = userReview?.Rating ?? 5;
                                    <button type="button" onclick="setRating(@i)" class="star-btn p-1 transition-all hover:scale-125" data-value="@i">
                                        <span class="material-symbols-outlined star-icon text-3xl @(i <= currentRating ? "text-amber-400 fill-current" : "text-white/20")">star</span>
                                    </button>
                                }
                                <input type="hidden" name="rating" id="rating-input" value="@(userReview?.Rating ?? 5)" />
                            </div>
                        </div>

                        <div>
                            <textarea name="comment" 
                                      required
                                      placeholder="Share your thoughts..."
                                      class="w-full h-32 px-5 py-4 rounded-2xl bg-white/5 border border-white/10 text-white text-sm placeholder:text-white/20 focus:border-primary focus:ring-1 focus:ring-primary transition-all outline-none resize-none">@userReview?.Comment</textarea>
                        </div>

                        <button type="submit" 
                                class="w-full py-4 bg-primary text-background-dark font-black rounded-2xl shadow-xl shadow-primary/20 hover:scale-[1.02] active:scale-95 transition-all">
                            Submit Review
                        </button>
                    </form>
                }
                else
                {
                    <div class="text-center py-10">
                        <span class="material-symbols-outlined text-4xl text-primary mb-4">lock</span>
                        <h3 class="text-white font-bold mb-3">Please logging to review</h3>
                        <a href="/Auth/Login" class="text-primary text-xs font-black uppercase tracking-widest hover:underline">Login Now</a>
                    </div>
                }
            </div>
        </div>

        <!-- Reviews List -->
        <div class="lg:col-span-2 space-y-8">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-2xl font-black text-white">Community Reviews</h2>
                <div class="px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-[10px] font-black text-white/50 uppercase">@Model.Count Reviews</div>
            </div>

            @if (Model.Any())
            {
                foreach (var review in Model)
                {
                    <div class="p-8 rounded-[2rem] bg-white/5 border border-white/5 hover:border-white/10 transition-all group">
                        <div class="flex justify-between items-start mb-6">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-primary/20 to-teal-500/20 flex items-center justify-center text-primary font-black text-xl border border-primary/20">
                                    @review.User?.FullName.Substring(0, 1)
                                </div>
                                <div>
                                    <h4 class="text-white font-bold">@review.User?.FullName</h4>
                                    <div class="flex items-center gap-2 mt-0.5">
                                        <div class="flex text-amber-400">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <span class="material-symbols-outlined text-xs @(i <= review.Rating ? "fill-current" : "opacity-20")">star</span>
                                            }
                                        </div>
                                        <span class="text-[10px] text-white/20 font-bold">
                                            @if (review.UpdatedAt.HasValue)
                                            {
                                                <span>Updated @review.UpdatedAt.Value.ToString("MMM dd, yyyy")</span>
                                            }
                                            else
                                            {
                                                @review.CreatedAt.ToString("MMM dd, yyyy")
                                            }
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <p class="text-white/70 leading-relaxed text-sm italic">"@review.Comment"</p>
                    </div>
                }
            }
            else
            {
                <div class="p-20 rounded-[2.5rem] border border-dashed border-white/10 flex flex-col items-center justify-center text-center">
                    <span class="material-symbols-outlined text-5xl text-white/10 mb-6">chat_bubble</span>
                    <h3 class="text-white/40 font-bold">No reviews yet</h3>
                    <p class="text-white/20 text-sm">Be the first to share your thoughts!</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .fill-current {
        font-variation-settings: 'FILL' 1;
    }
</style>

<script>
    function setRating(val) {
        document.getElementById('rating-input').value = val;
        const stars = document.querySelectorAll('.star-icon');
        stars.forEach((star, index) => {
            if (index < val) {
                star.classList.add('text-amber-400', 'fill-current');
                star.classList.remove('text-white/20');
            } else {
                star.classList.remove('text-amber-400', 'fill-current');
                star.classList.add('text-white/20');
            }
        });
    }
</script>
