@model IEnumerable<LibraryManagementDAL.DTO.RenewalRequest.RenewalRequestItem>
@using LibraryManagementDAL.Models
@{
    ViewData["Title"] = "Renewal Requests";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="flex-1 p-8 min-w-0 overflow-y-auto custom-scrollbar">
    <div class="mb-8">
        <a asp-controller="Circulation" asp-action="Index" class="inline-flex items-center text-white/40 hover:text-primary transition-colors mb-4 text-sm font-medium">
            <span class="material-symbols-outlined text-[18px] mr-1">arrow_back</span>
            Back to circulation
        </a>
        <h1 class="text-4xl font-bold font-display text-white mb-2">Renewal Requests</h1>
        <p class="text-white/60">Review member renewal requests and approve or reject them.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-6 px-4 py-3 bg-emerald-500/10 border border-emerald-500/20 rounded-xl flex items-center justify-between">
            <div class="flex items-center gap-3 text-emerald-400">
                <span class="material-symbols-outlined">check_circle</span>
                <span class="font-medium text-sm">@TempData["SuccessMessage"]</span>
            </div>
            <button class="text-white/40 hover:text-white transition-colors" onclick="this.parentElement.remove()">
                <span class="material-symbols-outlined text-lg">close</span>
            </button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="mb-6 px-4 py-3 bg-red-500/10 border border-red-500/20 rounded-xl flex items-center justify-between">
            <div class="flex items-center gap-3 text-red-400">
                <span class="material-symbols-outlined">error</span>
                <span class="font-medium text-sm">@TempData["ErrorMessage"]</span>
            </div>
            <button class="text-white/40 hover:text-white transition-colors" onclick="this.parentElement.remove()">
                <span class="material-symbols-outlined text-lg">close</span>
            </button>
        </div>
    }

    <div class="bg-white/5 border border-white/10 rounded-2xl overflow-hidden shadow-2xl">
        <div class="p-6 border-b border-white/5 bg-black/20">
            <h3 class="text-lg font-bold text-white flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">pending_actions</span>
                Pending Requests
            </h3>
        </div>

        <div class="overflow-x-auto custom-scrollbar">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-black/20 text-white/40 text-[11px] uppercase tracking-wider font-bold">
                        <th class="p-4 border-b border-white/5">Member</th>
                        <th class="p-4 border-b border-white/5">Book</th>
                        <th class="p-4 border-b border-white/5">Current Due Date</th>
                        <th class="p-4 border-b border-white/5">Requested</th>
                        <th class="p-4 border-b border-white/5 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="text-sm">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr class="text-white/80 border-b border-white/5 hover:bg-white/5 transition-colors group">
                                <td class="p-4">
                                    <div class="font-semibold text-white group-hover:text-primary transition-colors">@item.UserFullName</div>
                                    <div class="text-[11px] text-white/40">@item.UserEmail</div>
                                </td>
                                <td class="p-4">
                                    <div class="text-white font-medium">@item.BookTitle</div>
                                    <div class="text-[11px] text-primary flex items-center gap-1 mt-0.5">
                                        <span class="material-symbols-outlined text-[12px]">barcode</span>
                                        @item.Barcode
                                    </div>
                                </td>
                                <td class="p-4 text-white/60">
                                    <div>@item.CurrentDueDate.ToString("dd/MM/yyyy")</div>
                                    <div class="text-[11px] text-white/30 mt-0.5">+@item.RequestedExtraDays days if approved</div>
                                </td>
                                <td class="p-4 text-white/60">@item.RequestedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="p-4 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <form asp-action="Approve" asp-route-id="@item.RenewalRequestId" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="p-2 bg-primary text-background-dark rounded-lg hover:scale-105 transition-all font-bold text-xs flex items-center gap-1 shadow-lg shadow-primary/20">
                                                <span class="material-symbols-outlined text-sm">check</span>
                                                Approve
                                            </button>
                                        </form>
                                        <button type="button"
                                                onclick="openRejectModal(@item.RenewalRequestId, '@Html.Raw(item.BookTitle.Replace("'", "\\'"))')"
                                                class="p-2 bg-white/5 text-red-400 hover:bg-red-500/10 border border-white/10 hover:border-red-500/20 rounded-lg transition-all text-xs font-bold flex items-center gap-1">
                                            <span class="material-symbols-outlined text-sm">close</span>
                                            Reject
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="p-16 text-center text-white/40">
                                <div class="w-20 h-20 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-4 border border-white/10">
                                    <span class="material-symbols-outlined text-4xl text-white/10">autorenew</span>
                                </div>
                                <h4 class="text-lg font-bold text-white/60 mb-2">No Pending Requests</h4>
                                <p class="text-sm max-w-xs mx-auto text-white/30">When members request renewals, they will appear here for your review.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="rejectModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70 p-4">
    <div class="w-full max-w-md bg-[#0b1220] border border-white/10 rounded-2xl shadow-2xl p-6">
        <h3 class="text-xl font-bold text-white mb-2">Reject Renewal Request</h3>
        <p class="text-sm text-white/50 mb-4">Book: <span id="rejectBookTitle" class="text-white font-medium"></span></p>
        <form id="rejectForm" method="post">
            @Html.AntiForgeryToken()
            <label class="block text-[10px] text-white/40 font-black uppercase tracking-widest mb-2">Reason (required)</label>
            <textarea name="reason" id="rejectReason" rows="4" required minlength="5"
                      class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white text-sm focus:border-primary/50 focus:outline-none resize-none"
                      placeholder="Explain why this renewal cannot be approved..."></textarea>
            <div class="flex justify-end gap-3 mt-6">
                <button type="button" onclick="closeRejectModal()" class="px-4 py-2 text-white/60 hover:text-white font-bold text-sm">Cancel</button>
                <button type="submit" class="px-5 py-2 bg-red-500/20 hover:bg-red-500/30 text-red-300 border border-red-500/30 rounded-xl font-bold text-sm">Reject Request</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openRejectModal(id, bookTitle) {
            document.getElementById('rejectBookTitle').textContent = bookTitle;
            document.getElementById('rejectForm').action = '/RenewalRequest/Reject/' + id;
            document.getElementById('rejectReason').value = '';
            const modal = document.getElementById('rejectModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeRejectModal() {
            const modal = document.getElementById('rejectModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }
    </script>
}
