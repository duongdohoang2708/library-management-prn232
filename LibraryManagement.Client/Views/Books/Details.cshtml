@model LibraryManagementDAL.Models.Book
@using LibraryManagementDAL.Models
@{
    var userRoles = User.Claims
        .Where(c => c.Type == System.Security.Claims.ClaimTypes.Role)
        .Select(c => c.Value)
        .ToList();

    var isMember = userRoles.Contains("Member");
    ViewData["Title"] = "Book Details";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";

    // Check available copies
    var copies = Model.BookCopies ?? new List<BookCopy>();
    var availableCount = copies.Count(c => c.Status == BookCopyStatus.Available);
    var isOutOffStock = availableCount == 0;

    // Check login status
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
}

<div class="p-10">

    <div class="max-w-6xl mx-auto">

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

            <!-- BOOK COVER -->
            <div class="h-fit sticky top-10">
                <div class="group relative aspect-[3/4] rounded-3xl overflow-hidden shadow-2xl border border-white/10 bg-slate-900 flex items-center justify-center p-8">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    <img class="w-full h-full object-contain drop-shadow-2xl rounded-lg scale-100 group-hover:scale-105 transition-transform duration-700"
                         src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://lh3.googleusercontent.com/aida-public/AB6AXuAvK-cjH676fwE2CtPAaKeNs1CFkHzF117dsgnXA3wuDRqathH8u9Zff-Qy8ru3VTxc66TJe4aBEeR1gzvWg1Vi0r9Szi8ALKxif6kBgMSdEbjI8dr3hs3gyZdL0mk0Rjx-KU1jv3tmiDqnnA2Wf6Ar2eOgjiXiB9d8PVkgDaEhQGE9Vlq6nid3BI-XIbI6gseJsabnRZKqCi2WbVxDK4-OTDqAVWsUAyZTsgLjWVtvnsgd4Z1zymxCNpOoXgUSbL3Y25pTkW1i5Rq1" : Model.ImageUrl)"
                         asp-append-version="true" />

                    @if (isOutOffStock)
                    {
                        <div class="absolute top-6 right-6 px-4 py-2 bg-rose-500/90 backdrop-blur-md text-white text-xs font-black uppercase tracking-widest rounded-full shadow-lg border border-white/20">
                            Out of Stock
                        </div>
                    }
                    else
                    {
                        <div class="absolute top-6 right-6 px-4 py-2 bg-emerald-500/90 backdrop-blur-md text-white text-xs font-black uppercase tracking-widest rounded-full shadow-lg border border-white/20">
                            Available: @availableCount copies
                        </div>
                    }
                </div>
            </div>

            <!-- BOOK INFO -->
            <div class="flex flex-col">

                <div class="flex-1">
                    <!-- Heading Meta -->
                    <div class="flex items-center gap-3 mb-6">
                        <span class="px-3 py-1 bg-primary/10 text-primary text-[10px] font-bold uppercase tracking-widest rounded-lg border border-primary/20">
                            @Model.Category?.CategoryName
                        </span>
                        <div class="h-1 w-1 bg-white/20 rounded-full"></div>
                        <span class="text-white/40 text-[10px] font-bold uppercase tracking-widest">@Model.Publisher?.PublisherName</span>
                    </div>

                    <!-- Title -->
                    <h1 class="text-5xl font-black text-white mb-4 tracking-tight leading-tight">
                        @Model.Title
                    </h1>

                    <!-- Author -->
                    <div class="flex items-center gap-3 mb-10">
                        <div class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/40 uppercase font-black">
                            @Model.Author?.Name[0]
                        </div>
                        <p class="text-xl text-white/60 font-medium italic">
                            By @Model.Author?.Name
                        </p>
                    </div>

                    <!-- Description -->
                    <div class="relative mb-12">
                        <div class="absolute -left-6 top-0 bottom-0 w-1 bg-primary/20 rounded-full"></div>
                        <h3 class="text-xs font-black text-white/30 uppercase tracking-[0.2em] mb-4">Summary</h3>
                        <p class="text-lg text-white/70 leading-relaxed font-light">
                            @(string.IsNullOrEmpty(Model.Description)
                                                        ? "No detailed description available for this book."
                                                        : Model.Description)
                        </p>
                    </div>

                    <!-- Meta Grid -->
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 p-8 bg-white/5 border border-white/10 rounded-3xl mb-12">
                        <div>
                            <p class="text-[10px] text-white/30 font-black uppercase tracking-widest mb-1">Publish Year</p>
                            <p class="text-white font-bold text-lg">@Model.PublishYear</p>
                        </div>
                        <div>
                            <p class="text-[10px] text-white/30 font-black uppercase tracking-widest mb-1">Edition</p>
                            <p class="text-white font-bold text-lg">Edition @Model.EditionNumber</p>
                        </div>
                        <div>
                            <p class="text-[10px] text-white/30 font-black uppercase tracking-widest mb-1">ISBN</p>
                            <p class="text-white font-bold text-lg truncate" title="@Model.ISBN">@Model.ISBN</p>
                        </div>
                        <div>
                            <p class="text-[10px] text-white/30 font-black uppercase tracking-widest mb-1">Status</p>
                            <p class="@(Model.IsActive ? "text-emerald-400" : "text-rose-400") font-bold text-lg">@(Model.IsActive ? "Available" : "Discontinued")</p>
                        </div>
                    </div>

                    <!-- Ratings Summary -->
                    @{
                        var avgRating = Model.BookReviews != null && Model.BookReviews.Any()
                        ? Math.Round(Model.BookReviews.Average(r => r.Rating), 1)
                        : 0;
                        var totalReviews = Model.BookReviews?.Count ?? 0;
                    }
                    <div class="p-8 bg-gradient-to-br from-white/5 to-transparent border border-white/10 rounded-3xl mb-12 group hover:border-primary/40 transition-all duration-500">
                        <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
                            <div class="flex flex-col gap-1">
                                <p class="text-[10px] text-white/30 font-black uppercase tracking-widest text-center sm:text-left">Community Rating</p>
                                <div class="flex items-center gap-3">
                                    <div class="flex text-amber-500">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <span class="material-symbols-outlined text-xl @(i <= Math.Round(avgRating) ? "fill-current" : "opacity-20")">star</span>
                                        }
                                    </div>
                                    <span class="text-2xl font-black text-white">@avgRating</span>
                                    <span class="text-white/30 font-bold ml-1">(@totalReviews reviews)</span>
                                </div>
                            </div>
                            <a href="@Url.Action("Index", "Review", new { bookId = Model.BookId })" class="px-6 py-3 bg-white/5 hover:bg-primary hover:text-background-dark text-primary text-xs font-black uppercase tracking-widest rounded-2xl border border-primary/20 transition-all shadow-lg active:scale-95 text-center w-full sm:w-auto">
                                View All
                            </a>
                        </div>
                    </div>
                </div>

                <!-- ACTION BUTTONS -->
                <div class="mt-8 flex flex-col sm:flex-row gap-4">
                    @if (isMember)
                    {
                        @if (isAuthenticated)
                        {
                            @if (isOutOffStock)
                            {
                                <form asp-action="RequestReserve" asp-controller="UserAction" method="post" class="flex-1">
                                    <input type="hidden" name="bookId" value="@Model.BookId" />
                                    <button type="submit" class="w-full px-10 py-5 bg-white/10 hover:bg-white/20 text-white font-black rounded-2xl border border-white/10 transition-all flex items-center justify-center gap-3">
                                        <span class="material-symbols-outlined">event_note</span>
                                        <span>Reserve Queue</span>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="RequestBorrow" asp-controller="UserAction" method="post" class="flex-1">
                                    <input type="hidden" name="bookId" value="@Model.BookId" />
                                    <button type="submit" class="w-full px-10 py-5 bg-primary text-background-dark font-black rounded-2xl hover:bg-primary-hover shadow-xl shadow-primary/30 transition-all active:scale-[0.98] flex items-center justify-center gap-3">
                                        <span class="material-symbols-outlined">book_5</span>
                                        <span>Borrow Now</span>
                                    </button>
                                </form>
                            }
                        }
                        else
                        {
                            <a asp-action="Login" asp-controller="Auth" asp-route-returnUrl="@Context.Request.Path" class="flex-1 px-10 py-5 bg-primary text-background-dark font-black rounded-2xl hover:bg-primary-hover shadow-xl shadow-primary/30 transition-all text-center flex items-center justify-center gap-3">
                                <span class="material-symbols-outlined">login</span>
                                Log in to borrow
                            </a>
                        }
                    }
                    else
                    {
                        <a asp-controller="Inventory" asp-action="ManageCopies" asp-route-bookId="@Model.BookId"
                           class="flex-1 px-10 py-5 bg-primary text-background-dark font-black rounded-2xl hover:bg-primary-hover shadow-xl shadow-primary/30 transition-all text-center flex items-center justify-center gap-3">
                            <span class="material-symbols-outlined">inventory_2</span>
                            Manage Copies
                        </a>
                    }

                    <a asp-action="@(isMember ? "ViewBooks" : "AllBooks")" asp-controller="Books"
                       class="px-10 py-5 bg-white/5 hover:bg-white/10 text-white/70 font-bold rounded-2xl border border-white/5 transition-all text-center flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined">arrow_back</span>
                        Back
                    </a>
                </div>

                @if (isAuthenticated && isOutOffStock)
                {
                    <p class="mt-6 text-center text-xs text-white/40 font-bold italic">
                        * This book is currently unavailable. You can reserve it and the system will automatically hold it for you once it is returned.
                    </p>
                }
            </div>

        </div>

    </div>

</div>