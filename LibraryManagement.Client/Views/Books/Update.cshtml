@model LibraryManagementDAL.DTO.Book.BookUpdateModelRequest
@{
    ViewData["Title"] = "Update Book";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="p-10">
    <div class="max-w-6xl mx-auto">

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-14">

            <!-- BOOK COVER -->
            <div class="h-fit top-10">
                <div class="aspect-[3/4] rounded-2xl overflow-hidden shadow-2xl border border-primary/30 bg-black/40 flex items-center justify-center p-4">
                    <img class="w-full h-full object-contain drop-shadow-2xl rounded"
                         src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://lh3.googleusercontent.com/aida-public/AB6AXuAvK-cjH676fwE2CtPAaKeNs1CFkHzF117dsgnXA3wuDRqathH8u9Zff-Qy8ru3VTxc66TJe4aBEeR1gzvWg1Vi0r9Szi8ALKxif6kBgMSdEbjI8dr3hs3gyZdL0mk0Rjx-KU1jv3tmiDqnnA2Wf6Ar2eOgjiXiB9d8PVkgDaEhQGE9Vlq6nid3BI-XIbI6gseJsabnRZKqCi2WbVxDK4-OTDqAVWsUAyZTsgLjWVtvnsgd4Z1zymxCNpOoXgUSbL3Y25pTkW1i5Rq1" : Model.ImageUrl)"
                         asp-append-version="true" />
                </div>
            </div>


            <div>


                <div class="mb-8">
                    <h1 class="text-4xl font-bold font-display text-white mb-2">Update Book</h1>
                </div>

                <!-- EDIT MODE -->
                <form id="edit-mode"
                      asp-action="Update"
                      asp-route-id="@Model.BookId"
                      method="post"
                      enctype="multipart/form-data"
                      class="flex flex-col gap-6">

                    <div asp-validation-summary="All" class="text-red-500 mb-4"></div>

                    <input type="hidden" asp-for="BookId" />
                    <input type="hidden" asp-for="ImageUrl" />

                    <!-- COVER IMAGE -->
                    <div>
                        <label class="text-white/60 text-sm">Cover Image (Upload to replace)</label>
                        <input type="file" name="ImageFile" accept="image/*"
                               class="w-full bg-white/10 text-white p-2 rounded-xl border border-white/20 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-primary file:text-black hover:file:bg-primary/90" />
                    </div>

                    <!-- TITLE -->
                    <div>
                        <label class="text-white/60 text-sm">Title</label>
                        <input asp-for="Title"
                               class="w-full bg-white/10 text-white p-3 rounded-xl border border-white/20" />
                    </div>

                    <!-- ISBN -->
                    <div>
                        <label class="text-white/60 text-sm">ISBN</label>

                        <input asp-for="ISBN"
                               class="w-full bg-white/10 text-white p-3 rounded-xl border border-white/20" />
                    </div>
                    <!-- AUTHOR -->
                    <div>
                        <label class="text-white/60 text-sm">Author</label>
                        <select name="AuthorId"
                                class="w-full p-2 rounded bg-black/30 text-white border border-white/10 mb-2">

                            @foreach (var author in ViewBag.Authors)
                            {
                                <option value="@author.AuthorId"
                                        selected="@(author.AuthorId == Model.AuthorId)">
                                    @author.Name
                                </option>
                            }

                        </select>
                    </div>


                    <!-- CATEGORY -->
                    <div>
                        <label class="text-white/60 text-sm">Category</label>
                        <select name="CategoryId"
                                class="w-full p-2 rounded bg-black/30 text-white border border-white/10 mb-2">

                            @foreach (var category in ViewBag.Categories)
                            {
                                <option value="@category.CategoryId"
                                        selected="@(category.CategoryId == Model.CategoryId)">
                                    @category.CategoryName
                                </option>
                            }

                        </select>
                    </div>


                    <!-- PUBLISHER -->
                    <div>
                        <label class="text-white/60 text-sm">Publisher</label>
                        <select name="PublisherId"
                                class="w-full p-2 rounded bg-black/30 text-white border border-white/10 mb-2">

                            @foreach (var publisher in ViewBag.Publishers)
                            {
                                <option value="@publisher.PublisherId"
                                        selected="@(publisher.PublisherId == Model.PublisherId)">
                                    @publisher.PublisherName
                                </option>
                            }

                        </select>
                    </div>


                    <div class="grid grid-cols-2 gap-6">

                        <div>
                            <label class="text-white/60 text-sm">Edition</label>
                            <input asp-for="EditionNumber"
                                   class="w-full bg-white/10 text-white p-3 rounded-xl border border-white/20" />
                        </div>

                        <div>
                            <label class="text-white/60 text-sm">Publish Year</label>
                            <input asp-for="PublishYear"
                                   class="w-full bg-white/10 text-white p-3 rounded-xl border border-white/20" />
                        </div>

                    </div>


                    <div>
                        <label class="text-white/60 text-sm">Description</label>
<textarea asp-for="Description"
          class="w-full bg-white/10 text-white p-3 rounded-xl border border-white/20 h-32"></textarea>
                    </div>

                    <!-- ACTIVE -->
                    <div class="flex items-center gap-3">

                        <input asp-for="IsActive"
                               type="checkbox"
                               class="w-5 h-5 accent-yellow-400" />

                        <label class="text-white/70">
                            Active
                        </label>

                    </div>


                    <div class="flex gap-4 mt-4">

                        <button type="submit"
                                class="px-8 py-3 bg-yellow-400 text-black rounded-xl font-semibold hover:bg-yellow-300">
                            Save
                        </button>

                        <a asp-action="AllBooks"
                                class="px-8 py-3 border border-white/20 text-white text-center rounded-xl hover:bg-white/10 block leading-tight">
                            Cancel
                        </a>

                    </div>

                </form>

            </div>
        </div>
    </div>
</div>
