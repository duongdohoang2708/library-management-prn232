@model IEnumerable<LibraryManagementDAL.Models.Book>

@{
    ViewData["Title"] = "All Books";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="flex-1 flex overflow-hidden">

    <!-- MAIN CONTENT -->
    <div class="flex-1 p-8 overflow-y-auto custom-scrollbar">

        <!-- Header -->
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-10">  
            <div>
                <h2 class="text-3xl font-bold text-white mb-1">All Books</h2>
                <p class="text-white/40 text-sm">Browse all available books</p>
            </div>
        </div>

        <!-- Filter -->
        <form id="searchForm" method="get" asp-action="ViewBooks">
            <input type="hidden" name="page" value="@(ViewBag.Request?.Page ?? 1)" />

            <div class="mb-8 flex gap-4 flex-wrap bg-white/5 p-4 rounded-3xl border border-white/10 backdrop-blur-md shadow-lg">
                <div class="flex-1 relative min-w-[250px]">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-white/40">search</span>
                    <input type="text" name="keyword" value="@ViewBag.Keyword"
                           oninput="clearTimeout(this.delay); this.delay = setTimeout(() => { this.form.querySelector('input[name=\'page\']').value = 1; triggerSearch(this.form); }, 500);"
                           placeholder="Search books by title, author..."
                           class="w-full bg-white/5 border border-white/10 rounded-xl py-3 pl-12 pr-4 text-white focus:outline-none focus:border-primary/50 focus:bg-white/10 transition-colors h-full" />
                </div>

                <div class="relative min-w-[180px]">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-white/40 pointer-events-none text-sm">category</span>
                    <select name="category"
                            onchange="this.form.querySelector('input[name=\'page\']').value = 1; triggerSearch(this.form)"
                            class="w-full bg-white/5 text-white border border-white/10 rounded-xl py-3 pl-10 pr-10 focus:outline-none focus:border-primary/50 focus:bg-white/10 transition-colors appearance-none cursor-pointer h-full">
                        <option value="" class="bg-gray-900">All Categories</option>
                        @if (ViewBag.Categories != null) {
                            foreach (var c in ViewBag.Categories)
                            {
                                <option value="@c.CategoryName" class="bg-gray-900" selected="@(ViewBag.Category == c.CategoryName)">
                                    @c.CategoryName
                                </option>
                            }
                        }
                    </select>
                    <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-white/40 pointer-events-none text-sm">expand_more</span>
                </div>

                <div class="relative min-w-[150px]">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-white/40 pointer-events-none text-sm">calendar_month</span>
                    <select name="publishYear"
                            onchange="this.form.querySelector('input[name=\'page\']').value = 1; triggerSearch(this.form)"
                            class="w-full bg-white/5 text-white border border-white/10 rounded-xl py-3 pl-10 pr-10 focus:outline-none focus:border-primary/50 focus:bg-white/10 transition-colors appearance-none cursor-pointer h-full">
                        <option value="" class="bg-gray-900">Any Year</option>
                        @if (ViewBag.PublishYears != null) {
                            foreach (int year in ViewBag.PublishYears)
                            {
                                <option value="@year" class="bg-gray-900" selected="@(ViewBag.PublishYear == year)">
                                    @year
                                </option>
                            }
                        }
                    </select>
                    <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-white/40 pointer-events-none text-sm">expand_more</span>
                </div>

                <div class="relative min-w-[150px]">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-white/40 pointer-events-none text-sm">star</span>
                    <select name="minRating"
                            onchange="this.form.querySelector('input[name=\'page\']').value = 1; triggerSearch(this.form)"
                            class="w-full bg-white/5 text-white border border-white/10 rounded-xl py-3 pl-10 pr-10 focus:outline-none focus:border-primary/50 focus:bg-white/10 transition-colors appearance-none cursor-pointer h-full">
                        <option value="" class="bg-gray-900">Any Rating</option>
                        <option value="4" class="bg-gray-900" selected="@(ViewBag.MinRating == 4)">4+ Stars</option>
                        <option value="3" class="bg-gray-900" selected="@(ViewBag.MinRating == 3)">3+ Stars</option>
                        <option value="2" class="bg-gray-900" selected="@(ViewBag.MinRating == 2)">2+ Stars</option>
                    </select>
                    <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-white/40 pointer-events-none text-sm">expand_more</span>
                </div>

                <div class="relative min-w-[170px]">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-white/40 pointer-events-none text-sm">sort</span>
                    <select name="sort"
                        onchange="triggerSearch(this.form)"
                        class="w-full bg-white/5 text-white border border-white/10 rounded-xl py-3 pl-10 pr-10 focus:outline-none focus:border-primary/50 focus:bg-white/10 transition-colors appearance-none cursor-pointer h-full">
                        <option value="" class="bg-gray-900">Sort: Default</option>
                        <option value="newest" class="bg-gray-900" selected="@(ViewBag.Sort == "newest")">Sort: Newest</option>
                        <option value="year" class="bg-gray-900" selected="@(ViewBag.Sort == "year")">Sort: Year</option>
                    </select>
                    <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-white/40 pointer-events-none text-sm">expand_more</span>
                </div>
            </div>
        </form>

        <!-- Books Grid -->
        <div id="booksGridContainer">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-8">

            @if (Model != null && Model.Any())
            {
                foreach (var book in Model)
                {
                    <div class="group relative flex flex-col gap-3">
                        <div class="w-full aspect-[3/4.5] rounded-3xl overflow-hidden relative shadow-[0_10px_30px_rgba(0,0,0,0.5)] border border-white/5 group-hover:border-primary/50 transition-all duration-500 cursor-pointer">
                            <img src="@BookImageHelper.Resolve(book.ImageUrl, book.Title)" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" onerror="this.onerror=null;this.src='@BookImageHelper.Placeholder';" />
                            <div class="absolute inset-0 bg-gradient-to-t from-background-dark via-background-dark/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                            
                            <!-- Hover Actions -->
                            <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-500 flex justify-center">
                                <a asp-action="Details" asp-route-id="@book.BookId" class="px-5 py-2.5 bg-primary text-background-dark font-black text-[10px] uppercase tracking-widest rounded-full shadow-[0_0_20px_rgba(16,185,129,0.5)] hover:scale-105 transition-transform">
                                    View Details
                                </a>
                            </div>
                        </div>
                        
                        <div class="px-1">
                            <h3 class="text-base font-black text-white group-hover:text-primary transition-colors line-clamp-1" title="@book.Title">
                                <a asp-action="Details" asp-route-id="@book.BookId">@book.Title</a>
                            </h3>
                            <p class="text-[11px] font-bold text-white/50 uppercase tracking-widest line-clamp-1 mt-1">@book.Author?.Name</p>
                            
                            <div class="flex items-center justify-between mt-3">
                                <div class="flex items-center text-amber-400 text-xs">
                                    @{
                                        var rating = book.BookReviews?.Any() == true ? Math.Round(book.BookReviews.Average(r => r.Rating), 1) : 0;
                                    }
                                    <span class="material-symbols-outlined text-[16px]">star</span>
                                    <span class="text-[11px] font-bold text-white ml-1">@(rating > 0 ? rating.ToString("0.0") : "New")</span>
                                </div>
                                <span class="text-[10px] font-bold text-white/40 bg-white/5 px-2 py-1 rounded-md border border-white/5">@book.PublishYear</span>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-span-full text-center text-white/40">
                    No books found.
                </div>
            }

        </div>
        @if (ViewBag.TotalPages > 1)
{
        <div class="flex justify-center mt-12">
            <div class="flex items-center gap-2 flex-wrap">

            @if (ViewBag.Request.Page > 1)
            {
                <a href="@Url.Action("ViewBooks", new {
                        page = ViewBag.Request.Page - 1,
                        keyword = ViewBag.Request.Keyword,
                        category = ViewBag.Request.Category,
                        sort = ViewBag.Request.Sort
                    })"
                   class="px-4 py-2 rounded-lg bg-white/10 text-white hover:bg-primary transition">
                    Previous
                </a>
            }

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <a href="@Url.Action("ViewBooks", new {
                        page = i,
                        keyword = ViewBag.Request.Keyword,
                        category = ViewBag.Request.Category,
                        sort = ViewBag.Request.Sort
                    })"
                   class="px-4 py-2 rounded-lg transition
                   @(i == ViewBag.Request.Page
                        ? "bg-primary text-white font-bold shadow-lg"
                        : "bg-white/10 text-white hover:bg-primary")">
                    @i
                </a>
            }

            @if (ViewBag.Request.Page < ViewBag.TotalPages)
            {
                <a href="@Url.Action("ViewBooks", new {
                        page = ViewBag.Request.Page + 1,
                        keyword = ViewBag.Request.Keyword,
                        category = ViewBag.Request.Category,
                        sort = ViewBag.Request.Sort
                    })"
                   class="px-4 py-2 rounded-lg bg-white/10 text-white hover:bg-primary transition">
                    Next
                </a>
            }

        </div>
    </div>
}
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function triggerSearch(form) {
            const formData = new FormData(form);
            const params = new URLSearchParams(formData);
            
            const container = document.getElementById('booksGridContainer');
            if (container) {
                container.style.opacity = '0.5';
                container.style.pointerEvents = 'none';
            }

            fetch(`${form.action}?${params.toString()}`)
            .then(response => response.text())
            .then(html => {
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');
                
                const oldEl = document.getElementById('booksGridContainer');
                const newEl = doc.getElementById('booksGridContainer');
                if (oldEl && newEl) {
                    oldEl.innerHTML = newEl.innerHTML;
                    oldEl.style.opacity = '1';
                    oldEl.style.pointerEvents = 'auto';
                }
                
                window.history.replaceState({}, '', `${form.action}?${params.toString()}`);
            })
            .catch(error => {
                console.error("Error fetching data:", error);
                if (container) {
                    container.style.opacity = '1';
                    container.style.pointerEvents = 'auto';
                }
            });
        }
    </script>
}
