@model IEnumerable<LibraryManagementDAL.Models.Book>

@{
    ViewData["Title"] = "All Books";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="flex-1 flex overflow-hidden">

    <!-- MAIN CONTENT -->
    <div class="flex-1 p-8 overflow-y-auto custom-scrollbar">

        <!-- Header -->
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-10">  
            <div>
                <h2 class="text-3xl font-bold text-white mb-1">All Books</h2>
                <p class="text-white/40 text-sm">Browse all available books</p>
            </div>
        </div>

        <!-- Filter -->
        <form method="get" asp-action="ViewBooks">
            <input type="hidden" name="keyword" value="@ViewBag.Keyword" />

            <div class="mb-8 flex gap-4 flex-wrap">
                <select name="category"
                        onchange="this.form.submit()"
                        class="bg-gray-800 text-white
               border border-gray-600
               rounded-xl px-4 py-2
               focus:ring-2 focus:ring-primary/40
               focus:border-primary
               appearance-none">

                    <option value=""
                            selected="@(string.IsNullOrEmpty(ViewBag.Category))">
                        All Categories
                    </option>

                    @foreach (var c in ViewBag.Categories)
                    {
                        <option value="@c.CategoryName"
                                class="bg-gray-800 text-white"
                                selected="@(ViewBag.Category == c.CategoryName)">
                            @c.CategoryName
                        </option>
                    }
                </select>

                <select name="sort"
                    onchange="this.form.submit()"
                    class="bg-gray-800 text-white
                           border border-gray-600
                           rounded-xl px-4 py-2
                           focus:ring-2 focus:ring-primary/40
                           focus:border-primary">

                    <option value=""
                            selected="@(string.IsNullOrEmpty(ViewBag.Sort))">
                        Sort By
                    </option>

                    <option value="newest"
                            selected="@(ViewBag.Sort == "newest")">
                        Newest
                    </option>

                    <option value="year"
                            selected="@(ViewBag.Sort == "year")">
                        Publish Year
                    </option>

                </select>
            </div>
        </form>

        <!-- Books Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">

            @if (Model != null && Model.Any())
            {
                foreach (var book in Model)
                {
                    <div class="group bg-white/5 border border-white/10 rounded-2xl p-4 hover:border-primary/30 hover:bg-white/10 transition-all flex flex-col">

                        <!-- Image -->
                        <div class="relative aspect-[3/4] rounded-xl overflow-hidden mb-4 shadow-xl">
                            <img alt="@book.Title"
                                 class="w-full h-full object-cover"
                                 src="@(string.IsNullOrEmpty(book.ImageUrl) 
                                        ? "https://via.placeholder.com/300x400?text=No+Image" 
                                        : book.ImageUrl)" />
                        </div>

                        <!-- Info -->
                        <div class="flex flex-col flex-grow">
                            <h3 class="text-lg font-bold text-white mb-1 truncate group-hover:text-primary transition-colors">
                                @book.Title
                            </h3>

                            <p class="text-sm text-white/50 mb-3 truncate">
                                @book.Author?.Name
                            </p>

                            <div class="flex justify-between text-xs text-white/40 mb-4">
                                <span>Edition: @book.EditionNumber</span>
                                <span>@book.PublishYear</span>
                            </div>

                            <a asp-action="Details"
                               asp-route-id="@book.BookId"
                               class="mt-auto w-full py-2.5 border border-primary/40 text-primary hover:bg-primary hover:text-background-dark font-bold rounded-lg text-xs transition-all uppercase tracking-widest text-center">
                                View Details
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-span-full text-center text-white/40">
                    No books found.
                </div>
            }

        </div>
        @if (ViewBag.TotalPages > 1)
{
        <div class="flex justify-center mt-12">
            <div class="flex items-center gap-2 flex-wrap">

            @if (ViewBag.Request.Page > 1)
            {
                <a href="@Url.Action("ViewBooks", new {
                        page = ViewBag.Request.Page - 1,
                        keyword = ViewBag.Request.Keyword,
                        category = ViewBag.Request.Category,
                        sort = ViewBag.Request.Sort
                    })"
                   class="px-4 py-2 rounded-lg bg-white/10 text-white hover:bg-primary transition">
                    Previous
                </a>
            }

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <a href="@Url.Action("ViewBooks", new {
                        page = i,
                        keyword = ViewBag.Request.Keyword,
                        category = ViewBag.Request.Category,
                        sort = ViewBag.Request.Sort
                    })"
                   class="px-4 py-2 rounded-lg transition
                   @(i == ViewBag.Request.Page
                        ? "bg-primary text-white font-bold shadow-lg"
                        : "bg-white/10 text-white hover:bg-primary")">
                    @i
                </a>
            }

            @if (ViewBag.Request.Page < ViewBag.TotalPages)
            {
                <a href="@Url.Action("ViewBooks", new {
                        page = ViewBag.Request.Page + 1,
                        keyword = ViewBag.Request.Keyword,
                        category = ViewBag.Request.Category,
                        sort = ViewBag.Request.Sort
                    })"
                   class="px-4 py-2 rounded-lg bg-white/10 text-white hover:bg-primary transition">
                    Next
                </a>
            }

        </div>
    </div>
}

    </div>
</div>
