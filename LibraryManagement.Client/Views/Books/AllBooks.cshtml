@model IEnumerable<LibraryManagementDAL.Models.Book>
@using System.Linq
@{
    var books = Model?.ToList() ?? new List<LibraryManagementDAL.Models.Book>();

    var userRoles = User.Claims
        .Where(c => c.Type == System.Security.Claims.ClaimTypes.Role)
        .Select(c => c.Value)
        .ToList();

    var isStaff = userRoles.Any(r => r == "Admin" || r == "Librarian" || r == "Manager");
    Layout = isStaff ? "~/Views/Shared/_LayoutDashboard.cshtml" : "~/Views/Shared/_Layout.cshtml";
}

<div class="flex-1 flex overflow-hidden">

    <!-- MAIN CONTENT -->
    <div class="flex-1 px-8 py-12 overflow-y-auto custom-scrollbar">

        @if (TempData["NewBookId"] != null)
        {
            <div class="mb-8 p-4 rounded-xl bg-green-500/10 border border-green-500/20 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-green-400">check_circle</span>
                    <div>
                        <strong class="block text-green-400">Book created successfully!</strong>
                        <span class="text-sm text-green-400/80">Would you like to manage physical copies for this new book?</span>
                    </div>
                </div>
                <a asp-controller="Inventory" asp-action="ManageCopies" asp-route-bookId="@TempData["NewBookId"]" class="px-5 py-2.5 bg-green-500/20 hover:bg-green-500/30 text-green-300 rounded-lg w-max font-bold transition-colors whitespace-nowrap border border-green-500/30 flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">inventory_2</span>
                    Manage Copies
                </a>
            </div>
        }

        <!-- Header -->
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-10">  
            <div>
                <h2 class="text-3xl font-bold text-white mb-1">@(isStaff ? "Book Catalog Management" : "Explore Library")</h2>
                <p class="text-white/40 text-sm">@(isStaff ? "View and manage all books in the system" : "Search for your favorite books")</p>
            </div>
            @if (isStaff)
            {
                <a asp-action="AddBook" class="px-6 py-3 bg-primary text-background-dark font-black rounded-xl hover:shadow-xl hover:shadow-primary/30 transition-all flex items-center gap-2">
                    <span class="material-symbols-outlined">add_box</span>
                    Add New Book
                </a>
            }
        </div>

        <!-- Search Bar & Filters -->
        <div class="bg-black/20 border border-white/10 rounded-2xl p-6 mb-8 backdrop-blur-md">
            <form id="searchForm" method="get" asp-action="AllBooks" class="flex flex-col md:flex-row gap-4">
                <input type="hidden" name="page" value="@ViewBag.Request.Page" />
                
                <div class="flex-1 relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-white/40">search</span>
                    <input type="text" name="keyword" value="@ViewBag.Keyword"
                           oninput="clearTimeout(this.delay); this.delay = setTimeout(() => { this.form.querySelector('input[name=\'page\']').value = 1; triggerSearch(this.form); }, 500);"
                           placeholder="Search by book title, author, or ISBN..."
                           class="w-full bg-black/40 border border-white/10 rounded-xl py-3 pl-12 pr-4 text-white focus:outline-none focus:border-primary transition-colors" />
                </div>

                <div class="flex gap-4 flex-wrap">
                    <select name="category"
                            onchange="this.form.querySelector('input[name=\'page\']').value = 1; triggerSearch(this.form)"
                            class="bg-black/40 border border-white/10 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-primary transition-colors cursor-pointer min-w-[150px]">
                        <option value="" selected="@(string.IsNullOrEmpty(ViewBag.Category))">All Categories</option>
                        @if(ViewBag.Categories != null)
                        {
                            foreach (var c in ViewBag.Categories)
                            {
                                <option value="@c.CategoryName" selected="@(ViewBag.Category == c.CategoryName)">@c.CategoryName</option>
                            }
                        }
                    </select>

                    <select name="publisherId"
                            onchange="this.form.querySelector('input[name=\'page\']').value = 1; triggerSearch(this.form)"
                            class="bg-black/40 border border-white/10 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-primary transition-colors cursor-pointer min-w-[160px]">
                        <option value="">All Publishers</option>
                        @if (ViewBag.Publishers != null)
                        {
                            foreach (var p in ViewBag.Publishers)
                            {
                                <option value="@p.PublisherId" selected="@(ViewBag.PublisherId == p.PublisherId)">@p.PublisherName</option>
                            }
                        }
                    </select>

                    <select name="publishYear"
                            onchange="this.form.querySelector('input[name=\'page\']').value = 1; triggerSearch(this.form)"
                            class="bg-black/40 border border-white/10 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-primary transition-colors cursor-pointer min-w-[130px]">
                        <option value="">All Years</option>
                        @if (ViewBag.PublishYears != null)
                        {
                            foreach (var year in ViewBag.PublishYears)
                            {
                                <option value="@year" selected="@(ViewBag.PublishYear == year)">@year</option>
                            }
                        }
                    </select>

                    @if (isStaff)
                    {
                        <select name="isActive"
                                onchange="this.form.querySelector('input[name=\'page\']').value = 1; triggerSearch(this.form)"
                                class="bg-black/40 border border-white/10 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-primary transition-colors cursor-pointer min-w-[130px]">
                            <option value="">All Status</option>
                            <option value="true" selected="@(ViewBag.IsActive == true)">Active</option>
                            <option value="false" selected="@(ViewBag.IsActive == false)">Inactive</option>
                        </select>
                    }

                    <select name="availability"
                            onchange="this.form.querySelector('input[name=\'page\']').value = 1; triggerSearch(this.form)"
                            class="bg-black/40 border border-white/10 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-primary transition-colors cursor-pointer min-w-[150px]">
                        <option value="" selected="@(string.IsNullOrEmpty(ViewBag.Availability))">Any Availability</option>
                        <option value="available" selected="@(ViewBag.Availability == "available")">Available</option>
                        <option value="unavailable" selected="@(ViewBag.Availability == "unavailable")">Unavailable</option>
                        <option value="borrowed" selected="@(ViewBag.Availability == "borrowed")">Borrowed</option>
                        <option value="reserved" selected="@(ViewBag.Availability == "reserved")">Reserved</option>
                        <option value="lost" selected="@(ViewBag.Availability == "lost")">Lost</option>
                        <option value="damaged" selected="@(ViewBag.Availability == "damaged")">Damaged</option>
                    </select>

                    <select name="minRating"
                            onchange="this.form.querySelector('input[name=\'page\']').value = 1; triggerSearch(this.form)"
                            class="bg-black/40 border border-white/10 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-primary transition-colors cursor-pointer min-w-[130px]">
                        <option value="" selected="@(ViewBag.MinRating == null)">Any Rating</option>
                        <option value="5" selected="@(ViewBag.MinRating == 5)">5 stars</option>
                        <option value="4" selected="@(ViewBag.MinRating == 4)">4+ stars</option>
                        <option value="3" selected="@(ViewBag.MinRating == 3)">3+ stars</option>
                    </select>

                    <select name="sort"
                            onchange="triggerSearch(this.form)"
                            class="bg-black/40 border border-white/10 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-primary transition-colors cursor-pointer min-w-[150px]">
                        <option value="" selected="@(string.IsNullOrEmpty(ViewBag.Sort))">Sort By</option>
                        <option value="newest" selected="@(ViewBag.Sort == "newest")">Newest arrivals</option>
                        <option value="year" selected="@(ViewBag.Sort == "year")">Publish Year</option>
                        <option value="az" selected="@(ViewBag.Sort == "az")">Title: A-Z</option>
                    </select>
                    
                    @if (!string.IsNullOrEmpty((string)ViewBag.Keyword) ||
                                        !string.IsNullOrEmpty((string)ViewBag.Category) ||
                                        ViewBag.PublisherId != null ||
                                        ViewBag.PublishYear != null ||
                                        ViewBag.IsActive != null ||
                                        !string.IsNullOrEmpty((string)ViewBag.Availability) ||
                                        ViewBag.MinRating != null ||
                                        !string.IsNullOrEmpty((string)ViewBag.Sort))
                    {
                        <a asp-action="AllBooks" class="px-4 py-3 bg-white/5 text-white/60 font-medium rounded-xl hover:bg-white/10 transition-colors flex items-center" title="Clear Filters">
                            <span class="material-symbols-outlined">close</span>
                        </a>
                    }
                </div>
            </form>
        </div>

        @if (isStaff)
        {
            <!-- Staff Table View -->
            <div id="staffContainer" class="bg-black/20 border border-white/10 rounded-2xl overflow-hidden shadow-2xl mb-12">
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="bg-white/5 border-b border-white/5 text-[10px] uppercase font-bold tracking-widest text-white/40">
                            <tr>
                                <th class="px-6 py-4">Book</th>
                                <th class="px-6 py-4">Category</th>
                                <th class="px-6 py-4">Publisher</th>
                                <th class="px-6 py-4">Year</th>
                                <th class="px-6 py-4">Edition</th>
                                <th class="px-6 py-4">Status</th>
                                <th class="px-6 py-4 text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/5 text-sm">
                            @foreach (var book in Model)
                            {
                                <tr class="hover:bg-white/[0.02] transition-colors group">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-4">
                                            <div class="w-10 h-14 rounded bg-black/40 flex items-center justify-center p-0.5 flex-shrink-0 overflow-hidden shadow-lg border border-primary/20 group-hover:border-primary/50 transition-all">
                                                <img alt="@book.Title"
                                                     src="@BookImageHelper.Resolve(book.ImageUrl, book.Title)"
                                                     onerror="this.onerror=null;this.src='@BookImageHelper.Placeholder';"
                                                     class="w-full h-full object-contain rounded-sm">                                            </div>
                                            <div>
                                                <p class="font-bold text-white group-hover:text-primary transition-colors">@book.Title</p>
                                                <p class="text-[11px] text-white/40 italic">@book.Author?.Name</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-white/60">@book.Category?.CategoryName</td>
                                    <td class="px-6 py-4 text-white/60">@book.Publisher?.PublisherName</td>
                                    <td class="px-6 py-4 text-white/60">@book.PublishYear</td>
                                    <td class="px-6 py-4">
                                        <span class="px-2 py-0.5 bg-primary/10 text-primary text-[10px] font-bold rounded">ED @book.EditionNumber</span>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="px-2 py-0.5 @(book.IsActive ? "bg-emerald-500/10 text-emerald-400 border-emerald-500/20" : "bg-red-500/10 text-red-500 border-red-500/20") text-[10px] font-bold rounded border">
                                            @(book.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <div class="flex justify-end gap-2">
                                            <a asp-action="Details" asp-route-id="@book.BookId" class="p-2 bg-white/5 border border-white/10 rounded-lg text-white/60 hover:text-primary hover:border-primary/50 transition-all" title="View Details">
                                                <span class="material-symbols-outlined text-sm">visibility</span>
                                            </a>
                                            <a asp-action="Update" asp-route-id="@book.BookId" class="p-2 bg-white/5 border border-white/10 rounded-lg text-white/60 hover:text-blue-400 hover:border-blue-400/50 transition-all inline-block" title="Edit Book">
                                                <span class="material-symbols-outlined text-sm">edit</span>
                                            </a>
                                            <a asp-controller="Inventory" asp-action="ManageCopies" asp-route-bookId="@book.BookId" class="p-2 bg-white/5 border border-white/10 rounded-lg text-white/60 hover:text-yellow-400 hover:border-yellow-400/50 transition-all inline-block" title="Manage Copies">
                                                <span class="material-symbols-outlined text-sm">inventory_2</span>
                                            </a>
                                            <form asp-action="ToggleStatus" asp-route-id="@book.BookId" method="post" class="inline-block" onsubmit="return confirm('Are you sure you want to change this book\'s status?');">
                                                <button type="submit" class="p-2 bg-white/5 border border-white/10 rounded-lg text-white/60 hover:@(book.IsActive ? "text-red-400 hover:border-red-400/50" : "text-emerald-400 hover:border-emerald-400/50") transition-all inline-block" title="@(book.IsActive ? "Deactivate Book" : "Activate Book")">
                                                    <span class="material-symbols-outlined text-sm">@(book.IsActive ? "delete" : "restore")</span>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Footer Pagination for Staff -->
                <div id="staffPagination" class="paginationContainer">
                    @if (ViewBag.TotalPages > 1)
                    {
                        <div class="p-8 border-t border-white/5 bg-black/10 flex items-center justify-between">
                            <div class="text-[10px] text-white/30 font-bold uppercase tracking-[0.2em] mb-0 mr-4">
                                Page <span class="text-white">@ViewBag.Request.Page</span> / <span class="text-white">@ViewBag.TotalPages</span>
                            </div>
                            <div class="flex items-center gap-3">
                                @if (ViewBag.Request.Page > 1)
                                {
                                    <button type="button" onclick="event.preventDefault(); document.querySelector('form#searchForm input[name=\'page\']').value = @(ViewBag.Request.Page - 1); triggerSearch(document.getElementById('searchForm'));" 
                                            class="px-6 py-2 rounded-full bg-white/5 border border-white/10 text-white/80 text-xs font-bold hover:bg-white/10 hover:border-white/20 transition-all flex items-center justify-center group shadow-lg">
                                        <span class="material-symbols-outlined text-[18px] mr-1 group-hover:-translate-x-1 transition-transform">chevron_left</span>
                                        Prev
                                    </button>
                                }
                                
                                <div class="flex items-center gap-2 mx-2">
                                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                                    {
                                        if (i == 1 || i == ViewBag.TotalPages || (i >= ViewBag.Request.Page - 1 && i <= ViewBag.Request.Page + 1))
                                        {
                                            <button type="button" onclick="event.preventDefault(); document.querySelector('form#searchForm input[name=\'page\']').value = @i; triggerSearch(document.getElementById('searchForm'));" 
                                                    class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-black transition-all duration-300
                                                           @(i == ViewBag.Request.Page 
                                                             ? "bg-primary text-background-dark shadow-[0_0_20px_rgba(234,179,8,0.3)] ring-4 ring-primary/20" 
                                                             : "bg-transparent text-white/40 hover:text-white border border-white/10 hover:border-white/30")">
                                                @i
                                            </button>
                                        }
                                        else if (i == 2 || i == ViewBag.TotalPages - 1)
                                        {
                                            @if((i == 2 && ViewBag.Request.Page > 3) || (i == ViewBag.TotalPages - 1 && ViewBag.Request.Page < ViewBag.TotalPages - 2))
                                            {
                                                <span class="text-white/20 px-1 font-black">...</span>
                                            }
                                        }
                                    }
                                </div>

                                @if (ViewBag.Request.Page < ViewBag.TotalPages)
                                {
                                    <button type="button" onclick="event.preventDefault(); document.querySelector('form#searchForm input[name=\'page\']').value = @(ViewBag.Request.Page + 1); triggerSearch(document.getElementById('searchForm'));" 
                                            class="px-6 py-2 rounded-full bg-white/5 border border-white/10 text-white/80 text-xs font-bold hover:bg-white/10 hover:border-white/20 transition-all flex items-center justify-center group shadow-lg">
                                        Next
                                        <span class="material-symbols-outlined text-[18px] ml-1 group-hover:translate-x-1 transition-transform">chevron_right</span>
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div id="userGridContainer" class="mb-12">
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-8">
                    @if (books.Count > 0)
                    {
                        foreach (var book in books)
                        {
                            <div class="group bg-white/5 border border-white/10 rounded-2xl p-4 hover:border-primary/30 hover:bg-white/10 transition-all flex flex-col">

                                <div class="relative aspect-[3/4] rounded-xl overflow-hidden mb-4 shadow-xl">
                                    <img alt="@book.Title"
                                         class="w-full h-full object-cover"
                                         src="@BookImageHelper.Resolve(book.ImageUrl, book.Title)"
                                         onerror="this.onerror=null;this.src='@BookImageHelper.Placeholder';" />
                                </div>

                                <div class="flex flex-col flex-grow">
                                    <h3 class="text-lg font-bold text-white mb-1 truncate group-hover:text-primary transition-colors">
                                        @book.Title
                                    </h3>

                                    <p class="text-sm text-white/50 mb-3 truncate">
                                        @book.Author?.Name
                                    </p>

                                    <div class="flex justify-between text-xs text-white/40 mb-4">
                                        <span>Edition: @book.EditionNumber</span>
                                        <span>@book.PublishYear</span>
                                    </div>

                                    <a asp-action="Details"
                                       asp-route-id="@book.BookId"
                                       class="mt-auto w-full py-2.5 border border-primary/40 text-primary hover:bg-primary hover:text-background-dark font-bold rounded-lg text-xs transition-all uppercase tracking-widest text-center">
                                        View Details
                                    </a>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-span-full text-center text-white/40">
                            No books found.
                        </div>
                    }
                </div>

                @if (ViewBag.TotalPages > 1)
                {
                    <div class="flex justify-center mt-12">
                        <div class="flex items-center gap-2 flex-wrap">

                            @if (ViewBag.Request.Page > 1)
                            {
                                <button type="button"
                                        onclick="event.preventDefault(); document.querySelector('form#searchForm input[name=\'page\']').value = @(ViewBag.Request.Page - 1); triggerSearch(document.getElementById('searchForm'));"
                                        class="px-4 py-2 rounded-lg bg-white/10 text-white hover:bg-primary transition">
                                    Previous
                                </button>
                            }

                            @for (int i = 1; i <= ViewBag.TotalPages; i++)
                            {
                                <button type="button"
                                        onclick="event.preventDefault(); document.querySelector('form#searchForm input[name=\'page\']').value = @i; triggerSearch(document.getElementById('searchForm'));"
                                        class="px-4 py-2 rounded-lg transition @(i == ViewBag.Request.Page ? "bg-primary text-white font-bold shadow-lg" : "bg-white/10 text-white hover:bg-primary")">
                                    @i
                                </button>
                            }

                            @if (ViewBag.Request.Page < ViewBag.TotalPages)
                            {
                                <button type="button"
                                        onclick="event.preventDefault(); document.querySelector('form#searchForm input[name=\'page\']').value = @(ViewBag.Request.Page + 1); triggerSearch(document.getElementById('searchForm'));"
                                        class="px-4 py-2 rounded-lg bg-white/10 text-white hover:bg-primary transition">
                                    Next
                                </button>
                            }

                        </div>
                    </div>
                }
            </div>
            }
        </div>
    </div
</div>

@section Scripts {
    <script>
        function triggerSearch(form) {
            const formData = new FormData(form);
            const params = new URLSearchParams(formData);
            
            const staffContainer = document.getElementById('staffContainer');
            const userGridContainer = document.getElementById('userGridContainer');
            
            [staffContainer, userGridContainer].forEach(container => {
                if (container) {
                    container.style.opacity = '0.5';
                    container.style.pointerEvents = 'none';
                }
            });

            fetch(`${form.action}?${params.toString()}`)
            .then(response => response.text())
            .then(html => {
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');
                
                ['staffContainer', 'userGridContainer'].forEach(id => {
                    const oldEl = document.getElementById(id);
                    const newEl = doc.getElementById(id);
                    if (oldEl && newEl) {
                        oldEl.innerHTML = newEl.innerHTML;
                        oldEl.style.opacity = '1';
                        oldEl.style.pointerEvents = 'auto';
                    }
                });
                
                window.history.replaceState({}, '', `${form.action}?${params.toString()}`);
            })
            .catch(error => {
                console.error("Error fetching data:", error);
                [staffContainer, userGridContainer].forEach(container => {
                    if (container) {
                        container.style.opacity = '1';
                        container.style.pointerEvents = 'auto';
                    }
                });
            });
        }
    </script>
}
