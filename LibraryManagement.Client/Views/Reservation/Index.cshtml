@model IEnumerable<LibraryManagementDAL.DTO.Reservation.ReservationItem>
@{
    ViewData["Title"] = "Reservation Requests";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="flex-1 p-8 min-w-0 overflow-y-auto custom-scrollbar">
    <div class="mb-8">
        <a asp-controller="Circulation" asp-action="Index" class="inline-flex items-center text-white/40 hover:text-primary transition-colors mb-4 text-sm font-medium">
            <span class="material-symbols-outlined text-[18px] mr-1">arrow_back</span>
            Back to circulation
        </a>
        <h1 class="text-4xl font-bold font-display text-white mb-2">Book Reservation Requests</h1>
        <p class="text-white/60">Manage hold requests and approve pickup loans.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-6 px-4 py-3 bg-emerald-500/10 border border-emerald-500/20 rounded-xl flex items-center justify-between">
            <div class="flex items-center gap-3 text-emerald-400">
                <span class="material-symbols-outlined">check_circle</span>
                <span class="font-medium text-sm">@TempData["SuccessMessage"]</span>
            </div>
            <button class="text-white/40 hover:text-white transition-colors" onclick="this.parentElement.remove()">
                <span class="material-symbols-outlined text-lg">close</span>
            </button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="mb-6 px-4 py-3 bg-red-500/10 border border-red-500/20 rounded-xl flex items-center justify-between">
            <div class="flex items-center gap-3 text-red-400">
                <span class="material-symbols-outlined">error</span>
                <span class="font-medium text-sm">@TempData["ErrorMessage"]</span>
            </div>
            <button class="text-white/40 hover:text-white transition-colors" onclick="this.parentElement.remove()">
                <span class="material-symbols-outlined text-lg">close</span>
            </button>
        </div>
    }

    <div class="bg-white/5 border border-white/10 rounded-2xl overflow-hidden shadow-2xl">
        <div class="p-6 border-b border-white/5 bg-black/20">
            <h3 class="text-lg font-bold text-white flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">pending_actions</span>
                Open Requests
            </h3>
        </div>

        <div class="overflow-x-auto custom-scrollbar">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-black/20 text-white/40 text-[11px] uppercase tracking-wider font-bold">
                        <th class="p-4 border-b border-white/5">Requester</th>
                        <th class="p-4 border-b border-white/5">Book Information</th>
                        <th class="p-4 border-b border-white/5">Date Requested</th>
                        <th class="p-4 border-b border-white/5">Status</th>
                        <th class="p-4 border-b border-white/5 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="text-sm">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr class="text-white/80 border-b border-white/5 hover:bg-white/5 transition-colors group">
                                <td class="p-4">
                                    <div class="font-semibold text-white group-hover:text-primary transition-colors">@item.UserFullName</div>
                                    <div class="text-[11px] text-white/40">@item.UserEmail</div>
                                </td>
                                <td class="p-4">
                                    <div class="text-white font-medium">@item.BookTitle</div>
                                    @if (!string.IsNullOrWhiteSpace(item.Barcode))
                                    {
                                        <div class="text-[11px] text-primary flex items-center gap-1 mt-0.5">
                                            <span class="material-symbols-outlined text-[12px]">barcode</span>
                                            @item.Barcode
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-[11px] text-white/30 italic">Waiting for allocation...</div>
                                    }
                                </td>
                                <td class="p-4 text-white/60">
                                    <div>@item.ReservedAt.ToString("dd/MM/yyyy HH:mm")</div>
                                    @if (item.ExpireAt.HasValue)
                                    {
                                        <div class="text-[11px] text-white/30 mt-0.5">Hold until @item.ExpireAt.Value.ToString("dd/MM/yyyy HH:mm")</div>
                                    }
                                </td>
                                <td class="p-4">
                                    @if (item.Status == ReservationStatus.Allocated)
                                    {
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 text-[11px] font-bold uppercase tracking-wider">
                                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
                                            Ready for Pickup
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-amber-500/10 text-amber-500 border border-amber-500/20 text-[11px] font-bold uppercase tracking-wider">
                                            <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                                            Waiting for Book
                                        </span>
                                    }
                                </td>
                                <td class="p-4 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        @if (item.Status == ReservationStatus.Allocated)
                                        {
                                            <form asp-action="Approve" asp-route-id="@item.ReservationId" method="post" class="inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="p-2 bg-primary text-background-dark rounded-lg hover:scale-105 transition-all font-bold text-xs flex items-center gap-1 shadow-lg shadow-primary/20">
                                                    <span class="material-symbols-outlined text-sm">check</span>
                                                    Approve Loan
                                                </button>
                                            </form>
                                        }
                                        <form asp-action="Cancel" asp-route-id="@item.ReservationId" method="post" class="inline" onsubmit="return confirm('Are you sure you want to cancel this request?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="p-2 bg-white/5 text-red-400 hover:bg-red-500/10 border border-white/10 hover:border-red-500/20 rounded-lg transition-all" title="Cancel Request">
                                                <span class="material-symbols-outlined text-lg">delete</span>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="p-16 text-center text-white/40">
                                <div class="w-20 h-20 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-4 border border-white/10">
                                    <span class="material-symbols-outlined text-4xl text-white/10">bookmark</span>
                                </div>
                                <h4 class="text-lg font-bold text-white/60 mb-2">No Requests</h4>
                                <p class="text-sm max-w-xs mx-auto text-white/30">When readers place books on hold, the list will appear here for you to manage.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
