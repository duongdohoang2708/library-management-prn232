@model IEnumerable<LibraryManagementDAL.Models.BookCopy>
@using LibraryManagementDAL.Models
@{
    ViewData["Title"] = "Quản lý Kho sách Vật lý";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    var searchBarcode = ViewBag.SearchBarcode as string;
    var location = ViewBag.Location as string;
}

<div class="flex-1 p-8 min-w-0 overflow-y-auto custom-scrollbar">
    <!-- Header Area -->
    <div class="flex justify-between items-end mb-8">
        <div>
            <h1 class="text-4xl font-bold font-display text-white mb-2">Physical Inventory Management</h1>
            <p class="text-white/60">Manage list of book physical copies, barcodes, and real-time shelf availability</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="p-4 mb-6 rounded-xl bg-green-500/10 border border-green-500/20 text-green-400">
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="p-4 mb-6 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400">
            @TempData["ErrorMessage"]
        </div>
    }

    <!-- Search Bar & Filters -->
    <div class="bg-black/20 border border-white/10 rounded-2xl p-6 mb-8 backdrop-blur-md">
        <form id="inventorySearchForm" method="get" asp-action="Index" class="flex flex-col md:flex-row gap-4">
            <div class="flex-1 relative">
                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-white/40">barcode_scanner</span>
                <input type="text" name="searchBarcode" value="@searchBarcode"
                       oninput="clearTimeout(this.delay); this.delay = setTimeout(() => { triggerSearch(this.form); }, 500);"
                       placeholder="Scan or enter barcode, book name..."
                       class="w-full bg-black/40 border border-white/10 rounded-xl py-3 pl-12 pr-4 text-white focus:outline-none focus:border-primary transition-colors" />
            </div>
            
            <div class="flex gap-4 flex-wrap">
                <select name="status" onchange="triggerSearch(this.form)" class="bg-black/40 border border-white/10 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-primary transition-colors cursor-pointer">
                    <option value="">All Statuses</option>
                    <option value="0" selected="@(ViewBag.Status == BookCopyStatus.Available)">Available</option>
                    <option value="1" selected="@(ViewBag.Status == BookCopyStatus.Borrowed)">Borrowed</option>
                    <option value="2" selected="@(ViewBag.Status == BookCopyStatus.Reserved)">Reserved</option>
                    <option value="3" selected="@(ViewBag.Status == BookCopyStatus.Lost)">Lost</option>
                    <option value="4" selected="@(ViewBag.Status == BookCopyStatus.Damaged)">Damaged</option>
                </select>

                <select name="condition" onchange="triggerSearch(this.form)" class="bg-black/40 border border-white/10 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-primary transition-colors truncate max-w-[180px] cursor-pointer">
                    <option value="">All Conditions</option>
                    <option value="0" selected="@(ViewBag.Condition == BookCondition.New)">New</option>
                    <option value="1" selected="@(ViewBag.Condition == BookCondition.Good)">Good</option>
                    <option value="2" selected="@(ViewBag.Condition == BookCondition.Fair)">Fair</option>
                    <option value="3" selected="@(ViewBag.Condition == BookCondition.Poor)">Poor</option>
                    <option value="4" selected="@(ViewBag.Condition == BookCondition.Damaged)">Damaged</option>
                </select>

                <input type="text" name="location" value="@location"
                       oninput="clearTimeout(this.delay); this.delay = setTimeout(() => { triggerSearch(this.form); }, 500);"
                       placeholder="Shelf location..."
                       class="bg-black/40 border border-white/10 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-primary transition-colors min-w-[160px]" />

                @if (!string.IsNullOrEmpty(searchBarcode) || ViewBag.Status != null || ViewBag.Condition != null || !string.IsNullOrEmpty(location))
                {
                    <a asp-action="Index" class="px-4 py-3 bg-white/5 text-white/60 font-medium rounded-xl hover:bg-white/10 transition-colors flex items-center" title="Clear Filters">
                        <span class="material-symbols-outlined">close</span>
                    </a>
                }
            </div>
        </form>
    </div>

    <!-- Inventory Table -->
    <div class="bg-black/20 border border-white/10 rounded-2xl overflow-hidden backdrop-blur-md" id="tableContainer">
        <partial name="_InventoryTable" model="Model" />
    </div>
</div>

@section Scripts {
    <script>
        let currentPage = 1;

        function changePage(page) {
            currentPage = page;
            triggerSearch(document.getElementById('inventorySearchForm'));
        }

        function triggerSearch(form) {
            const formData = new FormData(form);
            const params = new URLSearchParams(formData);
            params.set('page', currentPage);
            
            const tableContainer = document.getElementById('tableContainer');
            if (tableContainer) {
                tableContainer.style.opacity = '0.5';
                tableContainer.style.pointerEvents = 'none';
            }

            fetch(`${form.action}?${params.toString()}`, {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.text())
            .then(html => {
                if (tableContainer) {
                    tableContainer.innerHTML = html;
                    tableContainer.style.opacity = '1';
                    tableContainer.style.pointerEvents = 'auto';
                    window.history.replaceState({}, '', `${form.action}?${params.toString()}`);
                }
            })
            .catch(error => {
                console.error("Error fetching data:", error);
                if (tableContainer) {
                    tableContainer.style.opacity = '1';
                    tableContainer.style.pointerEvents = 'auto';
                }
            });
        }

        // Reset page to 1 when filters change
        document.querySelectorAll('select[name="status"], select[name="condition"], input[name="searchBarcode"], input[name="location"]').forEach(el => {
            el.addEventListener('change', () => { currentPage = 1; });
            if (el.tagName === 'INPUT') {
                el.addEventListener('input', () => { currentPage = 1; });
            }
        });
    </script>
}
