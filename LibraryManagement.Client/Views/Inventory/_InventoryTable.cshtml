@model IEnumerable<LibraryManagementDAL.Models.BookCopy>
@using LibraryManagementDAL.Models

<div class="overflow-x-auto">
    <table class="w-full text-left border-collapse">
        <thead>
            <tr class="border-b border-white/10 bg-white/5">
                <th class="py-4 px-6 font-medium text-white/60">Barcode</th>
                <th class="py-4 px-6 font-medium text-white/60">Book Title</th>
                <th class="py-4 px-6 font-medium text-white/60">Status</th>
                <th class="py-4 px-6 font-medium text-white/60">Condition</th>
                <th class="py-4 px-6 font-medium text-white/60">Shelf Location</th>
                <th class="py-4 px-6 font-medium text-white/60 text-right">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-white/5 text-white/80">
            @if (Model != null && Model.Any())
            {
                foreach (var copy in Model)
                {
                    <tr class="hover:bg-white/[0.02] transition-colors group">
                        <td class="py-4 px-6 whitespace-nowrap">
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-white/40 text-sm">qr_code_2</span>
                                <span class="text-primary font-mono bg-primary/10 px-2 py-0.5 rounded border border-primary/20">@copy.Barcode</span>
                            </div>
                        </td>
                        <td class="py-4 px-6">
                            <p class="font-medium text-white line-clamp-1" title="@copy.Book.Title">@copy.Book.Title</p>
                            <a asp-controller="Books" asp-action="Details" asp-route-id="@copy.BookId" class="text-primary/70 text-sm hover:underline">
                                Book ID: @copy.BookId
                            </a>
                        </td>
                        <td class="py-4 px-6 whitespace-nowrap">
                            @switch (copy.Status)
                            {
                                case BookCopyStatus.Available:
                                    <span class="px-3 py-1 bg-green-500/10 text-green-400 rounded-full text-sm border border-green-500/20">Available</span>
                                    break;
                                case BookCopyStatus.Borrowed:
                                    <span class="px-3 py-1 bg-blue-500/10 text-blue-400 rounded-full text-sm border border-blue-500/20">Borrowed</span>
                                    break;
                                case BookCopyStatus.Reserved:
                                    <span class="px-3 py-1 bg-purple-500/10 text-purple-400 rounded-full text-sm border border-purple-500/20">Reserved</span>
                                    break;
                                case BookCopyStatus.Lost:
                                    <span class="px-3 py-1 bg-red-500/10 text-red-400 rounded-full text-sm border border-red-500/20">Lost</span>
                                    break;
                                case BookCopyStatus.Damaged:
                                    <span class="px-3 py-1 bg-orange-500/10 text-orange-400 rounded-full text-sm border border-orange-500/20">Damaged</span>
                                    break;
                            }
                        </td>
                        <td class="py-4 px-6 whitespace-nowrap">
                            @switch (copy.Condition)
                            {
                                case BookCondition.New:
                                    <span class="text-white/80"><span class="material-symbols-outlined text-sm text-green-400 align-middle mr-1">star</span>New</span>
                                    break;
                                case BookCondition.Good:
                                    <span class="text-white/80"><span class="material-symbols-outlined text-sm text-blue-400 align-middle mr-1">thumb_up</span>Good</span>
                                    break;
                                case BookCondition.Fair:
                                    <span class="text-white/80"><span class="material-symbols-outlined text-sm text-yellow-400 align-middle mr-1">horizontal_rule</span>Fair</span>
                                    break;
                                case BookCondition.Poor:
                                    <span class="text-white/60"><span class="material-symbols-outlined text-sm text-orange-400 align-middle mr-1">warning</span>Poor</span>
                                    break;
                                case BookCondition.Damaged:
                                    <span class="text-red-400"><span class="material-symbols-outlined text-sm align-middle mr-1">error</span>Damaged</span>
                                    break;
                            }
                        </td>
                        <td class="py-4 px-6 whitespace-nowrap">
                            <span class="text-white/60">@(string.IsNullOrEmpty(copy.Location) ? "Unknown" : copy.Location)</span>
                        </td>
                        <td class="py-4 px-6 whitespace-nowrap text-right">
                            <a asp-action="ManageCopies" asp-route-bookId="@copy.BookId" 
                               class="px-3 py-1.5 bg-white/5 text-primary hover:bg-primary/20 rounded-lg transition-colors inline-flex items-center gap-1.5 text-sm"
                               title="Quản lý toàn bộ bản in của đầu sách này">
                                <span class="material-symbols-outlined text-[18px]">inventory</span>
                                Copies
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="py-12 text-center text-white/40">
                        <span class="material-symbols-outlined text-5xl mb-4 opacity-50 block">inventory_2</span>
                        No physical copies found in inventory.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination -->
@if (ViewBag.TotalPages > 1)
{
    <div class="p-8 border-t border-white/5 bg-black/10 flex items-center justify-between">
        <div class="text-[10px] text-white/30 font-bold uppercase tracking-[0.2em] mb-0 mr-4">
            Page <span class="text-white">@ViewBag.CurrentPage</span> / <span class="text-white">@ViewBag.TotalPages</span>
        </div>
        <div class="flex items-center gap-3">
            @if (ViewBag.CurrentPage > 1)
            {
                <button type="button" onclick="changePage(@(ViewBag.CurrentPage - 1))" 
                        class="px-6 py-2 rounded-full bg-white/5 border border-white/10 text-white/80 text-xs font-bold hover:bg-white/10 hover:border-white/20 transition-all flex items-center justify-center group shadow-lg">
                    <span class="material-symbols-outlined text-[18px] mr-1 group-hover:-translate-x-1 transition-transform">chevron_left</span>
                    Prev
                </button>
            }
            
            <div class="flex items-center gap-2 mx-2">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    if (i == 1 || i == ViewBag.TotalPages || (i >= ViewBag.CurrentPage - 1 && i <= ViewBag.CurrentPage + 1))
                    {
                        <button type="button" onclick="changePage(@i)" 
                                class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-black transition-all duration-300
                                       @(i == ViewBag.CurrentPage 
                                         ? "bg-primary text-background-dark shadow-[0_0_20px_rgba(234,179,8,0.3)] ring-4 ring-primary/20" 
                                         : "bg-transparent text-white/40 hover:text-white border border-white/10 hover:border-white/30")">
                            @i
                        </button>
                    }
                    else if (i == 2 || i == ViewBag.TotalPages - 1)
                    {
                        @if((i == 2 && ViewBag.CurrentPage > 3) || (i == ViewBag.TotalPages - 1 && ViewBag.CurrentPage < ViewBag.TotalPages - 2))
                        {
                            <span class="text-white/20 px-1 font-black">...</span>
                        }
                    }
                }
            </div>

            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <button type="button" onclick="changePage(@(ViewBag.CurrentPage + 1))" 
                        class="px-6 py-2 rounded-full bg-white/5 border border-white/10 text-white/80 text-xs font-bold hover:bg-white/10 hover:border-white/20 transition-all flex items-center justify-center group shadow-lg">
                    Next
                    <span class="material-symbols-outlined text-[18px] ml-1 group-hover:translate-x-1 transition-transform">chevron_right</span>
                </button>
            }
        </div>
    </div>
}
