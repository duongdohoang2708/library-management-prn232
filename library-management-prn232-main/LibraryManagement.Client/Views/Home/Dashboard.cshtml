@using LibraryManagementDAL.Models
@using LibraryManagementBLL.Interfaces

@{
    ViewData["Title"] = "System Statistics";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";

    var recentTransactions = ViewBag.RecentTransactions as List<BorrowTransaction> ?? new List<BorrowTransaction>();
    var topDebtors = ViewBag.TopDebtors as List<UserFinesDTO> ?? new List<UserFinesDTO>();
}

<div class="flex-1 p-8 min-w-0 overflow-y-auto custom-scrollbar">

    <div class="mb-10">
        <h1 class="text-4xl font-extrabold text-white tracking-tight mb-2">
            Good afternoon, <span class="text-primary">@User.Identity?.Name</span> 📚
        </h1>
        <p class="text-white/50 text-lg">Here is an overview of the library's status today.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        <div class="bg-white/5 border border-white/10 p-6 rounded-3xl relative overflow-hidden group hover:border-primary/40 transition-all shadow-xl shadow-black/20">
            <div class="absolute -right-6 -bottom-6 w-24 h-24 bg-primary/10 rounded-full blur-2xl group-hover:bg-primary/20 transition-all"></div>
            <div class="flex items-center gap-4 mb-4">
                <div class="p-3 bg-primary/20 rounded-2xl text-primary">
                    <span class="material-symbols-outlined text-3xl">library_books</span>
                </div>
                <div>
                    <p class="text-[11px] font-bold text-white/40 uppercase tracking-widest">Total Books</p>
                    <h3 class="text-3xl font-black text-white">@(((int?)ViewBag.TotalBooks ?? 0).ToString("N0"))</h3>
                </div>
            </div>
            <div class="text-[10px] text-primary/70 font-bold bg-primary/5 w-fit px-2 py-0.5 rounded border border-primary/20">
                Available for lending
            </div>
        </div>

        <div class="bg-white/5 border border-white/10 p-6 rounded-3xl relative overflow-hidden group hover:border-blue-500/40 transition-all shadow-xl shadow-black/20">
            <div class="absolute -right-6 -bottom-6 w-24 h-24 bg-blue-500/10 rounded-full blur-2xl group-hover:bg-blue-500/20 transition-all"></div>
            <div class="flex items-center gap-4 mb-4">
                <div class="p-3 bg-blue-500/20 rounded-2xl text-blue-400">
                    <span class="material-symbols-outlined text-3xl">compare_arrows</span>
                </div>
                <div>
                    <p class="text-[11px] font-bold text-white/40 uppercase tracking-widest">Active Borrows</p>
                    <h3 class="text-3xl font-black text-white">@(((int?)ViewBag.TotalActiveBorrows ?? 0).ToString("N0"))</h3>
                </div>
            </div>
            <div class="text-[10px] text-blue-400/70 font-bold bg-blue-500/5 w-fit px-2 py-0.5 rounded border border-blue-500/20">
                Open sessions
            </div>
        </div>

        <div class="bg-white/5 border border-white/10 p-6 rounded-3xl relative overflow-hidden group hover:border-red-500/40 transition-all shadow-xl shadow-black/20">
            <div class="absolute -right-6 -bottom-6 w-24 h-24 bg-red-500/10 rounded-full blur-2xl group-hover:bg-red-500/20 transition-all"></div>
            <div class="flex items-center gap-4 mb-4">
                <div class="p-3 bg-red-500/20 rounded-2xl text-red-500">
                    <span class="material-symbols-outlined text-3xl">warning</span>
                </div>
                <div>
                    <p class="text-[11px] font-bold text-white/40 uppercase tracking-widest">Overdue</p>
                    <h3 class="text-3xl font-black text-white">@(((int?)ViewBag.OverdueBooksCount ?? 0).ToString("N0"))</h3>
                </div>
            </div>
            <div class="text-[10px] text-red-500/70 font-bold bg-red-500/5 w-fit px-2 py-0.5 rounded border border-red-500/20">
                Needs processing
            </div>
        </div>

        <div class="bg-white/5 border border-white/10 p-6 rounded-3xl relative overflow-hidden group hover:border-green-500/40 transition-all shadow-xl shadow-black/20">
            <div class="absolute -right-6 -bottom-6 w-24 h-24 bg-green-500/10 rounded-full blur-2xl group-hover:bg-green-500/20 transition-all"></div>
            <div class="flex items-center gap-4 mb-4">
                <div class="p-3 bg-green-500/20 rounded-2xl text-green-400">
                    <span class="material-symbols-outlined text-3xl">payments</span>
                </div>
                <div>
                    <p class="text-[11px] font-bold text-white/40 uppercase tracking-widest">Unpaid Fines</p>
                    <h3 class="text-3xl font-black text-white">
                        @(((decimal?)ViewBag.TotalUnpaidFines ?? 0).ToString("N0")) <span class="text-sm font-normal">đ</span>
                    </h3>
                </div>
            </div>
            <div class="text-[10px] text-green-400/70 font-bold bg-green-500/5 w-fit px-2 py-0.5 rounded border border-green-500/20">
                Pending payments
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <div class="lg:col-span-2 bg-black/20 border border-white/10 rounded-3xl overflow-hidden flex flex-col shadow-2xl">
            <div class="p-6 border-b border-white/5 bg-white/5 flex items-center justify-between">
                <h3 class="text-lg font-bold text-white flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">history</span>
                    Recent Transactions
                </h3>
                <a asp-controller="Circulation" asp-action="Index" class="text-xs font-bold text-primary hover:underline">Details</a>
            </div>
            <div class="flex-1 overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-white/5 text-[10px] uppercase font-bold tracking-widest text-white/40">
                        <tr>
                            <th class="px-6 py-4">Borrower</th>
                            <th class="px-6 py-4">Date</th>
                            <th class="px-6 py-4">Due Date</th>
                            <th class="px-6 py-4">Status</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        @foreach (var tx in recentTransactions)
                        {
                            <tr class="hover:bg-white/[0.02] transition-colors group">
                                <td class="px-6 py-5">
                                    <div class="flex items-center gap-3">
                                        <div class="w-9 h-9 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-primary font-bold text-sm">
                                            @tx.User?.FullName?[0]
                                        </div>
                                        <div>
                                            <p class="text-sm font-bold text-white group-hover:text-primary transition-colors">@tx.User?.FullName</p>
                                            <p class="text-[10px] text-white/30 font-mono italic">ID: #@tx.UserId</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-5 text-sm text-white/60">@tx.BorrowDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="px-6 py-5 text-sm text-white/60">@tx.DueDate.ToString("dd/MM/yyyy")</td>
                                <td class="px-6 py-5">
                                    @{
                                        var statusClass = tx.Status == "Returned"
                                        ? "bg-green-500/10 text-green-400 border-green-500/20"
                                        : tx.DueDate < DateTime.UtcNow
                                        ? "bg-red-500/10 text-red-500 border-red-500/20 animate-pulse"
                                        : "bg-blue-500/10 text-blue-400 border-blue-500/20";
                                    }
                                    <span class="px-2 py-1 rounded text-[10px] font-black uppercase border @statusClass">
                                        @(tx.DueDate < DateTime.UtcNow && tx.Status != "Returned" ? "Overdue" : tx.Status)
                                    </span>
                                </td>
                            </tr>
                        }

                        @if (!recentTransactions.Any())
                        {
                            <tr>
                                <td colspan="4" class="px-6 py-8 text-center text-sm text-white/30">
                                    No recent transactions.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="flex flex-col gap-8">
            <div class="bg-primary/10 border border-primary/20 p-8 rounded-3xl relative overflow-hidden">
                <h3 class="text-xl font-black text-primary mb-6 flex items-center">Quick Actions</h3>
                <div class="flex flex-col gap-3">
                    <a asp-controller="Circulation" asp-action="Borrow" class="flex items-center gap-4 bg-primary text-background-dark p-4 rounded-2xl font-black hover:scale-[1.02] active:scale-95 transition-all shadow-lg shadow-primary/20">
                        <span class="material-symbols-outlined">add_circle</span>
                        New Loan
                    </a>
                    <a asp-controller="Inventory" asp-action="Index" class="flex items-center gap-4 bg-white/5 text-white p-4 rounded-2xl font-bold hover:bg-white/10 active:scale-95 transition-all border border-white/10">
                        <span class="material-symbols-outlined text-primary">barcode_reader</span>
                        Check Inventory
                    </a>
                </div>
            </div>

            <div class="bg-white/5 border border-white/10 p-6 rounded-3xl flex flex-col shadow-2xl">
                <h3 class="text-sm font-bold text-white/60 uppercase tracking-widest mb-6 flex items-center justify-between">
                    Top Debtors
                    <span class="material-symbols-outlined text-red-500">priority_high</span>
                </h3>
                <div class="flex flex-col gap-5">
                    @foreach (var debtor in topDebtors)
                    {
                        <div class="flex items-center gap-4 group cursor-pointer" onclick="window.location.href='/Payment/Details?userId=@debtor.UserId'">
                            <div class="w-10 h-10 rounded-full bg-red-500/10 border border-red-500/20 flex items-center justify-center text-red-500 font-bold shadow-lg group-hover:bg-red-500 group-hover:text-background-dark transition-all">
                                @debtor.FullName?[0]
                            </div>
                            <div class="min-w-0">
                                <h4 class="text-xs font-bold text-white truncate group-hover:text-primary transition-colors">@debtor.FullName</h4>
                                <p class="text-[9px] text-white/30 font-mono italic truncate">@debtor.Email</p>
                                <div class="mt-1 flex items-center gap-2">
                                    <span class="text-[10px] font-black text-red-400">@debtor.TotalUnpaidFine.ToString("N0") đ</span>
                                    <span class="text-[8px] text-white/20">•</span>
                                    <span class="text-[9px] text-white/40">@debtor.UnpaidBookCount books owed</span>
                                </div>
                            </div>
                        </div>
                    }

                    @if (!topDebtors.Any())
                    {
                        <p class="text-xs text-white/20 text-center py-4">No unpaid fines.</p>
                    }
                </div>
                <a asp-controller="Payment" asp-action="Index" class="mt-8 text-[10px] font-black text-center text-primary uppercase tracking-[0.2em] hover:tracking-[0.3em] transition-all">
                    Manage Fees & Fines
                </a>
            </div>
        </div>

    </div>
</div>