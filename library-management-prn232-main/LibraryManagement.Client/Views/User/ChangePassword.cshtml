@model LibraryManagementDAL.DTO.Auth.ChangePasswordRequestDto
@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    bool isGoogleAccount = ViewBag.IsGoogleAccount ?? false;
    bool hasPassword = ViewBag.HasPassword ?? true;
    bool needsSetPassword = isGoogleAccount && !hasPassword;
}

<div class="p-6 lg:p-10 max-w-2xl mx-auto min-h-[calc(100vh-200px)] flex flex-col justify-center">
    <div class="bg-white dark:bg-slate-800 rounded-3xl p-8 lg:p-12 border border-slate-200 dark:border-white/5 shadow-2xl shadow-slate-200/50 dark:shadow-none">

        <div class="mb-10 text-center">
            <div class="w-20 h-20 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto mb-6">
                <span class="material-symbols-outlined text-primary text-4xl">@(needsSetPassword ? "security_update_good" : "lock_reset")</span>
            </div>
            <h1 class="text-3xl font-black text-slate-900 dark:text-white mb-2 tracking-tight">@(needsSetPassword ? "Set Password" : "Change Password")</h1>
            <p class="text-slate-500 dark:text-slate-400 font-medium">
                @if (needsSetPassword)
                {
                    <span class="text-emerald-500 font-bold block mb-2">You are logged in with Google!</span>
                    <span>Please set a new password so you can log in directly with Email in the future.</span>
                }
                else
                {
                    <span>Protect your account with a stronger password.</span>
                }
            </p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="mb-8 p-4 bg-rose-50 dark:bg-rose-500/10 border border-rose-200 dark:border-rose-500/20 rounded-2xl text-rose-700 dark:text-rose-400 text-sm font-medium">
                <div asp-validation-summary="All" class="list-disc list-inside"></div>
            </div>
        }

        <form asp-action="ChangePassword" method="post" class="space-y-6">
            @Html.AntiForgeryToken()

            @if (!needsSetPassword)
            {
                <div class="space-y-2">
                    <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Current Password</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl pointer-events-none">lock</span>
                        <input name="CurrentPassword" type="password" class="w-full pl-12 pr-5 py-4 rounded-2xl bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white font-medium focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="••••••••" required />
                    </div>
                </div>
            }
            else
            {
                <input type="hidden" name="CurrentPassword" value="" />
            }

            <div class="space-y-2">
                <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">New Password</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl pointer-events-none">security</span>
                    <input name="NewPassword" type="password" class="w-full pl-12 pr-5 py-4 rounded-2xl bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white font-medium focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="••••••••" required />
                </div>
            </div>

            <div class="space-y-2">
                <label class="block text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Confirm New Password</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-xl pointer-events-none">verified_user</span>
                    <input name="ConfirmNewPassword" type="password" class="w-full pl-12 pr-5 py-4 rounded-2xl bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white font-medium focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="••••••••" required />
                </div>
            </div>

            <div class="pt-6 space-y-4">
                <button type="submit" class="w-full px-10 py-5 bg-primary text-background-dark font-black rounded-2xl hover:bg-primary-hover shadow-xl shadow-primary/30 transition-all active:scale-[0.98] flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined">@(needsSetPassword ? "check_circle" : "key")</span>
                    @(needsSetPassword ? "Set Password" : "Update Password")
                </button>

                <a asp-action="Profile" class="w-full py-4 text-center text-slate-500 dark:text-slate-400 font-bold hover:text-slate-700 dark:hover:text-slate-200 transition-colors flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-lg">arrow_back</span>
                    Back to Profile
                </a>
            </div>
        </form>
    </div>
</div>