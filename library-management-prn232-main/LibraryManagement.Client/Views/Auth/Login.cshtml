@model LibraryManagement.Client.DTO.Auth.LoginRequestDto
@{
    ViewData["Title"] = "Login - LMS Library";
    ViewData["Description"] = "Login to LMS smart library system";
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
}

<!-- Left Branding Panel -->
<div class="hidden lg:flex flex-col justify-between w-[45%] p-12 relative overflow-hidden border-r border-white/5">

    <!-- Top logo -->
    <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center shadow-lg shadow-primary/30">
            <span class="material-symbols-outlined text-background-dark text-xl font-bold">menu_book</span>
        </div>
        <span class="text-white font-bold text-lg tracking-tight">Standard Library</span>
    </div>

    <!-- Center Illustration -->
    <div class="flex flex-col items-center text-center">
        <!-- Decorative book stack visual -->
        <div class="relative mb-10">
            <div class="w-48 h-48 rounded-3xl bg-white/5 border border-white/10 flex items-center justify-center shadow-2xl shadow-black/50">
                <span class="material-symbols-outlined text-[96px] text-primary/80">auto_stories</span>
            </div>
            <!-- Floating badges -->
            <div class="absolute -top-4 -right-4 bg-primary text-background-dark text-xs font-black px-3 py-1.5 rounded-xl shadow-lg shadow-primary/30 flex items-center gap-1.5">
                <span class="material-symbols-outlined text-sm">verified</span>
                Verified
            </div>
            <div class="absolute -bottom-4 -left-4 glass-card text-white text-xs font-semibold px-3 py-1.5 rounded-xl flex items-center gap-1.5">
                <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
                500K+ Books
            </div>
        </div>

        <h1 class="text-3xl font-black text-white mb-4 leading-tight">
            l Vault<br/>
            <span class="text-primary">at your fingertips</span>
        </h1>
        <p class="text-white/50 text-sm leading-relaxed max-w-xs">
            Smart library management system — borrow books, track history, easily manage your account.
        </p>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-3 gap-4">
        <div class="glass-card rounded-xl p-4 text-center">
            <div class="text-primary font-black text-xl">500K+</div>
            <div class="text-white/40 text-xs mt-1">Books</div>
        </div>
        <div class="glass-card rounded-xl p-4 text-center">
            <div class="text-primary font-black text-xl">12K+</div>
            <div class="text-white/40 text-xs mt-1">Readers</div>
        </div>
        <div class="glass-card rounded-xl p-4 text-center">
            <div class="text-primary font-black text-xl">98%</div>
            <div class="text-white/40 text-xs mt-1">Satisfied</div>
        </div>
    </div>
</div>

<!-- Right Form Panel -->
<div class="flex-1 flex flex-col justify-center items-center p-8 lg:p-16">

    <div class="w-full max-w-md">

        <!-- Mobile logo -->
        <div class="flex items-center gap-3 mb-10 lg:hidden">
            <div class="w-9 h-9 bg-primary rounded-xl flex items-center justify-center">
                <span class="material-symbols-outlined text-background-dark text-lg">menu_book</span>
            </div>
            <span class="text-white font-bold">Standard Library</span>
        </div>

        <!-- Header -->
        <div class="mb-8">
            <h2 class="text-3xl font-black text-white mb-2">Welcome Back 👋</h2>
            <p class="text-white/50 text-sm">Log in to continue your reading journey</p>
        </div>

        <!-- Success Message -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="mb-5 flex items-center gap-3 bg-emerald-500/10 border border-emerald-500/20 rounded-xl px-4 py-3 text-emerald-400 text-sm">
                <span class="material-symbols-outlined text-lg">check_circle</span>
                @TempData["SuccessMessage"]
            </div>
        }

        <!-- Validation Summary -->
        @{
            var hasErrors = ViewContext.ModelState.Values.Any(v => v.Errors.Any());
        }
        @if (hasErrors)
        {
            <div class="mb-5 flex items-start gap-3 bg-red-500/10 border border-red-500/20 rounded-xl px-4 py-3 text-red-400 text-sm">
                <span class="material-symbols-outlined text-lg flex-shrink-0 mt-0.5">error</span>
                <div>
                    @foreach (var state in ViewContext.ModelState.Values)
                    {
                        foreach (var error in state.Errors)
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    }
                </div>
            </div>
        }

        <!-- Login Form -->
        <form asp-action="Login" asp-controller="Auth" method="post" id="loginForm" class="space-y-5">
            @Html.AntiForgeryToken()
            @if (ViewBag.ReturnUrl != null)
            {
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
            }

            <!-- Email -->
            <div>
                <label asp-for="Email" class="block text-sm font-semibold text-white/70 mb-2">
                    Email
                </label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-white/30 text-lg pointer-events-none">alternate_email</span>
                    <input asp-for="Email"
                           id="emailInput"
                           class="auth-input !pl-12"
                           placeholder="your@email.com"
                           autocomplete="email"
                           autofocus />
                </div>
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <!-- Password -->
            <div>
                <div class="flex items-center justify-between mb-2">
                    <label asp-for="Password" class="text-sm font-semibold text-white/70">Password</label>
                    <a asp-action="ForgotPassword" asp-controller="Auth" class="text-xs text-primary hover:text-primary/80 transition-colors font-medium">Forgot password?</a>
                </div>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-white/30 text-lg pointer-events-none">lock</span>
                    <input asp-for="Password"
                           id="passwordInput"
                           type="password"
                           class="auth-input !pl-12 !pr-12"
                           placeholder="••••••••"
                           autocomplete="current-password" />
                    <button type="button"
                            id="togglePasswordBtn"
                            class="absolute right-4 top-1/2 -translate-y-1/2 text-white/30 hover:text-white/70 transition-colors"
                            onclick="togglePassword()">
                        <span class="material-symbols-outlined text-lg" id="toggleIcon">visibility_off</span>
                    </button>
                </div>
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <!-- Remember me -->
            <div class="flex items-center gap-3">
                <input asp-for="RememberMe"
                       type="checkbox"
                       id="rememberMe"
                       class="w-4 h-4 rounded border-white/20 bg-white/5 text-primary focus:ring-primary/40 cursor-pointer" />
                <label for="rememberMe" class="text-sm text-white/60 cursor-pointer select-none">
                    Remember me for 7 days
                </label>
            </div>

            <!-- Submit -->
            <button type="submit" id="submitBtn" class="btn-primary-auth flex items-center justify-center gap-2 mt-2">
                <span id="btnIcon" class="material-symbols-outlined text-lg">login</span>
                <span id="btnText">Log In</span>
            </button>
        </form>

        <!-- Divider -->
        <div class="flex items-center gap-4 my-6">
            <div class="flex-1 h-px bg-white/10"></div>
            <span class="text-white/30 text-xs font-medium uppercase tracking-widest">Or</span>
            <div class="flex-1 h-px bg-white/10"></div>
        </div>

        <!-- Google Login -->
        <button id="googleLoginBtn"
                onclick="initiateGoogleLogin()"
                class="btn-social group">
            <!-- Google SVG Icon -->
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4"/>
                <path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 009 18z" fill="#34A853"/>
                <path d="M3.964 10.71A5.41 5.41 0 013.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 000 9c0 1.452.348 2.827.957 4.042l3.007-2.332z" fill="#FBBC05"/>
                <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 00.957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z" fill="#EA4335"/>
            </svg>
            <span class="group-hover:text-white transition-colors">Continue with Google</span>
        </button>

        <!-- Register link -->
        <p class="text-center text-white/40 text-sm mt-8">
            Don't have an account?
            <a asp-action="Register" asp-controller="Auth"
               class="text-primary font-semibold hover:text-primary/80 transition-colors ml-1">
                Register for free
            </a>
        </p>

        <!-- Test accounts hint -->
        <div class="mt-6 p-4 rounded-xl border border-white/5 bg-white/[0.02]">
            <p class="text-white/30 text-xs font-semibold uppercase tracking-widest mb-2">Test accounts</p>
            <div class="grid grid-cols-3 gap-2 text-xs">
                <button onclick="fillCredentials('admin@lms.com','Admin@123')"
                        class="text-left text-white/50 hover:text-primary transition-colors p-2 rounded-lg hover:bg-white/5">
                    <div class="font-semibold text-white/70">👑 Admin</div>
                    <div class="text-white/30 truncate" title="admin@lms.com">admin@lms.com</div>
                </button>
                <button onclick="fillCredentials('librarian1@lms.com','Member@123')"
                        class="text-left text-white/50 hover:text-primary transition-colors p-2 rounded-lg hover:bg-white/5">
                    <div class="font-semibold text-white/70">📚 Librarian</div>
                    <div class="text-white/30 truncate" title="librarian1@lms.com">librarian1@lms.com</div>
                </button>
                <button onclick="fillCredentials('member1@mail.com','Member@123')"
                        class="text-left text-white/50 hover:text-primary transition-colors p-2 rounded-lg hover:bg-white/5">
                    <div class="font-semibold text-white/70">👤 Member</div>
                    <div class="text-white/30 truncate" title="member1@mail.com">member1@mail.com</div>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <!-- Google Identity Services -->
    <script src="https://accounts.google.com/gsi/client" async defer></script>

    <script>
        // Toggle password visibility
        function togglePassword() {
            const input = document.getElementById('passwordInput');
            const icon = document.getElementById('toggleIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.textContent = 'visibility';
            } else {
                input.type = 'password';
                icon.textContent = 'visibility_off';
            }
        }

        // Quick-fill test credentials
        function fillCredentials(email, password) {
            document.getElementById('emailInput').value = email;
            document.getElementById('passwordInput').value = password;
            // Small visual feedback
            document.getElementById('emailInput').classList.add('border-primary/40');
            setTimeout(() => document.getElementById('emailInput').classList.remove('border-primary/40'), 800);
        }

        // Loading state on submit
        document.getElementById('loginForm').addEventListener('submit', function () {
            const btn = document.getElementById('submitBtn');
            const icon = document.getElementById('btnIcon');
            const btnText = document.getElementById('btnText');
            btn.disabled = true;
            btn.classList.add('opacity-80');
            icon.textContent = 'progress_activity';
            icon.classList.add('animate-spin');
            btnText.textContent = "Processing...";
        });

        // Google Sign-In Setup
        const googleBtnOriginalHTML = document.getElementById('googleLoginBtn').innerHTML;
        const googleClientId = '@(ViewBag.GoogleClientId)';

        window.onload = function () {
            if (googleClientId && googleClientId !== 'YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com') {
                google.accounts.id.initialize({
                    client_id: googleClientId,
                    callback: handleGoogleCallback,
                    auto_select: false,
                    cancel_on_tap_outside: true
                });
                console.log("Google SDK Initialized");
            } else {
                console.warn("Google Client ID is not configured properly in appsettings.json");
            }
        };

        function initiateGoogleLogin() {
            try {
                google.accounts.id.prompt((notification) => {
                    if (notification.isNotDisplayed()) {
                        console.warn("Google Prompt not displayed:", notification.getNotDisplayedReason());
                        // Nếu prompt bị chặn (ví dụ do click nhiều lần), có thể dùng phương thức login khác hoặc thông báo
                        if (notification.getNotDisplayedReason() === 'skipped_by_user') {
                             google.accounts.id.prompt(); // Thử gọi lại
                        }
                    }
                });
            } catch (err) {
                console.error("Google Login Error:", err);
                showError("Cannot connect with Google. Please try again later.");
            }
        }

        async function handleGoogleCallback(response) {
            const btn = document.getElementById('googleLoginBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="material-symbols-outlined text-sm animate-spin">progress_activity</span><span>Authenticating...</span>';

            try {
                const res = await fetch('/Auth/LoginWithGoogle', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ idToken: response.credential })
                });
                
                if (res.ok) {
                    const returnUrl = '@(ViewBag.ReturnUrl ?? "")';
                    window.location.href = returnUrl || '/';
                } else {
                    const data = await res.json();
                    showError('Google login failed: ' + (data.message || 'Please try again'));
                    resetGoogleBtn();
                }
            } catch (e) {
                console.error("Fetch Error:", e);
                showError('Server connection error. Please check your network.');
                resetGoogleBtn();
            }
        }

        function resetGoogleBtn() {
            const btn = document.getElementById('googleLoginBtn');
            btn.disabled = false;
            btn.innerHTML = googleBtnOriginalHTML;
        }

        function showError(msg) {
            const existing = document.getElementById('dynamicError');
            if (existing) existing.remove();
            const div = document.createElement('div');
            div.id = 'dynamicError';
            div.className = 'mb-5 flex items-center gap-3 bg-red-500/10 border border-red-500/20 rounded-xl px-4 py-3 text-red-400 text-sm';
            div.innerHTML = '<span class="material-symbols-outlined text-lg">error</span>' + msg;
            document.getElementById('loginForm').before(div);
        }
    </script>
}
