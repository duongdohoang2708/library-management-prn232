@{
    ViewData["Title"] = "Email Sent - LMS Library";
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
}

<div class="flex-1 flex flex-col justify-center items-center p-8 lg:p-16 w-full max-w-2xl mx-auto h-screen">
    
    <div class="text-center bg-white/5 border border-white/10 p-12 rounded-3xl backdrop-blur-md shadow-2xl">
        <div class="w-24 h-24 bg-emerald-500/20 border-4 border-emerald-500/30 rounded-full flex items-center justify-center mx-auto mb-6 text-emerald-400">
            <span class="material-symbols-outlined" style="font-size: 48px">mark_email_read</span>
        </div>
        
        <h1 class="text-3xl font-black text-white mb-4">Check your inbox</h1>
        
        <p class="text-white/60 mb-8 max-w-sm mx-auto leading-relaxed">
            @if (TempData["SuccessMessage"] != null)
            {
                @TempData["SuccessMessage"]
            }
            else
            {
                <text>We've sent a password reset link to your email address.</text>
            }
        </p>
        
        @if (TempData["ResetLink"] != null)
        {
            <!-- Link removed for real SMTP usage. -->
        }

        <a asp-action="Login" asp-controller="Auth" class="btn-primary-auth flex items-center justify-center gap-2 max-w-xs mx-auto">
            <span class="material-symbols-outlined">login</span>
            Return to Login
        </a>
    </div>

</div>
