## Ignore Visual Studio temp files, build results, and files generated by popular IDEs.

# User-specific files
*.rsuser
*.suo
*.user
*.user-serviced
*.userprefs
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache directory
.vs/
# Generated user secrets file
secrets.json

# Roslyn cache directories
*.o
*.obj

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Cc]ontent/

# NUnit
/*.xml
/*.log

# OpenCover
pdf/

# Rider / IntelliJ IDEs
.idea/
*.sln.iml
*.idea.js

# Node.js / NPM (if any frontend client dependencies are used)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Publish output
publish/

# Operating System files
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# Local application secrets/configs
**/appsettings.Local.json

# VS Code workspace settings
.vscode/

# MSBuild binary logs
*.binlog
README.md
library-management-system.sln
